@model List<DuAnTotNghiep.Models.ViewModels.Student.NoteViewModel>
@{
    Layout = "_AILearnLayout";
    ViewData["Title"] = "Ghi chú học tập";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-note-sticky me-2"></i>Ghi chú của tôi</h2>
            <p class="text-muted mb-0">Lưu lại các kiến thức quan trọng và ý tưởng học tập</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4" onclick="openCreateNoteModal()">
            <i class="fa-solid fa-plus me-2"></i>Tạo ghi chú
        </button>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center py-5 rounded-4 border-0">
            <i class="fa-solid fa-clipboard fa-3x mb-3 text-secondary"></i>
            <h5>Bạn chưa có ghi chú nào!</h5>
            <p class="text-muted">Hãy tạo ghi chú đầu tiên của bạn để theo dõi quá trình học tập.</p>
            <button class="btn btn-outline-primary mt-2 rounded-pill" onclick="openCreateNoteModal()">Tạo ghi chú ngay</button>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="notesGrid">
            @foreach (var note in Model)
            {
                <div class="col note-item" id="note-card-@note.Id">
                    <div class="card h-100 border-0 shadow-sm rounded-4 note-card transition-all" style="background-color: #fdfbf7;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-dark text-truncate mb-0" title="@note.Title">@note.Title</h5>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                        <li><a class="dropdown-item" href="#" onclick="openEditNoteModal(@note.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(note.Title))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(note.Content))')"><i class="fa-solid fa-pen text-primary me-2"></i>Chỉnh sửa</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="#" onclick="deleteNote(@note.Id)"><i class="fa-solid fa-trash me-2"></i>Xóa</a></li>
                                    </ul>
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(note.CourseName))
                            {
                                <div class="mb-3">
                                    <span class="badge bg-primary-subtle text-primary rounded-pill"><i class="fa-solid fa-book-open me-1"></i> @note.CourseName</span>
                                    @if (!string.IsNullOrEmpty(note.LessonName))
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill ms-1">@note.LessonName</span>
                                    }
                                </div>
                            }

                            <p class="card-text text-muted note-content">@Html.Raw(note.Content.Replace("\n", "<br/>"))</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0 px-4 pb-3">
                            <small class="text-muted"><i class="fa-regular fa-clock me-1"></i>
                                @if (note.UpdatedAt.HasValue)
                                {
                                    <span>Sửa đổi: @note.UpdatedAt.Value.ToString("dd/MM/yy HH:mm")</span>
                                }
                                else
                                {
                                    <span>Tạo: @note.CreatedAt.ToString("dd/MM/yy HH:mm")</span>
                                }
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<partial name="_NoteForm" />

@section Styles {
    <style>
        .note-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .note-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        }
        .note-content {
            display: -webkit-box;
            -webkit-line-clamp: 6;
            -webkit-box-orient: vertical;
            overflow: hidden;
            font-size: 0.95rem;
            line-height: 1.5;
        }
    </style>
}

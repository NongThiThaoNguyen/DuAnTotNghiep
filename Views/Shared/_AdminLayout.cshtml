@using System.Security.Claims
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string NavClass(string controller, string? action = null)
    {
        var isActive = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));

        return "admin-nav-link group flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all " +
            (isActive
                ? "bg-blue-50 text-blue-700 border border-blue-100 shadow-xs"
                : "text-slate-700 hover:text-blue-600 hover:bg-slate-50");
    }

    var controllerLabel = currentController switch
    {
        "Home" => "Tổng quan",
        "User" => "Quản lý tài khoản",
        "PlacementTests" => "Đề thi đầu vào",
        "PlacementAttempts" => "Lượt thi đầu vào",
        "LearningTopics" => "Chủ đề học tập",
        "TeacherSchedules" => "Lịch giáo viên",
        "ReferenceSources" => "Nguồn tham khảo",
        "ReferenceReview" => "Duyệt nguồn",
        "Notifications" => "Thông báo",
        "Achievements" => "Huy hiệu",
        "AuditLogs" => "Lịch sử hệ thống",
        "Settings" => "Cài đặt",
        "LearningPaths" => "Lộ trình học",
        "PathTemplates" => "Mẫu lộ trình",
        "AIContent" => "Nội dung AI",
        "AiPrompts" => "Prompt AI",
        "AiUsageLogs" => "Nhật ký AI",
        "CompetencyHistory" => "Lịch sử năng lực",
        "EnglishSkills" => "Kỹ năng tiếng Anh",
        "EnglishProficiencyLevels" => "Trình độ tiếng Anh",
        "SchemaStatus" => "Trạng thái hệ thống",
        _ => currentController
    };

    var actionLabel = currentAction switch
    {
        "Index" => "Danh sách",
        "Create" => "Tạo mới",
        "Edit" => "Chỉnh sửa",
        "Details" => "Chi tiết",
        "Pending" => "Chờ duyệt",
        "PathHistory" => "Lịch sử lộ trình",
        "GenerationLogs" => "Nhật ký tạo",
        "PathDetail" => "Chi tiết lộ trình",
        "Preview" => "Xem trước",
        "AuditLogs" => "Nhật ký kiểm tra",
        _ => currentAction
    };
}

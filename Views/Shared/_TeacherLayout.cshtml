@using System.Security.Claims
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Giảng Viên</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6.4 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    
    <!-- AI Learn custom layout and responsive styles -->
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Style overrides to support collapsible submenus and responsive drawer -->
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap');
        
        a, a:hover {
            text-decoration: none !important;
        }
        .sidebar {
            overflow-y: auto;
        }
        .sidebar::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }
        
        /* Premium Button Overrides */
        .btn, .btn-primary-ailearn, .btn-secondary-ailearn, .btn-outline-primary, .btn-outline-secondary {
            text-decoration: none !important;
        }
        
        .btn-primary-ailearn {
            background-color: #6C63FF !important;
            background: #6C63FF !important;
            color: #FFFFFF !important;
            border: none !important;
            border-radius: 9999px !important;
            padding: 10px 24px !important;
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            box-shadow: 0 4px 14px rgba(108, 99, 255, 0.25) !important;
            transition: all 0.25s ease !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-primary-ailearn:hover {
            transform: translateY(-1px) !important;
            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.35) !important;
            background-color: #5A52E6 !important;
            background: #5A52E6 !important;
            color: #FFFFFF !important;
        }
        
        .btn-secondary-ailearn {
            background-color: #F1F5F9 !important;
            color: #334155 !important;
            border: 1px solid #E2E8F0 !important;
            border-radius: 9999px !important;
            padding: 10px 24px !important;
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            transition: all 0.25s ease !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-secondary-ailearn:hover {
            background-color: #E2E8F0 !important;
            color: #1E293B !important;
            transform: translateY(-1px) !important;
        }
        
        /* Action buttons in tables */
        .btn-action-edit {
            background-color: rgba(108, 99, 255, 0.1) !important;
            color: #6C63FF !important;
            border: none !important;
            border-radius: 8px !important;
            width: 34px !important;
            height: 34px !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            transition: all 0.2s ease !important;
            text-decoration: none !important;
        }
        .btn-action-edit:hover {
            background-color: #6C63FF !important;
            color: #FFFFFF !important;
            transform: scale(1.05) !important;
        }
        
        .btn-action-delete {
            background-color: rgba(239, 68, 68, 0.1) !important;
            color: #EF4444 !important;
            border: none !important;
            border-radius: 8px !important;
            width: 34px !important;
            height: 34px !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            transition: all 0.2s ease !important;
            text-decoration: none !important;
        }
        .btn-action-delete:hover {
            background-color: #EF4444 !important;
            color: #FFFFFF !important;
            transform: scale(1.05) !important;
        }
        
        /* Refresh button */
        .btn-refresh-ailearn {
            background-color: #F1F5F9 !important;
            color: #64748B !important;
            border: 1px solid #E2E8F0 !important;
            border-radius: 12px !important;
            width: 42px !important;
            height: 42px !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            transition: all 0.2s ease !important;
            text-decoration: none !important;
        }
        .btn-refresh-ailearn:hover {
            background-color: #E2E8F0 !important;
            color: #334155 !important;
            transform: rotate(45deg) !important;
        }
        
        /* Premium Form Controls */
        .form-control, .form-select {
            border: 1px solid #E2E8F0 !important;
            border-radius: 12px !important;
            padding: 10px 16px !important;
            font-size: 0.9rem !important;
            transition: all 0.2s ease !important;
            background-color: #FFFFFF !important;
        }
        .form-control:focus, .form-select:focus {
            outline: none !important;
            border-color: #6C63FF !important;
            box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.15) !important;
        }

        /* Dynamic Synchronization of Buttons to Brand Purple */
        .bg-blue-600, .bg-indigo-600, .bg-indigo-650, .bg-blue-650, 
        .bg-blue-700, .bg-indigo-700, .hover\:bg-blue-700:hover, 
        .hover\:bg-indigo-700:hover, .btn-primary, .bg-indigo-650,
        a[href*="/Create"].bg-blue-600, a[href*="/Create"].bg-indigo-600,
        a[href*="/Create"].btn-primary-ailearn, a[href*="/Create"].px-4,
        a[href*="/Create"].px-5 {
            background-color: #6C63FF !important;
            background: #6C63FF !important;
            color: #FFFFFF !important;
            border: none !important;
            text-decoration: none !important;
            border-radius: 9999px !important;
            box-shadow: 0 4px 14px rgba(108, 99, 255, 0.25) !important;
        }
        .bg-blue-600:hover, .bg-indigo-600:hover, .bg-blue-700:hover, 
        .bg-indigo-700:hover, .btn-primary:hover,
        a[href*="/Create"].bg-blue-600:hover, a[href*="/Create"].bg-indigo-600:hover,
        a[href*="/Create"].btn-primary-ailearn:hover {
            background-color: #5A52E6 !important;
            background: #5A52E6 !important;
            color: #FFFFFF !important;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.35) !important;
        }
        
        /* Red/Danger Warning Buttons Sync */
        .bg-red-650, .bg-red-700, .btn-danger, .btn-danger-ailearn,
        button[type="submit"].bg-red-650, button[type="submit"].bg-red-700 {
            background-color: #EF4444 !important;
            background: #EF4444 !important;
            color: #FFFFFF !important;
            border-radius: 9999px !important;
            border: none !important;
            box-shadow: 0 4px 14px rgba(239, 68, 68, 0.25) !important;
            font-weight: 600 !important;
            transition: all 0.25s ease !important;
            padding: 10px 24px !important;
        }
        .bg-red-650:hover, .bg-red-700:hover, .btn-danger:hover, .btn-danger-ailearn:hover,
        button[type="submit"].bg-red-650:hover, button[type="submit"].bg-red-700:hover {
            background-color: #DC2626 !important;
            background: #DC2626 !important;
            box-shadow: 0 6px 20px rgba(239, 68, 68, 0.35) !important;
            transform: translateY(-1px);
        }
        
        /* Links and Text Brand color sync */
        .text-blue-600, .text-indigo-600, .text-blue-650, .text-indigo-650, 
        .hover\:text-blue-700:hover, .hover\:text-indigo-700:hover {
            color: #6C63FF !important;
        }
        .text-blue-600:hover, .text-indigo-600:hover {
            color: #5A52E6 !important;
        }
        
        /* Border color sync */
        .border-blue-600, .border-indigo-600, .border-blue-500, .border-indigo-500 {
            border-color: #6C63FF !important;
        }
        
        /* Shadows sync */
        .shadow-blue-600\/10, .shadow-purple-500\/20, .shadow-purple-500\/15 {
            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.2) !important;
        }

        /* Kill browser default underlines globally for main content area links */
        .main-content a {
            text-decoration: none !important;
        }

        /* Premium Toast Notifications */
        #toastContainer {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 99999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
            max-width: 380px;
            width: 100%;
        }
        .toast-notification {
            pointer-events: auto;
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(10px) !important;
            -webkit-backdrop-filter: blur(10px) !important;
            border: 1px solid rgba(255, 255, 255, 0.5) !important;
            border-radius: 16px !important;
            padding: 16px 20px !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08), 0 1px 3px rgba(0, 0, 0, 0.02) !important;
            display: flex;
            align-items: center;
            gap: 14px;
            transform: translateX(120%);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }
        .toast-notification.show {
            transform: translateX(0);
        }
        .toast-notification::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
        }
        .toast-notification.success::before { background-color: #10B981; }
        .toast-notification.danger::before { background-color: #EF4444; }
        .toast-notification.warning::before { background-color: #F59E0B; }
        .toast-notification.info::before { background-color: #3B82F6; }

        .toast-icon {
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .toast-notification.success .toast-icon { color: #10B981; }
        .toast-notification.danger .toast-icon { color: #EF4444; }
        .toast-notification.warning .toast-icon { color: #F59E0B; }
        .toast-notification.info .toast-icon { color: #3B82F6; }

        .toast-content {
            flex-grow: 1;
        }
        .toast-title {
            font-weight: 700;
            font-size: 0.85rem;
            color: #1E293B;
            margin: 0 0 2px 0;
        }
        .toast-message {
            font-size: 0.8rem;
            color: #64748B;
            margin: 0;
            line-height: 1.4;
        }
        .toast-close {
            background: none;
            border: none;
            color: #94A3B8;
            cursor: pointer;
            padding: 4px;
            font-size: 0.85rem;
            transition: color 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .toast-close:hover {
            color: #64748B;
        }

        /* ==========================================
           PREMIUM FORM DESIGN SYSTEM FOR TEACHER WORKSPACE
           ========================================== */
        
        /* Premium Form Card container */
        .main-content .bg-white.rounded-2xl {
            border: 1px solid rgba(108, 99, 255, 0.12) !important;
            box-shadow: 0 10px 30px -5px rgba(108, 99, 255, 0.04), 0 8px 16px -6px rgba(108, 99, 255, 0.02) !important;
            background: linear-gradient(135deg, #FFFFFF 0%, #FAFAFF 100%) !important;
            position: relative;
            overflow: hidden;
            animation: formFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        
        @@keyframes formFadeIn {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Top Accent bar for Form Card */
        .main-content .bg-white.rounded-2xl::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #6C63FF 0%, #8F8AFF 50%, #B8B5FF 100%) !important;
        }

        /* Enforce elegant styles on Bootstrap Modals globally */
        .modal-content {
            background: linear-gradient(135deg, #FFFFFF 0%, #FAFAFF 100%) !important;
            border: 1px solid rgba(108, 99, 255, 0.15) !important;
            box-shadow: 0 20px 50px rgba(108, 99, 255, 0.15) !important;
            border-radius: 20px !important;
            position: relative;
            overflow: hidden;
        }
        
        .modal-content::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 5px;
            background: linear-gradient(90deg, #6C63FF 0%, #8F8AFF 50%, #B8B5FF 100%) !important;
            border-top-left-radius: 20px;
            border-top-right-radius: 20px;
            z-index: 1051;
        }
        
        .modal-header {
            border-bottom: 1px solid rgba(108, 99, 255, 0.08) !important;
            padding: 24px 30px !important;
            background: rgba(108, 99, 255, 0.02) !important;
        }
        
        #globalAjaxModalLabel {
            color: #1E293B !important;
            font-weight: 800 !important;
            font-size: 1.25rem !important;
            letter-spacing: -0.01em;
        }

        .modal-body {
            padding: 30px 40px !important;
        }

        /* Eliminate duplicate white-on-white card layouts inside AJAX modals */
        #globalAjaxModalBody .bg-white.rounded-2xl,
        #globalAjaxModalBody .bg-white.p-6,
        #globalAjaxModalBody .bg-white.p-8,
        #globalAjaxModalBody .bg-white.p-6.sm\:p-8 {
            border: none !important;
            box-shadow: none !important;
            background: transparent !important;
            padding: 0 !important;
            animation: none !important;
        }
        
        #globalAjaxModalBody .bg-white.rounded-2xl::after {
            display: none !important;
        }
        
        /* Form fields spacing & structure */
        .main-content form .space-y-5 > * + *, .main-content form .space-y-6 > * + * {
            margin-top: 1.25rem !important;
        }
        
        /* Elegant Labels */
        .main-content label,
        #globalAjaxModalBody label {
            color: #475569 !important; /* slate-600 */
            font-size: 0.72rem !important;
            font-weight: 700 !important;
            letter-spacing: 0.06em !important;
            text-transform: uppercase !important;
            margin-bottom: 0.4rem !important;
            display: inline-flex !important;
            align-items: center;
            gap: 6px;
        }
        
        /* Add styled prefix to label */
        .main-content label::before,
        #globalAjaxModalBody label::before {
            content: '';
            display: inline-block;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background-color: #6C63FF;
            opacity: 0.7;
        }
        
        /* Premium Input / Select Styles */
        .main-content input[type="text"], 
        .main-content input[type="number"], 
        .main-content input[type="email"], 
        .main-content input[type="password"], 
        .main-content input[type="datetime-local"], 
        .main-content select, 
        .main-content textarea,
        #globalAjaxModalBody input,
        #globalAjaxModalBody select,
        #globalAjaxModalBody textarea,
        #globalAjaxModalBody .form-control,
        #globalAjaxModalBody .form-select {
            background-color: #F8FAFC !important; /* soft slate background */
            border: 1px solid #E2E8F0 !important;
            border-radius: 12px !important;
            padding: 10px 16px !important;
            font-size: 0.88rem !important;
            color: #1E293B !important;
            transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1) !important;
            box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.01) !important;
            height: 46px !important;
            font-weight: 500 !important;
        }
        
        .main-content textarea,
        #globalAjaxModalBody textarea {
            height: auto !important;
        }

        /* Custom Arrow Chevron style for dropdown select fields */
        .main-content select, 
        #globalAjaxModalBody select,
        .form-select,
        #globalAjaxModalBody .form-select {
            appearance: none !important;
            -webkit-appearance: none !important;
            -moz-appearance: none !important;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%236C63FF' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
            background-repeat: no-repeat !important;
            background-position: right 16px center !important;
            background-size: 12px 12px !important;
            padding-right: 40px !important;
        }
        
        .main-content input:hover,
        .main-content select:hover,
        .main-content textarea:hover,
        #globalAjaxModalBody input:hover,
        #globalAjaxModalBody select:hover,
        #globalAjaxModalBody textarea:hover {
            border-color: #CBD5E1 !important;
            background-color: #F1F5F9 !important;
        }
        
        .main-content input:focus, 
        .main-content select:focus, 
        .main-content textarea:focus,
        #globalAjaxModalBody input:focus,
        #globalAjaxModalBody select:focus,
        #globalAjaxModalBody textarea:focus {
            background-color: #FFFFFF !important;
            border-color: #6C63FF !important;
            box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.12), 0 4px 10px rgba(108, 99, 255, 0.05) !important;
            transform: translateY(-1px);
            outline: none !important;
        }

        /* Style placeholder text */
        ::placeholder,
        #globalAjaxModalBody ::placeholder {
            color: #94A3B8 !important;
            font-weight: 400 !important;
            font-size: 0.85rem !important;
        }
        
        /* Styled validation error callouts */
        .validation-summary-errors, 
        .main-content .text-danger, 
        .main-content .text-red-500,
        #globalAjaxModalBody .text-danger {
            font-size: 0.78rem !important;
            font-weight: 500 !important;
            color: #EF4444 !important;
        }
        
        .validation-summary-errors,
        #globalAjaxModalBody .validation-summary-errors {
            background-color: #FEF2F2 !important;
            border: 1px dashed rgba(239, 68, 68, 0.25) !important;
            padding: 12px 16px !important;
            border-radius: 12px !important;
            margin-bottom: 1.25rem !important;
        }
        
        .validation-summary-errors ul {
            margin: 0 !important;
            padding-left: 1.2rem !important;
            list-style-type: square !important;
        }
        
        /* Styled cancel buttons inside modal */
        #globalAjaxModalBody a.btn-secondary-ailearn,
        #globalAjaxModalBody a.border-slate-200 {
            background-color: #FFFFFF !important;
            color: #64748B !important;
            border: 1px solid #E2E8F0 !important;
            border-radius: 9999px !important;
            padding: 10px 28px !important;
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            transition: all 0.2s ease !important;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02) !important;
            height: 42px !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        
        #globalAjaxModalBody a.btn-secondary-ailearn:hover,
        #globalAjaxModalBody a.border-slate-200:hover {
            background-color: #F8FAFC !important;
            color: #334155 !important;
            border-color: #CBD5E1 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03) !important;
        }
        
        /* Styled Submit buttons inside modal */
        #globalAjaxModalBody button[type="submit"],
        #globalAjaxModalBody .btn-primary-ailearn {
            background: linear-gradient(135deg, #6C63FF 0%, #5A52E6 100%) !important;
            border: none !important;
            border-radius: 9999px !important;
            color: #FFFFFF !important;
            padding: 10px 28px !important;
            font-weight: 700 !important;
            font-size: 0.85rem !important;
            letter-spacing: 0.02em;
            box-shadow: 0 4px 14px rgba(108, 99, 255, 0.25) !important;
            transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1) !important;
            height: 42px !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        
        #globalAjaxModalBody button[type="submit"]:hover,
        #globalAjaxModalBody .btn-primary-ailearn:hover {
            transform: translateY(-1.5px) !important;
            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.35) !important;
            filter: brightness(1.05);
        }
        
        /* Redefining Delete views specifically */
        .main-content .w-12.h-12.bg-red-50,
        .main-content div[class*="bg-red-50"],
        #globalAjaxModalBody .w-12.h-12.bg-red-50,
        #globalAjaxModalBody div[class*="bg-red-50"] {
            width: 60px !important;
            height: 60px !important;
            background-color: rgba(239, 68, 68, 0.08) !important;
            border: 1px solid rgba(239, 68, 68, 0.15) !important;
            border-radius: 50% !important;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem auto !important;
            position: relative;
        }
        
        .main-content .w-12.h-12.bg-red-50::before,
        .main-content div[class*="bg-red-50"]::before,
        #globalAjaxModalBody .w-12.h-12.bg-red-50::before,
        #globalAjaxModalBody div[class*="bg-red-50"]::before {
            content: '';
            position: absolute;
            top: -4px; left: -4px; right: -4px; bottom: -4px;
            border-radius: 50%;
            border: 1px solid rgba(239, 68, 68, 0.2);
            animation: pulseRed 2s infinite;
        }
        
        @@keyframes pulseRed {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(1.15); opacity: 0; }
        }
        
        .main-content .w-12.h-12.bg-red-50 svg,
        .main-content div[class*="bg-red-50"] svg,
        #globalAjaxModalBody .w-12.h-12.bg-red-50 svg,
        #globalAjaxModalBody div[class*="bg-red-50"] svg {
            color: #EF4444 !important;
            width: 24px !important;
            height: 24px !important;
        }
        
        /* Detail displays / metadata fields */
        .main-content span.text-slate-400.font-bold,
        #globalAjaxModalBody span.text-slate-400.font-bold {
            color: #64748B !important;
            font-size: 0.72rem !important;
            font-weight: 700 !important;
            letter-spacing: 0.05em !important;
            margin-bottom: 0.25rem !important;
        }
        
        .main-content span.text-slate-800,
        #globalAjaxModalBody span.text-slate-800 {
            color: #1E293B !important;
            font-weight: 600 !important;
        }

        body, button, input, select, textarea, span, p, h1, h2, h3, h4, h5, h6, .font-sans, [class*="font-sans"] {
            font-family: 'Be Vietnam Pro', sans-serif !important;
        }

        /* Minimize top gap between the app header and content block */
        .main-content {
            padding: 20px 32px 32px 32px !important;
        }

        .app-header {
            margin-bottom: 16px !important;
            padding-bottom: 16px !important;
            border-bottom: 1px solid rgba(226, 232, 240, 0.6) !important;
        }

        .app-header .search-box input {
            height: 38px !important;
            border-radius: 9999px !important;
            background-color: #F8FAFC !important;
            border: 1px solid #E2E8F0 !important;
            font-size: 0.82rem !important;
            padding-left: 38px !important;
            transition: all 0.2s ease !important;
        }

        .app-header .search-box input:focus {
            background-color: #FFFFFF !important;
            border-color: #6C63FF !important;
            box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.1) !important;
        }

        .app-header .search-box i {
            left: 14px !important;
            color: #94A3B8 !important;
        }

        .main-content .search-box input {
            padding-left: 42px !important;
        }

        .main-content .search-box i {
            left: 16px !important;
            color: #94A3B8 !important;
            position: absolute !important;
            top: 50% !important;
            transform: translateY(-50%) !important;
        }

        /* Stretch constrained layouts (Schedule, Profile, Reports, etc.) to full-width matching Image 2 */
        .main-content .max-w-7xl,
        .main-content .max-w-6xl,
        .main-content .max-w-5xl,
        .main-content .max-w-4xl,
        .main-content .max-w-3xl {
            max-width: 100% !important;
            width: 100% !important;
            margin-top: 0 !important;
            padding-top: 0 !important;
        }

        /* Polished Headers & Subtitles Typography */
        .main-content h1 {
            font-size: 1.55rem !important;
            font-weight: 800 !important;
            color: #0F172A !important; /* Slate-900 */
            letter-spacing: -0.025em !important;
            margin-bottom: 2px !important;
        }

        .main-content p.text-slate-500,
        .main-content p.text-muted {
            color: #64748B !important; /* Slate-500 */
            font-size: 0.82rem !important;
            font-weight: 400 !important;
            margin-top: 0 !important;
        }

        /* Polish Inner Card Category Headers */
        .main-content h4.text-sm.font-bold,
        .main-content h4[class*="tracking-wider"],
        #globalAjaxModalBody h4 {
            font-size: 0.82rem !important;
            letter-spacing: 0.08em !important;
            color: #4F46E5 !important; /* indigo-600 */
            font-weight: 700 !important;
            text-transform: uppercase !important;
            border-bottom: 2px solid #F1F5F9 !important;
            padding-bottom: 8px !important;
            display: block !important;
            margin-top: 1.25rem !important;
            margin-bottom: 1.25rem !important;
        }

        /* Modernized table component overrides for dashboard pages */
        .main-content table {
            border-collapse: separate !important;
            border-spacing: 0 !important;
            width: 100% !important;
        }

        .main-content table thead th,
        .main-content table tr.bg-slate-50\/50 th {
            background-color: #F8FAFC !important;
            color: #475569 !important; /* slate-600 */
            font-weight: 700 !important;
            font-size: 0.72rem !important;
            letter-spacing: 0.06em !important;
            text-transform: uppercase !important;
            padding: 14px 20px !important;
            border-bottom: 2px solid #E2E8F0 !important;
            border-top: none !important;
        }

        .main-content table tbody td {
            padding: 16px 20px !important;
            font-size: 0.85rem !important;
            color: #334155 !important; /* slate-700 */
            vertical-align: middle !important;
            border-bottom: 1px solid #F1F5F9 !important;
        }

        .main-content table tbody tr:hover {
            background-color: rgba(108, 99, 255, 0.01) !important;
        }

        /* Premium status badge highlights */
        .purple-badge,
        .bg-purple-50.text-purple-650 {
            background-color: rgba(108, 99, 255, 0.08) !important;
            color: #6C63FF !important;
            border: 1px solid rgba(108, 99, 255, 0.15) !important;
            font-size: 0.72rem !important;
            font-weight: 700 !important;
            padding: 4px 10px !important;
            border-radius: 9999px !important;
            display: inline-block;
        }

        .bg-blue-50.text-blue-650 {
            background-color: rgba(59, 130, 246, 0.08) !important;
            color: #2563EB !important;
            border: 1px solid rgba(59, 130, 246, 0.15) !important;
            font-size: 0.72rem !important;
            font-weight: 700 !important;
            padding: 4px 10px !important;
            border-radius: 9999px !important;
            display: inline-block;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div>
                <!-- Brand logo -->
                <a href="/Teacher" class="sidebar-logo">
                    <div class="logo-icon">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <div class="logo-text">AI Learn</div>
                </a>

                <!-- Menus -->
                <ul class="sidebar-menu">
                    @{
                        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                        var action = ViewContext.RouteData.Values["action"]?.ToString();
                    }
                    <li class="menu-item @(controller == "Home" ? "active" : "")">
                        <a href="/Teacher">
                            <i class="fa-solid fa-house"></i>
                            <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Courses" ? "active" : "")">
                        <a href="/Teacher/Courses">
                            <i class="fa-solid fa-graduation-cap"></i>
                            <span>Khóa học giảng dạy</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Lessons" ? "active" : "")">
                        <a href="/Teacher/Lessons">
                            <i class="fa-solid fa-book-open"></i>
                            <span>Quản lý Bài học</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Assignments" ? "active" : "")">
                        <a href="/Teacher/Assignments">
                            <i class="fa-solid fa-clipboard-list"></i>
                            <span>Quản lý Bài tập</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Quizzes" ? "active" : "")">
                        <a href="/Teacher/Quizzes">
                            <i class="fa-solid fa-lightbulb"></i>
                            <span>Quản lý Quiz</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Students" ? "active" : "")">
                        <a href="/Teacher/Students">
                            <i class="fa-solid fa-users"></i>
                            <span>Quản lý Học viên</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Grades" ? "active" : "")">
                        <a href="/Teacher/Grades">
                            <i class="fa-solid fa-award"></i>
                            <span>Quản lý Điểm số</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Attendance" ? "active" : "")">
                        <a href="/Teacher/Attendance">
                            <i class="fa-solid fa-user-check"></i>
                            <span>Điểm danh</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Resources" ? "active" : "")">
                        <a href="/Teacher/Resources">
                            <i class="fa-solid fa-folder-open"></i>
                            <span>Tài liệu học tập</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Messages" ? "active" : "")">
                        <a href="/Teacher/Messages">
                            <i class="fa-solid fa-comment-dots"></i>
                            <span>Tin nhắn</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Schedule" ? "active" : "")">
                        <a href="/Teacher/Schedule">
                            <i class="fa-solid fa-calendar-days"></i>
                            <span>Lịch dạy</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Reports" ? "active" : "")">
                        <a href="/Teacher/Reports">
                            <i class="fa-solid fa-chart-simple"></i>
                            <span>Báo cáo tổng hợp</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Profile" ? "active" : "")">
                        <a href="/Teacher/Profile">
                            <i class="fa-solid fa-user-gear"></i>
                            <span>Hồ sơ cá nhân</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Settings" ? "active" : "")">
                        <a href="/Teacher/Settings">
                            <i class="fa-solid fa-sliders"></i>
                            <span>Cài đặt</span>
                        </a>
                    </li>
                    <li class="menu-item">
                        <a href="/Account/Logout">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span>Đăng xuất</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Bottom User Profile Info -->
            <div class="sidebar-user">
                <img src="@(User.FindFirst("AvatarUrl")?.Value ?? "/default-images/avatar.png")" alt="Avatar" class="user-avatar-sidebar" onerror="this.src='https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "GV")&background=6C63FF&color=fff'" />
                <div class="user-info-sidebar">
                    <span class="user-name-sidebar">@User.Identity?.Name</span>
                    <span class="user-role-sidebar">Giảng viên</span>
                </div>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <main class="main-content">
            <!-- Header bar -->
            <header class="app-header">
                <!-- Search -->
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Tìm kiếm nhanh..." id="headerSearchInput" />
                </div>

                <!-- Header Actions -->
                <div class="header-actions">
                    <!-- Notification -->
                    <button class="notification-btn" title="Thông báo">
                        <i class="fa-regular fa-bell"></i>
                        <span class="notification-badge"></span>
                    </button>

                    <!-- User Profile Dropdown -->
                    <a href="/Teacher/Profile" class="profile-dropdown-btn">
                        <img src="@(User.FindFirst("AvatarUrl")?.Value ?? "/default-images/avatar.png")" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "GV")&background=6C63FF&color=fff'" />
                        <span class="d-none d-md-inline">@User.Identity?.Name</span>
                    </a>
                </div>
            </header>

            <!-- Render Main View Content -->
            <div class="container-fluid p-0 flex-grow-1">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Global AJAX Modal -->
    <div class="modal fade" id="globalAjaxModal" tabindex="-1" aria-labelledby="globalAjaxModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 rounded-2xl shadow-lg">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title font-weight-bold text-dark px-4 pt-3" id="globalAjaxModalLabel">Thao tác</h5>
                    <button type="button" class="btn-close me-3 mt-3" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4" id="globalAjaxModalBody">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer"></div>

    <!-- Scripts -->
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap 5.3 JavaScript Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- jQuery Validation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>

    <!-- Global Modal & Toast Interceptor Script -->
    <script>
        function showToast(message, type = 'success', title = '') {
            const container = document.getElementById('toastContainer');
            if (!container) return;

            // Generate title based on type if empty
            if (!title) {
                title = type === 'success' ? 'Thành công' : 
                        type === 'danger' ? 'Lỗi' : 
                        type === 'warning' ? 'Cảnh báo' : 'Thông báo';
            }

            // Get corresponding icon
            const icon = type === 'success' ? 'fa-circle-check' : 
                         type === 'danger' ? 'fa-circle-xmark' : 
                         type === 'warning' ? 'fa-triangle-exclamation' : 'fa-circle-info';

            const toast = document.createElement('div');
            toast.className = `toast-notification ${type}`;
            toast.innerHTML = `
                <div class="toast-icon">
                    <i class="fa-solid ${icon}"></i>
                </div>
                <div class="toast-content">
                    <h5 class="toast-title">${title}</h5>
                    <p class="toast-message">${message}</p>
                </div>
                <button class="toast-close" onclick="this.parentElement.remove()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            `;

            container.appendChild(toast);

            // Trigger animation frame to slide in
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });

            // Auto remove after 4 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                // Remove element after transition ends
                toast.addEventListener('transitionend', () => {
                    toast.remove();
                });
            }, 4000);
        }

        // Show TempData alerts on load
        $(document).ready(function() {
            @if (TempData["Success"] != null) {
                <text>showToast('@Html.Raw(TempData["Success"])', 'success');</text>
            }
            @if (TempData["Error"] != null) {
                <text>showToast('@Html.Raw(TempData["Error"])', 'danger');</text>
            }
            @if (TempData["Warning"] != null) {
                <text>showToast('@Html.Raw(TempData["Warning"])', 'warning');</text>
            }
            @if (TempData["Info"] != null) {
                <text>showToast('@Html.Raw(TempData["Info"])', 'info');</text>
            }
        });
        function polishButtons() {
            // Remove text underlines from all buttons and specific action links
            $('.btn, .btn-primary-ailearn, .btn-secondary-ailearn, .btn-outline-primary, .btn-outline-secondary, a[href*="/Edit/"], a[href*="/Delete/"], a[href*="/Details/"]').css('text-decoration', 'none');

            // Convert raw action links to premium action buttons in tables
            $('a[href*="/Edit/"]').each(function() {
                const $btn = $(this);
                if ($btn.find('.fa-pen, .fa-pencil, .fa-edit').length > 0 || $btn.attr('title') === 'Sửa' || $btn.text().trim() === '') {
                    $btn.removeClass().addClass('btn-action-edit').attr('title', 'Sửa').html('<i class="fa-solid fa-pen"></i>');
                }
            });
            
            $('a[href*="/Delete/"]').each(function() {
                const $btn = $(this);
                if ($btn.find('.fa-trash, .fa-trash-can, .fa-destroy').length > 0 || $btn.attr('title') === 'Xóa' || $btn.text().trim() === '') {
                    $btn.removeClass().addClass('btn-action-delete').attr('title', 'Xóa').html('<i class="fa-solid fa-trash"></i>');
                }
            });
            
            // Format refresh buttons
            $('a[href*="/Teacher/"][title*="mới"], a[href*="/Teacher/"][title*="Refresh"], a[href*="/Teacher/"][title*="Mới"], a[title="Làm mới"]').each(function() {
                const href = $(this).attr('href');
                if (href && (href.endsWith('/Courses') || href.endsWith('/Lessons') || href.endsWith('/Assignments') || href.endsWith('/Quizzes') || href.endsWith('/Schedule') || href.endsWith('/Resources'))) {
                    $(this).removeClass().addClass('btn-refresh-ailearn').html('<i class="fa-solid fa-rotate"></i>');
                }
            });
        }

        $(document).ready(function() {
            polishButtons();
            
            // Re-polish when content changes (ajax, pagination, etc.)
            $(document).ajaxComplete(function() {
                polishButtons();
            });

            $(document).on('click', 'a[href*="/Teacher/"]', function(e) {
                const href = $(this).attr('href');
                if (!href) return;
                
                const lowerHref = href.toLowerCase();
                const isCreate = lowerHref.includes('/create') && !lowerHref.includes('questionbank');
                const isEdit = lowerHref.includes('/edit');
                const isDelete = lowerHref.includes('/delete');
                const isGrade = lowerHref.includes('/grade/'); // For grading popup
                
                if (!isCreate && !isEdit && !isDelete && !isGrade) return;
                if ($(this).hasClass('no-modal') || $(this).attr('target') === '_blank') return;
                
                e.preventDefault();
                
                const title = $(this).attr('title') || $(this).text().trim() || 'Thao tác';
                
                const $dialog = $('#globalAjaxModal .modal-dialog');
                if (isDelete) {
                    $dialog.removeClass('modal-lg').addClass('modal-md');
                } else {
                    $dialog.removeClass('modal-md').addClass('modal-lg');
                }
                
                $('#globalAjaxModalLabel').text(title);
                $('#globalAjaxModalBody').html(`
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                `);
                
                const modalEl = document.getElementById('globalAjaxModal');
                const myModal = new bootstrap.Modal(modalEl);
                myModal.show();
                
                $.get(href, function(html) {
                    const $parsed = $(html);
                    
                    let $content = $parsed.find('.max-w-2xl, .max-w-md, .max-w-4xl, .max-w-7xl');
                    if ($content.length === 0) {
                        $content = $parsed.find('form');
                    }
                    if ($content.length === 0) {
                        $content = $parsed;
                    }
                    
                    // Defensive cleanup: ensure sidebar and top layout headers are never loaded inside modal
                    $content.find('.sidebar, .app-header, header, aside, .sidebar-user').remove();
                    $content.find('.flex.items-center.gap-2, a:contains("Quay lại"), a:contains("back")').remove();
                    $content.find('h1, h2, p.text-muted').remove();
                    
                    $('#globalAjaxModalBody').html($content);
                    
                    // Style buttons inside modal
                    polishButtons();
                    
                    if (window.jQuery && $.validator && $.validator.unobtrusive) {
                        $.validator.unobtrusive.parse("#globalAjaxModalBody form");
                    }
                    
                    $('#globalAjaxModalBody form').on('submit', function(eForm) {
                        if ($(this).data('validator') && !$(this).valid()) {
                            return;
                        }
                        
                        eForm.preventDefault();
                        
                        const formAction = $(this).attr('action') || href;
                        const formData = new FormData(this);
                        
                        const $submitBtn = $(this).find('button[type="submit"]');
                        const originalBtnHtml = $submitBtn.html();
                        $submitBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Đang lưu...');
                        
                        $.ajax({
                            url: formAction,
                            type: 'POST',
                            data: formData,
                            processData: false,
                            contentType: false,
                            success: function(response) {
                                if (response.indexOf('<!DOCTYPE html>') !== -1 || response.indexOf('app-container') !== -1) {
                                    myModal.hide();
                                    window.location.reload();
                                } else {
                                    const $resParsed = $(response);
                                    let $resContent = $resParsed.find('.max-w-2xl, .max-w-md, .max-w-4xl, .max-w-7xl');
                                    if ($resContent.length === 0) {
                                        $resContent = $resParsed.find('form');
                                    }
                                    if ($resContent.length === 0) {
                                        $resContent = $resParsed;
                                    }
                                    $resContent.find('.sidebar, .app-header, header, aside, .sidebar-user').remove();
                                    $resContent.find('.flex.items-center.gap-2, a:contains("Quay lại"), a:contains("back")').remove();
                                    $resContent.find('h1, h2, p.text-muted').remove();
                                    
                                    $('#globalAjaxModalBody').html($resContent);
                                    polishButtons();
                                    if ($.validator && $.validator.unobtrusive) {
                                        $.validator.unobtrusive.parse("#globalAjaxModalBody form");
                                    }
                                }
                            },
                            error: function() {
                                $submitBtn.prop('disabled', false).html(originalBtnHtml);
                                alert('Đã xảy ra lỗi khi gửi yêu cầu. Vui lòng thử lại.');
                            }
                        });
                    });
                    
                    // Bind cancel buttons inside modal to close it instead of redirecting
                    $('#globalAjaxModalBody').find('a:contains("Hủy"), a:contains("Cancel")').removeClass().addClass('btn btn-secondary-ailearn no-modal').on('click', function(eCancel) {
                        eCancel.preventDefault();
                        myModal.hide();
                    });
                }).fail(function() {
                    $('#globalAjaxModalBody').html('<p class="text-danger text-center">Không thể tải nội dung. Vui lòng thử lại.</p>');
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


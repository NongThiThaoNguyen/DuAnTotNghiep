@using System.Security.Claims
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Learn (Teacher)</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6.4 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    
    <!-- AI Learn custom layout and responsive styles -->
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Style overrides to support collapsible submenus and responsive drawer -->
    <style>
        .sidebar {
            overflow-y: auto;
        }
        .sidebar::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div>
                <!-- Brand logo -->
                <a href="/Teacher" class="sidebar-logo">
                    <div class="logo-icon">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <div class="logo-text">AI Learn</div>
                </a>

                <!-- Menus -->
                <ul class="sidebar-menu">
                    @{
                        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                        var action = ViewContext.RouteData.Values["action"]?.ToString();
                    }
                    <li class="menu-item @(controller == "Home" ? "active" : "")">
                        <a href="/Teacher">
                            <i class="fa-solid fa-house"></i>
                            <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Courses" ? "active" : "")">
                        <a href="/Teacher/Courses">
                            <i class="fa-solid fa-graduation-cap"></i>
                            <span>Khóa học giảng dạy</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Lessons" ? "active" : "")">
                        <a href="/Teacher/Lessons">
                            <i class="fa-solid fa-book-open"></i>
                            <span>Quản lý Bài học</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Assignments" ? "active" : "")">
                        <a href="/Teacher/Assignments">
                            <i class="fa-solid fa-clipboard-list"></i>
                            <span>Quản lý Bài tập</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Quizzes" ? "active" : "")">
                        <a href="/Teacher/Quizzes">
                            <i class="fa-solid fa-lightbulb"></i>
                            <span>Quản lý Quiz</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Students" ? "active" : "")">
                        <a href="/Teacher/Students">
                            <i class="fa-solid fa-users"></i>
                            <span>Quản lý Học viên</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Grades" ? "active" : "")">
                        <a href="/Teacher/Grades">
                            <i class="fa-solid fa-award"></i>
                            <span>Quản lý Điểm số</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Attendance" ? "active" : "")">
                        <a href="/Teacher/Attendance">
                            <i class="fa-solid fa-user-check"></i>
                            <span>Điểm danh</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Resources" ? "active" : "")">
                        <a href="/Teacher/Resources">
                            <i class="fa-solid fa-folder-open"></i>
                            <span>Tài liệu học tập</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Messages" ? "active" : "")">
                        <a href="/Teacher/Messages">
                            <i class="fa-solid fa-comment-dots"></i>
                            <span>Tin nhắn</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Schedule" ? "active" : "")">
                        <a href="/Teacher/Schedule">
                            <i class="fa-solid fa-calendar-days"></i>
                            <span>Lịch dạy</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Reports" ? "active" : "")">
                        <a href="/Teacher/Reports">
                            <i class="fa-solid fa-chart-simple"></i>
                            <span>Báo cáo tổng hợp</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Profile" ? "active" : "")">
                        <a href="/Teacher/Profile">
                            <i class="fa-solid fa-user-gear"></i>
                            <span>Hồ sơ cá nhân</span>
                        </a>
                    </li>
                    <li class="menu-item @(controller == "Settings" ? "active" : "")">
                        <a href="/Teacher/Settings">
                            <i class="fa-solid fa-sliders"></i>
                            <span>Cài đặt</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Bottom User Profile Info -->
            <div class="sidebar-user">
                <img src="@(User.FindFirst("AvatarUrl")?.Value ?? "/default-images/avatar.png")" alt="Avatar" class="user-avatar-sidebar" onerror="this.src='https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "GV")&background=6C63FF&color=fff'" />
                <div class="user-info-sidebar">
                    <span class="user-name-sidebar">@User.Identity?.Name</span>
                    <span class="user-role-sidebar">Giảng viên</span>
                </div>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <main class="main-content">
            <!-- Header bar -->
            <header class="app-header">
                <!-- Title / Breadcrumb replacement -->
                <div class="d-flex align-items-center gap-2">
                    <h5 class="m-0 font-weight-bold text-dark">LMS Giảng Viên</h5>
                </div>

                <!-- Header Actions -->
                <div class="header-actions">
                    <!-- User Profile Dropdown -->
                    <a href="/Teacher/Profile" class="profile-dropdown-btn">
                        <img src="@(User.FindFirst("AvatarUrl")?.Value ?? "/default-images/avatar.png")" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "GV")&background=6C63FF&color=fff'" />
                        <span class="d-none d-md-inline">@User.Identity?.Name</span>
                    </a>

                    <!-- Logout link -->
                    <a href="/Account/Logout" class="text-danger ms-2" title="Đăng xuất">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                </div>
            </header>

            <!-- Render Main View Content -->
            <div class="container-fluid p-0 flex-grow-1">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Bootstrap 5.3 JavaScript Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model DuAnTotNghiep.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - AI Learn</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6.4 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="login-wrapper">
        <!-- Floating abstract UI decorations in background -->
        <div class="floating-elements">
            <div class="floating-icon i1"><i class="fa-solid fa-graduation-cap"></i></div>
            <div class="floating-icon i2"><i class="fa-solid fa-music"></i></div>
            <div class="floating-icon i3"><i class="fa-solid fa-star"></i></div>
            <div class="floating-icon i4"><i class="fa-solid fa-language"></i></div>
        </div>

        <div class="login-container-center" style="max-w-md; width: 100%;">
            <!-- Glassmorphic Register Card -->
            <div class="login-card-glass">
                
                <!-- Brand logo at top of card -->
                <div class="card-brand-header">
                    <div class="brand-logo-circle">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <h2>AI Learn</h2>
                    <p>Học thông minh hơn mỗi ngày với AI Tutor</p>
                </div>
                
                <div class="login-card-header">
                    <h3>Đăng ký tài khoản 🚀</h3>
                    <p>Bắt đầu hành trình chinh phục tiếng Anh</p>
                </div>

                <!-- Validation Alerts -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2.5 px-3 mb-4 text-sm rounded-2xl" role="alert">
                        <div asp-validation-summary="All" class="text-danger small font-medium"></div>
                    </div>
                }

                <!-- Social Login Buttons -->
                <div class="social-login-row">
                    <button class="social-login-btn google" type="button">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" />
                        <span>Google</span>
                    </button>
                    <button class="social-login-btn facebook" type="button">
                        <i class="fa-brands fa-facebook"></i>
                        <span>Facebook</span>
                    </button>
                </div>

                <div class="form-divider">hoặc đăng ký bằng email</div>

                <!-- Registration Form -->
                <form asp-controller="Account" asp-action="Register" method="post" class="space-y-3">
                    @Html.AntiForgeryToken()

                    <div class="form-group-custom">
                        <span class="form-label-custom">Họ và tên của bạn</span>
                        <div class="form-input-wrapper">
                            <input asp-for="FullName" placeholder="Nguyễn Văn A" required />
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <span class="form-label-custom">Email của bạn</span>
                        <div class="form-input-wrapper">
                            <input asp-for="Email" type="email" placeholder="example@gmail.com" required />
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <span class="form-label-custom">Mật khẩu</span>
                        <div class="form-input-wrapper">
                            <input asp-for="Password" type="password" id="passwordInputField" placeholder="••••••••" required />
                            <button type="button" class="password-toggle-icon" id="togglePasswordBtn">
                                <i class="fa-regular fa-eye-slash" id="togglePasswordIcon"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <span class="form-label-custom">Xác nhận mật khẩu</span>
                        <div class="form-input-wrapper">
                            <input asp-for="ConfirmPassword" type="password" id="confirmPasswordInputField" placeholder="••••••••" required />
                            <button type="button" class="password-toggle-icon" id="toggleConfirmPasswordBtn">
                                <i class="fa-regular fa-eye-slash" id="toggleConfirmPasswordIcon"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="login-btn-primary">Đăng ký tài khoản</button>

                    <div class="login-footer-text">
                        Đã có tài khoản? <a asp-action="Login">Đăng nhập ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Password toggle logic
            const togglePasswordBtn = document.getElementById('togglePasswordBtn');
            const passwordInputField = document.getElementById('passwordInputField');
            const togglePasswordIcon = document.getElementById('togglePasswordIcon');

            if (togglePasswordBtn && passwordInputField) {
                togglePasswordBtn.addEventListener('click', function () {
                    const type = passwordInputField.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInputField.setAttribute('type', type);
                    togglePasswordIcon.className = type === 'text' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
                });
            }

            // Confirm password toggle logic
            const toggleConfirmPasswordBtn = document.getElementById('toggleConfirmPasswordBtn');
            const confirmPasswordInputField = document.getElementById('confirmPasswordInputField');
            const toggleConfirmPasswordIcon = document.getElementById('toggleConfirmPasswordIcon');

            if (toggleConfirmPasswordBtn && confirmPasswordInputField) {
                toggleConfirmPasswordBtn.addEventListener('click', function () {
                    const type = confirmPasswordInputField.getAttribute('type') === 'password' ? 'text' : 'password';
                    confirmPasswordInputField.setAttribute('type', type);
                    toggleConfirmPasswordIcon.className = type === 'text' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
                });
            }
        });
    </script>
</body>
</html>

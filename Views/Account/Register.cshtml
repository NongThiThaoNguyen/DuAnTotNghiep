@model DuAnTotNghiep.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Ký - AI Study English</title>
    
    <!-- Google Fonts - Roboto -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Compiled Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DuAnTotNghiep.styles.css" asp-append-version="true" />
</head>
<body class="h-full flex items-center justify-center font-sans text-slate-900 bg-slate-50 py-12 px-4 sm:px-6 lg:px-8">

    <div class="max-w-md w-full space-y-8">
        <div class="bg-white py-10 px-6 sm:px-10 rounded-2xl shadow-sm border border-slate-200">
            <div class="text-center mb-8">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shadow-md shadow-blue-500/20 text-white font-bold text-2xl mx-auto mb-4">
                    D
                </div>
                <h2 class="text-3xl font-bold text-slate-800 tracking-tight">AI Study English</h2>
                <p class="mt-2 text-sm text-slate-500 font-medium">ĐĂNG KÝ TÀI KHOẢN</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post" id="registerForm" class="space-y-5">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-lg border border-red-100"></div>

                <!-- Họ và tên -->
                <div>
                    <label asp-for="FullName" class="block text-sm font-medium text-slate-700 mb-1"></label>
                    <input asp-for="FullName" class="block w-full px-4 py-3 rounded-xl border border-slate-300 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600/20 focus:border-blue-600 transition-colors placeholder-slate-400" placeholder="Nhập họ và tên của bạn" />
                    <span asp-validation-for="FullName" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1"></label>
                    <input asp-for="Email" class="block w-full px-4 py-3 rounded-xl border border-slate-300 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600/20 focus:border-blue-600 transition-colors placeholder-slate-400" placeholder="ví dụ: student@aistudy.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <!-- Mật khẩu -->
                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-slate-700 mb-1"></label>
                    <div class="relative">
                        <input asp-for="Password" class="block w-full px-4 py-3 rounded-xl border border-slate-300 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600/20 focus:border-blue-600 transition-colors placeholder-slate-400" placeholder="Tối thiểu 8 ký tự" autocomplete="new-password" />
                        <button type="button" class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none" onclick="togglePassword('Password', this)">
                            <svg class="h-5 w-5 eye-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <!-- Xác nhận mật khẩu -->
                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-medium text-slate-700 mb-1"></label>
                    <div class="relative">
                        <input asp-for="ConfirmPassword" class="block w-full px-4 py-3 rounded-xl border border-slate-300 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600/20 focus:border-blue-600 transition-colors placeholder-slate-400" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                        <button type="button" class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none" onclick="togglePassword('ConfirmPassword', this)">
                            <svg class="h-5 w-5 eye-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <!-- Nút Đăng ký -->
                <div class="pt-2">
                    <button type="submit" id="btnSubmit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-all">
                        <span id="btnText">Đăng ký</span>
                        <svg id="btnSpinner" class="animate-spin hidden ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </button>
                </div>

                <!-- Đăng nhập -->
                <div class="text-center mt-6">
                    <p class="text-sm text-slate-500">
                        Đã có tài khoản? 
                        <a href="/Account/Login" class="font-semibold text-blue-600 hover:text-blue-500 transition-colors">Đăng nhập ngay</a>
                    </p>
                </div>
            </form>
        </div>
    </div>

    <!-- jQuery & Validation Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // JS Hiện/Ẩn mật khẩu
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('.eye-icon');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
            }
        }

        // Thay đổi class lỗi của Unobtrusive để hợp với Tailwind
        $.validator.setDefaults({
            highlight: function (element) {
                $(element).addClass('border-red-500 focus:border-red-500 focus:ring-red-500/20');
                $(element).removeClass('border-slate-300 focus:border-blue-600 focus:ring-blue-600/20');
            },
            unhighlight: function (element) {
                $(element).removeClass('border-red-500 focus:border-red-500 focus:ring-red-500/20');
                $(element).addClass('border-slate-300 focus:border-blue-600 focus:ring-blue-600/20');
            }
        });

        // JS Loading Button khi Submit form hợp lệ
        $('#registerForm').on('submit', function (e) {
            const form = $(this);
            if (form.valid()) {
                const btnSubmit = $('#btnSubmit');
                const btnText = $('#btnText');
                const btnSpinner = $('#btnSpinner');

                btnSubmit.prop('disabled', true);
                btnSubmit.addClass('opacity-75 cursor-not-allowed');
                
                btnText.text('Đang đăng ký...');
                btnSpinner.removeClass('hidden');
            }
        });
    </script>
</body>
</html>

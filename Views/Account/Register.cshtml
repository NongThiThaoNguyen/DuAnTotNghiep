@model DuAnTotNghiep.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - AI Learn</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6.4 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="login-wrapper">
        <!-- Left Hero Section -->
        <div class="login-left d-none d-lg-flex">
            <!-- Floating UI Elements -->
            <div class="floating-elements">
                <div class="floating-icon i1"><i class="fa-solid fa-graduation-cap"></i></div>
                <div class="floating-icon i2"><i class="fa-solid fa-music"></i></div>
                <div class="floating-icon i3"><i class="fa-solid fa-star"></i></div>
                <div class="floating-icon i4"><i class="fa-solid fa-language"></i></div>
            </div>

            <!-- Brand logo -->
            <div class="left-brand">
                <i class="fa-solid fa-robot"></i>
                <span>AI Learn</span>
            </div>
            
            <p class="left-subtitle-main">Học thông minh hơn mỗi ngày với AI Tutor</p>

            <!-- Vector Illustration -->
            <div class="robot-illustration-container d-flex flex-column align-items-center">
                <svg class="robot-illustration" viewBox="0 0 200 200" width="180" height="180">
                    <rect x="50" y="50" width="100" height="80" rx="25" fill="#FFFFFF" />
                    <rect x="65" y="70" width="70" height="30" rx="12" fill="#08142E" />
                    <circle cx="85" cy="85" r="8" fill="#6C63FF" />
                    <circle cx="115" cy="85" r="8" fill="#6C63FF" />
                    <rect x="90" y="112" width="20" height="6" rx="3" fill="#08142E" />
                    <rect x="35" y="75" width="15" height="30" rx="6" fill="#7B6DFF" />
                    <rect x="150" y="75" width="15" height="30" rx="6" fill="#7B6DFF" />
                    <line x1="100" y1="50" x2="100" y2="25" stroke="#FFFFFF" stroke-width="6" />
                    <circle cx="100" cy="20" r="10" fill="#7B6DFF" />
                    <rect x="110" y="120" width="35" height="25" rx="4" fill="#08142E" transform="rotate(-15 110 120)" />
                    <rect x="113" y="123" width="29" height="19" rx="2" fill="#6C63FF" transform="rotate(-15 110 120)" />
                </svg>

                <svg class="illustration-books" viewBox="0 0 200 80" width="130" height="52">
                    <rect x="40" y="45" width="120" height="16" rx="3" fill="#7B6DFF" />
                    <rect x="35" y="45" width="10" height="16" rx="2" fill="#FFFFFF" />
                    <rect x="50" y="32" width="100" height="14" rx="3" fill="#FF5A5F" />
                    <rect x="45" y="32" width="8" height="14" rx="2" fill="#FFFFFF" />
                    <rect x="140" y="15" width="18" height="20" rx="3" fill="#E9ECF5" />
                    <path d="M140 15 C135 5, 142 0, 145 10 Z" fill="#4ADE80" />
                    <path d="M158 15 C163 5, 156 0, 153 10 Z" fill="#4ADE80" />
                </svg>
            </div>
        </div>

        <!-- Right Form Section -->
        <div class="login-right">
            <div class="login-card">
                <div class="login-card-header">
                    <h2>Đăng ký tài khoản 🚀</h2>
                    <p>Bắt đầu hành trình chinh phục tiếng Anh</p>
                </div>

                <!-- Validation Alerts -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 px-3 mb-3 text-sm rounded-3" role="alert">
                        <div asp-validation-summary="All" class="text-danger small"></div>
                    </div>
                }

                <form asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group-ailearn">
                        <div class="form-label-custom">Họ và tên của bạn</div>
                        <div class="form-input-wrapper">
                            <input asp-for="FullName" placeholder="Nguyễn Văn A" required />
                        </div>
                    </div>

                    <div class="form-group-ailearn">
                        <div class="form-label-custom">Email của bạn</div>
                        <div class="form-input-wrapper">
                            <input asp-for="Email" type="email" placeholder="example@gmail.com" required />
                        </div>
                    </div>

                    <div class="form-group-ailearn">
                        <div class="form-label-custom">Mật khẩu</div>
                        <div class="form-input-wrapper">
                            <input asp-for="Password" type="password" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="form-group-ailearn">
                        <div class="form-label-custom">Xác nhận mật khẩu</div>
                        <div class="form-input-wrapper">
                            <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required />
                        </div>
                    </div>

                    <button type="submit" class="login-btn-primary">Đăng ký tài khoản</button>

                    <div class="login-footer-text">
                        Đã có tài khoản? <a asp-action="Login">Đăng nhập ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

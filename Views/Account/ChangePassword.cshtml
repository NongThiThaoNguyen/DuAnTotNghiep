@model DuAnTotNghiep.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Bảo mật tài khoản</h1>
            <p class="mt-1 text-sm text-slate-500">Cập nhật mật khẩu để bảo vệ tài khoản của bạn.</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="p-6 sm:p-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="mb-6 bg-green-50 border border-green-200 rounded-xl p-4 flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="text-sm text-green-800">
                        @TempData["SuccessMessage"]
                    </div>
                </div>
            }

            <form asp-controller="Account" asp-action="ChangePassword" method="post" class="space-y-6 max-w-xl">
                <div asp-validation-summary="ModelOnly" class="text-sm font-medium text-red-600 bg-red-50 border border-red-200 rounded-lg p-3"></div>

                <div>
                    <label asp-for="CurrentPassword" class="block text-sm font-medium text-slate-700">Mật khẩu hiện tại</label>
                    <div class="mt-2 relative rounded-lg shadow-xs">
                        <input asp-for="CurrentPassword" type="password" class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent sm:text-sm transition-all" placeholder="Nhập mật khẩu hiện tại" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="mt-1 text-xs text-red-600 block"></span>
                </div>

                <hr class="border-slate-200" />

                <div>
                    <label asp-for="NewPassword" class="block text-sm font-medium text-slate-700">Mật khẩu mới</label>
                    <div class="mt-2 relative rounded-lg shadow-xs">
                        <input asp-for="NewPassword" type="password" class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent sm:text-sm transition-all" placeholder="Tối thiểu 6 ký tự" />
                    </div>
                    <span asp-validation-for="NewPassword" class="mt-1 text-xs text-red-600 block"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-medium text-slate-700">Xác nhận mật khẩu mới</label>
                    <div class="mt-2 relative rounded-lg shadow-xs">
                        <input asp-for="ConfirmPassword" type="password" class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent sm:text-sm transition-all" placeholder="Nhập lại mật khẩu mới" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="mt-1 text-xs text-red-600 block"></span>
                </div>

                <div class="pt-4 flex items-center justify-end gap-3">
                    <button type="button" class="px-4 py-2.5 border border-slate-300 rounded-lg text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-colors">
                        Hủy
                    </button>
                    <button type="submit" class="px-4 py-2.5 border border-transparent rounded-lg shadow-xs text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-colors">
                        Cập nhật mật khẩu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

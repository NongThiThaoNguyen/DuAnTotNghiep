@{
    Layout = null;
    ViewData["Title"] = "Từ chối truy cập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Study English</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary-blue: #2563EB;
            --primary-hover: #1D4ED8;
            --bg-color: #F8FAFC;
            --surface-color: #FFFFFF;
            --border-color: #E2E8F0;
            --text-primary: #0F172A;
            --text-secondary: #64748B;
            --danger-color: #EF4444;
            --danger-bg: #FEF2F2;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .error-card {
            background-color: var(--surface-color);
            border-radius: 16px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            width: 100%;
            max-width: 480px;
            padding: 3rem 2.5rem;
            text-align: center;
            margin: 1rem;
        }

        .icon-wrapper {
            width: 80px;
            height: 80px;
            background-color: var(--danger-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }

        .icon-shield {
            font-size: 2.5rem;
            color: var(--danger-color);
            line-height: 1;
        }

        h1 {
            font-size: 36px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 1rem;
        }

        p {
            font-size: 16px;
            color: var(--text-secondary);
            line-height: 1.6;
            margin-bottom: 2rem;
            font-weight: 400;
        }

        .btn-primary-custom {
            background-color: var(--primary-blue);
            color: #FFFFFF;
            border: none;
            border-radius: 12px;
            padding: 0.875rem 2rem;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-primary-custom:hover {
            background-color: var(--primary-hover);
            color: #FFFFFF;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }

        .btn-primary-custom i {
            font-size: 1.25rem;
        }
    </style>
</head>
<body>

    <div class="error-card">
        <div class="icon-wrapper">
            <i class="bi bi-shield-x icon-shield"></i>
        </div>
        
        <h1>Lỗi Phân Quyền</h1>
        <p>Rất tiếc, bạn không có đủ thẩm quyền để truy cập vào trang này. Hãy liên hệ Quản trị viên nếu bạn nghĩ đây là sự nhầm lẫn.</p>
        
        <a asp-controller="Home" asp-action="Index" class="btn-primary-custom">
            <i class="bi bi-house-door"></i> Quay về Trang chủ
        </a>
    </div>

</body>
</html>

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Từ chối truy cập";
    ViewData["Subtitle"] = "Lỗi 403 - Không có quyền truy cập";
}

<div class="bg-white py-12 px-6 shadow-sm border border-slate-200 rounded-2xl sm:px-10 text-center">
    
    <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-red-100 mb-6">
        <svg class="h-10 w-10 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
    </div>

    <h2 class="text-2xl font-bold text-slate-900 mb-2">Bạn không có quyền truy cập</h2>
    <p class="text-slate-500 mb-8">
        Trang bạn đang cố gắng truy cập yêu cầu đặc quyền mà tài khoản hiện tại không có. Vui lòng liên hệ quản trị viên nếu bạn cho rằng đây là một sự nhầm lẫn.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a asp-controller="Home" asp-action="Index" class="w-full sm:w-auto inline-flex justify-center items-center px-6 py-2.5 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-colors">
            Về trang chủ
        </a>
        
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="#" class="w-full sm:w-auto inline-flex justify-center items-center px-6 py-2.5 border border-slate-300 text-sm font-medium rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-colors">
                Đăng nhập tài khoản khác
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="w-full sm:w-auto inline-flex justify-center items-center px-6 py-2.5 border border-slate-300 text-sm font-medium rounded-lg text-slate-700 bg-white hover:bg-slate-50 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-colors">
                Đăng nhập ngay
            </a>
        }
    </div>
</div>

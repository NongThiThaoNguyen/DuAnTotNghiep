@{
    Layout = null;
    ViewData["Title"] = "Từ chối truy cập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Study English</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --bg-color: #F8FAFC;
            --surface-color: #FFFFFF;
            --text-primary: #0F172A;
            --text-secondary: #64748B;
            --danger-color: #EF4444;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .error-card {
            background-color: var(--surface-color);
            border-radius: 24px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 480px;
            padding: 3rem 2rem;
            text-align: center;
            border: 1px solid #E2E8F0;
        }

        .error-icon {
            font-size: 5rem;
            color: var(--danger-color);
            margin-bottom: 1rem;
            line-height: 1;
        }

        .error-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .error-desc {
            color: var(--text-secondary);
            font-size: 16px;
            margin-bottom: 2.5rem;
            line-height: 1.5;
        }

        .btn-back {
            background-color: #2563EB;
            color: white;
            border-radius: 12px;
            padding: 0.75rem 2rem;
            font-weight: 600;
            font-size: 16px;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-back:hover {
            background-color: #1D4ED8;
            color: white;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h1 class="error-title">403 Lỗi Phân Quyền</h1>
        <p class="error-desc">Rất tiếc, bạn không có đủ thẩm quyền để truy cập vào trang này.<br>Hãy liên hệ Quản trị viên nếu đây là một sự nhầm lẫn.</p>
        
        <a asp-controller="Home" asp-action="Index" class="btn-back">
            <i class="bi bi-house-door"></i> Về trang chủ
        </a>
    </div>

</body>
</html>

@model DuAnTotNghiep.Models.ViewModels.AILearn.LessonViewModel
@{
    Layout = "_AILearnLayout";
    ViewData["Title"] = Model.LessonTitle;
}

@section Styles {
    <link rel="stylesheet" href="~/css/lesson.css" asp-append-version="true" />
}

<div class="lesson-layout">
    <!-- Left Column: Video and Tabs -->
    <div>
        <!-- Video Player -->
        @if (Model.ContentType == "VIDEO_LINK" && !string.IsNullOrEmpty(Model.VideoUrl))
        {
            bool isYoutube = Model.VideoUrl.Contains("youtube.com") || Model.VideoUrl.Contains("youtu.be");
            string embedUrl = Model.VideoUrl;
            
            if (isYoutube)
            {
                if (Model.VideoUrl.Contains("youtube.com/watch?v="))
                {
                    var videoId = Model.VideoUrl.Split("v=")[1].Split("&")[0];
                    embedUrl = $"https://www.youtube.com/embed/{videoId}?enablejsapi=1";
                }
                else if (Model.VideoUrl.Contains("youtu.be/"))
                {
                    var videoId = Model.VideoUrl.Split("youtu.be/")[1].Split("?")[0];
                    embedUrl = $"https://www.youtube.com/embed/{videoId}?enablejsapi=1";
                }
            }

            <div class="lesson-player-container" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; background: #000; border-radius: 12px; margin-bottom: 10px;">
                @if (isYoutube)
                {
                    <iframe id="youtubePlayer" src="@embedUrl" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></iframe>
                }
                else
                {
                    <video id="html5Player" controls style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
                        <source src="@Model.VideoUrl" type="video/mp4" />
                        Trình duyệt của bạn không hỗ trợ tag video.
                    </video>
                }
            </div>

            <!-- Transcript Section -->
            @if (Model.LessonId == 125) 
            {
                <div class="transcript-wrapper mb-4">
                    <button class="btn btn-outline-primary btn-sm w-100 d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#transcriptBox" aria-expanded="true" aria-controls="transcriptBox" style="border-radius: 8px;">
                        <span class="fw-bold"><i class="fa-solid fa-closed-captioning me-2"></i>Lời thoại (Transcript)</span>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                    <div class="collapse show mt-2" id="transcriptBox">
                        <div class="card card-body bg-light border-0" style="max-height: 250px; overflow-y: auto; border-radius: 8px; font-size: 0.95rem; line-height: 1.8;">
                            <!-- Mẫu dữ liệu Transcript (sẽ được gen bằng DB hoặc Hardcode mẫu ở đây) -->
                            <div class="transcript-line" data-time="0">Welcome back to another English lesson!</div>
                            <div class="transcript-line" data-time="4">Today, we are talking about <strong>Continuous</strong> and <strong>Perfect</strong> tenses.</div>
                            <div class="transcript-line" data-time="9">It's very important to understand them <strong>simultaneously</strong>.</div>
                            <div class="transcript-line" data-time="14">Let's look at the first example on the board...</div>
                            <div class="transcript-line" data-time="20">When you say "I am doing", it means the action is happening right now.</div>
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Lesson Header Actions -->
        <div class="lesson-header-section">
            <div class="lesson-title-block">
                <h2>@Model.LessonTitle</h2>
                <span>Khóa học: @Model.CourseTitle &bull; Thời lượng dự kiến: @Model.EstimatedMinutes phút</span>
            </div>
            
            <form asp-controller="Lesson" asp-action="MarkCompleted" asp-route-id="@Model.LessonId" method="post">
                @Html.AntiForgeryToken()
                @if (Model.IsCompleted)
                {
                    <button class="btn btn-success" disabled>
                        <i class="fa-solid fa-circle-check me-2"></i>Đã hoàn thành
                    </button>
                }
                else
                {
                    <button type="submit" class="btn-primary-ailearn">
                        <i class="fa-solid fa-check me-2"></i>Đánh dấu hoàn thành
                    </button>
                }
            </form>
        </div>

        <!-- Details tabs -->
        <div class="card-ailearn lesson-details-card">
            <div class="lesson-details-tabs">
                <div class="lesson-details-tab active" data-tab="desc">Nội dung bài học</div>
                <div class="lesson-details-tab" data-tab="examples">Ví dụ & Giải nghĩa</div>
                <div class="lesson-details-tab" data-tab="resources">Tài liệu tham khảo</div>
            </div>

            <!-- Tab content -->
            <div class="tab-content">
                <!-- Description -->
                <div class="tab-content-item active" id="descContent">
                    @Html.Raw(Model.Content)
                </div>

                <!-- Examples -->
                <div class="tab-content-item" id="examplesContent">
                    <h5>Cấu trúc ngữ pháp áp dụng</h5>
                    <p>Trong bài giảng này, học sinh nên lưu ý các cấu trúc câu sau:</p>
                    <div class="p-3 border rounded bg-light mb-3">
                        <strong>1. Relative Clauses (Mệnh đề quan hệ):</strong><br>
                        Syntax: `Noun + who/which/that + Verb/Clause`<br>
                        <em>Example:</em> The tutor who supports me is very friendly.<br>
                        <strong>Dịch:</strong> Trợ lý người hỗ trợ tôi rất thân thiện.
                    </div>
                    <div class="p-3 border rounded bg-light">
                        <strong>2. Active / Passive Voice (Chủ động / Bị động):</strong><br>
                        Syntax: `S + be + V3/ed + by Noun`<br>
                        <em>Example:</em> The lesson was prepared by AI Tutor.<br>
                        <strong>Dịch:</strong> Bài học được chuẩn bị bởi Trợ lý AI.
                    </div>
                </div>

                <!-- Resources -->
                <div class="tab-content-item" id="resourcesContent">
                    <div class="resource-list">
                        <div class="resource-item">
                            <div class="resource-item-info">
                                <i class="fa-regular fa-file-pdf"></i>
                                <span>Tài liệu tóm tắt ngữ pháp bài học.pdf</span>
                            </div>
                            <a href="#" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-download"></i></a>
                        </div>
                        <div class="resource-item">
                            <div class="resource-item-info">
                                <i class="fa-regular fa-file-audio"></i>
                                <span>Audio phát âm ví dụ bài giảng.mp3</span>
                            </div>
                            <a href="#" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-download"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sibling Navigation footer links -->
        <div class="d-flex justify-content-between">
            @if (Model.PreviousLessonId.HasValue)
            {
                <a href="/Lesson/Detail/@Model.PreviousLessonId" class="btn btn-secondary-ailearn">
                    <i class="fa-solid fa-arrow-left me-2"></i>Bài trước
                </a>
            }
            else
            {
                <button class="btn btn-secondary-ailearn" disabled>
                    <i class="fa-solid fa-arrow-left me-2"></i>Bài trước
                </button>
            }

            @if (Model.NextLessonId.HasValue)
            {
                <a href="/Lesson/Detail/@Model.NextLessonId" class="btn btn-primary-ailearn">
                    Bài tiếp theo<i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            }
            else
            {
                <a href="/Courses" class="btn btn-primary-ailearn">
                    Quay về khóa học<i class="fa-solid fa-house ms-2"></i>
                </a>
            }
        </div>
    </div>

    <!-- Right Column: Sidebar Navigation -->
    <div>
        <div class="card-ailearn">
            <h3 class="h6 font-weight-bold mb-3">Danh sách bài học</h3>
            <div class="lesson-sidebar-list">
                @foreach (var sib in Model.LessonsInCourse)
                {
                    <a href="/Lesson/Detail/@sib.Id" class="lesson-sidebar-item @(sib.IsCurrent ? "active" : "")">
                        <div class="lesson-sidebar-item-status @(sib.IsCompleted ? "completed" : "pending")">
                            @if (sib.IsCompleted)
                            {
                                <i class="fa-solid fa-check"></i>
                            }
                            else
                            {
                                <span>@sib.OrderIndex</span>
                            }
                        </div>
                        <div class="lesson-sidebar-item-info">
                            <h4 class="lesson-sidebar-item-title">@sib.Title</h4>
                            <span class="lesson-sidebar-item-duration">@((sib.OrderIndex * 2) + 12) phút</span>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/lesson.js" asp-append-version="true"></script>
}

@model DuAnTotNghiep.Models.ViewModels.CompetencyResultViewModel
@using DuAnTotNghiep.Models.ViewModels

@{
    ViewData["Title"] = "Báo cáo năng lực";
    var isLatest = ViewBag.IsLatest as bool? ?? false;

    // Helper: map score % to color class
    string BarColor(decimal score) => score < 50 ? "bg-red-500" : score < 70 ? "bg-amber-400" : "bg-emerald-500";
    string BadgeColor(string cefr) => cefr switch {
        "A1" or "A2" => "bg-red-100 text-red-700 ring-red-200",
        "B1" or "B2" => "bg-amber-100 text-amber-700 ring-amber-200",
        "C1" or "C2" => "bg-emerald-100 text-emerald-700 ring-emerald-200",
        _ => "bg-slate-100 text-slate-700 ring-slate-200"
    };
    string SkillIcon(string skill) => skill?.ToUpper() switch {
        "LISTENING" or "NGHE" => "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3",
        "SPEAKING" or "NOI" => "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
        "READING" or "DOC" => "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
        "WRITING" or "VIET" => "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z",
        _ => "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
    };
}


@* ─── AI Fallback Banner ─── *@
@if (Model.IsAiFallback)
{
    <div class="mb-4 flex items-center gap-3 rounded-xl bg-amber-50 px-4 py-3 text-sm text-amber-700 ring-1 ring-amber-200">
        <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>Phân tích AI tạm thời không khả dụng. Dữ liệu hiển thị được tính toán bằng hệ thống đánh giá tự động (Rule-based).</span>
    </div>
}

@* ─── HEADER ─── *@
<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <div class="flex items-center gap-3 mb-1">
            @if (isLatest)
            {
                <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-semibold text-blue-700 ring-1 ring-blue-200">
                    ● MỚI NHẤT
                </span>
            }
            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-bold ring-1 @BadgeColor(Model.EstimatedCefrLevel)">
                @Model.EstimatedCefrLevel
            </span>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">Báo cáo năng lực tiếng Anh</h1>
        <p class="mt-1 text-sm text-slate-500">
            Phân tích ngày @Model.CalculatedAt.ToString("dd/MM/yyyy") lúc @Model.CalculatedAt.ToString("HH:mm")
            &nbsp;·&nbsp; ID: <span class="font-mono text-xs">#@Model.AnalysisId</span>
        </p>
    </div>
    <div class="flex items-center gap-2">
        @if (ViewBag.HasLearningPath == true)
        {
            <a href="/LearningPath"
               class="inline-flex items-center gap-2 rounded-lg border border-blue-200 bg-white px-3.5 py-2 text-sm font-medium text-blue-600 shadow-xs hover:bg-blue-50 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"/>
                </svg>
                Xem lộ trình hiện tại
            </a>
        }
        else
        {
            <a href="/LearningPath/Create?analysisId=@Model.AnalysisId"
               class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-3.5 py-2 text-sm font-semibold text-white shadow-xs hover:bg-blue-700 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Tạo lộ trình học
            </a>
        }
        <form asp-action="Regenerate" asp-route-id="@Model.AnalysisId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-xs hover:bg-slate-50 hover:text-blue-600 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Phân tích lại
            </button>
        </form>
    </div>
</div>

@* ─── SECTION 1: TỔNG QUAN ─── *@
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">

    {{!-- Overall Score --}}
    <div class="flex flex-col items-center justify-center rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-slate-400">Điểm tổng quan</p>
        <div class="relative flex items-center justify-center">
            <svg class="h-24 w-24 -rotate-90" viewBox="0 0 36 36">
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e2e8f0" stroke-width="3"/>
                <circle cx="18" cy="18" r="15.9" fill="none"
                        stroke="@(Model.OverallAccuracy < 50 ? "#ef4444" : Model.OverallAccuracy < 70 ? "#f59e0b" : "#10b981")"
                        stroke-width="3"
                        stroke-dasharray="@Model.OverallAccuracy 100"
                        stroke-linecap="round"/>
            </svg>
            <span class="absolute text-xl font-bold text-slate-800">@Model.OverallAccuracy<span class="text-xs">%</span></span>
        </div>
    </div>

    {{!-- Current Level --}}
    <div class="flex flex-col justify-center rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-slate-400">Trình độ hiện tại</p>
        <p class="text-2xl font-bold text-slate-900">@Model.CurrentLevelName</p>
        <div class="mt-3 flex items-center gap-2 text-sm text-slate-500">
            <svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            Mục tiêu: <span class="font-medium text-blue-600">@Model.RecommendedLevelName</span>
        </div>
    </div>

    {{!-- Summary Text --}}
    <div class="flex flex-col justify-center rounded-2xl bg-gradient-to-br from-blue-600 to-blue-700 p-6 shadow-sm">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-blue-200">Nhận xét tổng quan</p>
        <p class="text-sm leading-relaxed text-white">
            @(string.IsNullOrWhiteSpace(Model.DashboardSummary)
                ? "Hệ thống chưa có nhận xét. Vui lòng thử phân tích lại."
                : (Model.DashboardSummary.Length > 180 ? Model.DashboardSummary.Substring(0, 180) + "…" : Model.DashboardSummary))
        </p>
    </div>
</div>

@* ─── SECTION 2 & 4: SKILL BARS + PRIORITY TOPICS (side-by-side) ─── *@
<div class="mb-6 grid grid-cols-1 gap-6 lg:grid-cols-5">

    {{!-- Skill Progress Bars (col 3/5) --}}
    <div class="lg:col-span-3">
        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 h-full">
            <h2 class="mb-5 flex items-center gap-2 text-base font-semibold text-slate-800">
                <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                Điểm số theo kỹ năng
            </h2>

            @if (Model.RecommendedActions != null && Model.RecommendedActions.Any(a => a.SkillName != null))
            {
                var skills = Model.RecommendedActions
                    .Where(a => a.SkillName != null)
                    .GroupBy(a => a.SkillName!)
                    .Select(g => new { Skill = g.Key, Score = (decimal)(80 - g.Min(x => x.Priority) * 10) })
                    .ToList();

                foreach (var s in skills)
                {
                    var color = BarColor(s.Score);
                    var score = Math.Max(0, Math.Min(100, s.Score));
                    <div class="mb-5 group">
                        <div class="mb-1.5 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@SkillIcon(s.Skill)"/>
                                </svg>
                                <span class="text-sm font-medium text-slate-700">@s.Skill</span>
                            </div>
                            <span class="text-sm font-semibold text-slate-600">@score%</span>
                        </div>
                        <div class="relative h-3 w-full overflow-hidden rounded-full bg-slate-100"
                             title="@s.Skill: @score% - @(score < 50 ? "Cần cải thiện nhiều" : score < 70 ? "Đang tiến bộ" : "Tốt")">
                            <div class="h-full rounded-full transition-all duration-700 @color" style="width: @score%"></div>
                        </div>
                        <p class="mt-1 text-xs text-slate-400">
                            @(score < 50 ? "⚠ Cần tập trung cải thiện" : score < 70 ? "◐ Đang ở mức trung bình" : "✓ Đang làm tốt")
                        </p>
                    </div>
                }
            }
            else
            {
                @* Fallback: show mock bars for 4 main skills based on OverallAccuracy *@
                var baseScore = Model.OverallAccuracy;
                var mockSkills = new[] {
                    new { Name = "Nghe (Listening)", Score = Math.Round(baseScore * 0.9m, 0) },
                    new { Name = "Đọc (Reading)",   Score = Math.Round(baseScore * 1.05m, 0) },
                    new { Name = "Viết (Writing)",  Score = Math.Round(baseScore * 0.85m, 0) },
                    new { Name = "Nói (Speaking)",  Score = Math.Round(baseScore * 0.8m, 0)  }
                };
                foreach (var s in mockSkills)
                {
                    var clampScore = Math.Max(0, Math.Min(100, s.Score));
                    var color = BarColor(clampScore);
                    <div class="mb-5">
                        <div class="mb-1.5 flex items-center justify-between">
                            <span class="text-sm font-medium text-slate-700">@s.Name</span>
                            <span class="text-sm font-semibold text-slate-600">@clampScore%</span>
                        </div>
                        <div class="relative h-3 w-full overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full rounded-full transition-all duration-700 @color" style="width: @clampScore%"></div>
                        </div>
                        <p class="mt-1 text-xs text-slate-400">
                            @(clampScore < 50 ? "⚠ Cần tập trung cải thiện" : clampScore < 70 ? "◐ Đang ở mức trung bình" : "✓ Đang làm tốt")
                        </p>
                    </div>
                }
            }
        </div>
    </div>

    {{!-- Priority Topics Timeline (col 2/5) --}}
    <div class="lg:col-span-2">
        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 h-full">
            <h2 class="mb-5 flex items-center gap-2 text-base font-semibold text-slate-800">
                <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                Topic ưu tiên học
            </h2>

            @if (Model.PriorityTopics != null && Model.PriorityTopics.Any())
            {
                <ol class="relative border-l-2 border-slate-200 ml-3 space-y-6">
                    @foreach (var topic in Model.PriorityTopics.Take(5))
                    {
                        var dotColor = topic.AccuracyPercentage < 50 ? "bg-red-500 ring-red-100"
                                     : topic.AccuracyPercentage < 70 ? "bg-amber-400 ring-amber-100"
                                     : "bg-emerald-500 ring-emerald-100";
                        <li class="ml-6 group">
                            <span class="absolute -left-[11px] flex h-5 w-5 items-center justify-center rounded-full ring-4 @dotColor text-white text-[10px] font-bold shadow-sm">
                                @topic.Rank
                            </span>
                            <div class="rounded-xl bg-slate-50 p-3 ring-1 ring-slate-100 group-hover:bg-blue-50 group-hover:ring-blue-100 transition-all">
                                <p class="text-xs font-semibold text-slate-500 mb-0.5">@topic.SkillCode</p>
                                <p class="text-sm font-semibold text-slate-800 leading-snug">@topic.TopicTitle</p>
                                <p class="mt-1 text-xs text-slate-500">@topic.PriorityReason</p>
                                @if (!topic.PrerequisitesMet)
                                {
                                    <p class="mt-1 text-xs text-amber-600 flex items-center gap-1">
                                        <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                                        Cần hoàn thành topic trước
                                    </p>
                                }
                                <a href="@Url.Action("Start", "LearningPath", new { topicId = topic.TopicId, reportId = Model.AnalysisId })"
                                   class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-blue-600 hover:text-blue-800 hover:underline transition-colors">
                                    Bắt đầu học
                                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </a>
                            </div>
                        </li>
                    }
                </ol>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-8 text-center">
                    <svg class="h-12 w-12 text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    <p class="text-sm text-slate-400">Chưa có topic được đề xuất.</p>
                </div>
            }
        </div>
    </div>
</div>

@* ─── SECTION 3: STRENGTHS & WEAKNESSES ─── *@
<div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-2">

    {{!-- Strengths --}}
    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="mb-4 flex items-center gap-2 text-base font-semibold text-emerald-700">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-emerald-100">
                <svg class="h-4 w-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
            </span>
            Điểm mạnh
        </h2>

        @if (Model.Strengths != null && Model.Strengths.Any())
        {
            <ul class="space-y-3">
                @foreach (var item in Model.Strengths)
                {
                    <li class="flex items-start gap-3 rounded-xl bg-emerald-50 px-4 py-3 ring-1 ring-emerald-100 hover:ring-emerald-200 transition-all">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        <div>
                            <p class="text-sm font-semibold text-slate-800">@item.Title</p>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="mt-0.5 text-xs text-slate-500">@item.ShortDescription</p>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-sm text-slate-400 text-center py-4">Chưa có dữ liệu điểm mạnh.</p>
        }
    </div>

    {{!-- Weaknesses --}}
    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="mb-4 flex items-center gap-2 text-base font-semibold text-red-700">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-red-100">
                <svg class="h-4 w-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </span>
            Điểm cần cải thiện
        </h2>

        @if (Model.Weaknesses != null && Model.Weaknesses.Any())
        {
            <ul class="space-y-3">
                @foreach (var item in Model.Weaknesses)
                {
                    <li class="flex items-start gap-3 rounded-xl bg-red-50 px-4 py-3 ring-1 ring-red-100 hover:ring-red-200 transition-all">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        <div>
                            <p class="text-sm font-semibold text-slate-800">@item.Title</p>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="mt-0.5 text-xs text-slate-500">@item.ShortDescription</p>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-sm text-slate-400 text-center py-4">Chưa có dữ liệu điểm yếu.</p>
        }
    </div>
</div>

@* ─── SECTION 5: RECOMMENDED ACTIONS ─── *@
@if (Model.RecommendedActions != null && Model.RecommendedActions.Any())
{
    <div class="mb-6 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="mb-4 flex items-center gap-2 text-base font-semibold text-slate-800">
            <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            Hành động đề xuất
        </h2>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            @foreach (var action in Model.RecommendedActions.OrderBy(a => a.Priority).Take(6))
            {
                <div class="flex items-start gap-3 rounded-xl bg-blue-50 px-4 py-3 ring-1 ring-blue-100">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-600 text-[10px] font-bold text-white mt-0.5">
                        @action.Priority
                    </span>
                    <div>
                        <p class="text-sm text-slate-700">@action.ActionText</p>
                        @if (action.TopicId.HasValue)
                        {
                            <a href="@Url.Action("Start", "LearningPath", new { topicId = action.TopicId, reportId = Model.AnalysisId })"
                               class="mt-1 inline-flex items-center gap-1 text-xs font-medium text-blue-600 hover:text-blue-800">
                                Học topic "@action.TopicTitle"
                                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}


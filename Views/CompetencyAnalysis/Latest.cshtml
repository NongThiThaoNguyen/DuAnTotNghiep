@model DuAnTotNghiep.Models.ViewModels.CompetencyResultViewModel

@{
    ViewData["Title"] = "Báo cáo năng lực mới nhất";
    // Set flag so Result.cshtml shows the "MỚI NHẤT" badge
    ViewBag.IsLatest = true;
}

@* Latest-only notification banner *@
@if (TempData["InfoMessage"] != null)
{
    <div class="mb-4 flex items-start gap-3 rounded-xl bg-blue-50 px-4 py-3 text-sm text-blue-700 ring-1 ring-blue-200">
        <svg class="mt-0.5 h-5 w-5 shrink-0 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>@TempData["InfoMessage"]</span>
    </div>
}

<div class="mb-5 flex items-center gap-3 rounded-xl bg-blue-50 px-4 py-3 text-sm text-blue-700 ring-1 ring-blue-200">
    <svg class="h-5 w-5 shrink-0 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <span>
        Đây là báo cáo năng lực <strong>mới nhất</strong> của bạn —
        @if (Model != null)
        {
            @Model.CalculatedAt.ToString("HH:mm 'ngày' dd/MM/yyyy")
        }
        .
        Muốn xem lịch sử? <a asp-action="History" class="underline font-medium hover:text-blue-900">Xem tất cả báo cáo</a>.
    </span>
</div>

@* Delegate rendering to Result view – Model and ViewBag.IsLatest are already set *@
@await Html.PartialAsync("Result", Model)

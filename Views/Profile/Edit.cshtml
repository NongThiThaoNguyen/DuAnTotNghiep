@model DuAnTotNghiep.ViewModels.Profile.EditProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container mx-auto px-4 py-10 max-w-3xl font-sans">
    <div class="mb-6">
        <a asp-action="Index" class="text-sm text-slate-500 hover:text-blue-600 font-medium flex items-center gap-1.5 transition-colors mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Quay lại hồ sơ
        </a>
        <p class="text-[11px] font-semibold tracking-wider uppercase text-blue-600 mb-1">Tài khoản</p>
        <h1 class="text-3xl font-bold text-slate-900">Chỉnh sửa hồ sơ</h1>
    </div>

    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 sm:px-8 py-6">
            <form asp-action="Edit" method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label asp-for="FullName" class="block text-sm font-medium text-slate-700 mb-1.5">Họ và tên <span class="text-red-500">*</span></label>
                        <input asp-for="FullName" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-colors text-slate-900" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Phone" class="block text-sm font-medium text-slate-700 mb-1.5">Số điện thoại</label>
                        <input asp-for="Phone" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-colors text-slate-900" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="DateOfBirth" class="block text-sm font-medium text-slate-700 mb-1.5">Ngày sinh</label>
                        <input asp-for="DateOfBirth" type="date" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-colors text-slate-900" />
                        <span asp-validation-for="DateOfBirth" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Gender" class="block text-sm font-medium text-slate-700 mb-1.5">Giới tính</label>
                        <select asp-for="Gender" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-colors text-slate-900">
                            <option value="">Chọn giới tính</option>
                            <option value="MALE">Nam</option>
                            <option value="FEMALE">Nữ</option>
                            <option value="OTHER">Khác</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Country" class="block text-sm font-medium text-slate-700 mb-1.5">Quốc gia</label>
                        <input asp-for="Country" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-colors text-slate-900" placeholder="Nhập quốc gia" />
                        <span asp-validation-for="Country" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="Bio" class="block text-sm font-medium text-slate-700 mb-1.5">Giới thiệu bản thân</label>
                        <textarea asp-for="Bio" rows="4" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-colors text-slate-900 resize-y" placeholder="Viết một chút về bản thân bạn..."></textarea>
                        <span asp-validation-for="Bio" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="pt-4 flex gap-3">
                    <button type="submit" class="py-2.5 px-6 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-xl transition-colors shadow-sm">
                        Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="py-2.5 px-6 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 font-medium rounded-xl transition-colors">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

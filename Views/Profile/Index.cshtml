@model DuAnTotNghiep.Models.ViewModels.Profile.ProfileViewModel
@{
    Layout = "_AILearnLayout";
    ViewData["Title"] = "Hồ sơ của tôi";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-settings-layout">
    <!-- Left Column: Avatar & Basic actions -->
    <div class="card-ailearn profile-avatar-card">
        <form asp-action="UploadAvatar" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="profile-avatar-editor">
                <img id="avatarPreviewImage" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "/default-images/avatar.png" : Model.AvatarUrl)" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@(Model.FullName)&background=6C63FF&color=fff'" />
                <label for="avatarInputFile" class="avatar-upload-btn">
                    <i class="fa-solid fa-camera"></i>
                </label>
                <input type="file" id="avatarInputFile" name="AvatarFile" accept="image/*" class="d-none" onchange="this.form.submit();" />
            </div>
        </form>

        <h3 class="h5 font-weight-bold mb-1">@Model.FullName</h3>
        <p class="text-muted small mb-4">@Model.Email</p>

        <div class="d-grid gap-2">
            <a href="/Profile/Edit" class="btn btn-primary-ailearn btn-sm">Chỉnh sửa hồ sơ</a>
            <a href="/Profile/ChangePassword" class="btn btn-secondary-ailearn btn-sm">Đổi mật khẩu</a>
        </div>
    </div>

    <!-- Right Column: Personal details form/view -->
    <div class="card-ailearn">
        <h3 class="h5 font-weight-bold mb-4 border-bottom pb-2">Thông tin cá nhân</h3>
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="profile-form-grid">
            <div class="form-group-ailearn">
                <label class="small font-weight-bold text-muted">Họ và tên</label>
                <div class="p-3 border rounded bg-light font-weight-medium">@(string.IsNullOrWhiteSpace(Model.FullName) ? "Chưa cập nhật" : Model.FullName)</div>
            </div>

            <div class="form-group-ailearn">
                <label class="small font-weight-bold text-muted">Số điện thoại</label>
                <div class="p-3 border rounded bg-light font-weight-medium">@(string.IsNullOrWhiteSpace(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
            </div>

            <div class="form-group-ailearn">
                <label class="small font-weight-bold text-muted">Ngày sinh</label>
                <div class="p-3 border rounded bg-light font-weight-medium">@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")</div>
            </div>

            <div class="form-group-ailearn">
                <label class="small font-weight-bold text-muted">Giới tính</label>
                <div class="p-3 border rounded bg-light font-weight-medium">
                    @(string.IsNullOrWhiteSpace(Model.Gender) ? "Chưa cập nhật" :
                      Model.Gender == "MALE" ? "Nam" :
                      Model.Gender == "FEMALE" ? "Nữ" : "Khác")
                </div>
            </div>

            <div class="form-group-ailearn full-width">
                <label class="small font-weight-bold text-muted">Quốc gia</label>
                <div class="p-3 border rounded bg-light font-weight-medium">@(string.IsNullOrWhiteSpace(Model.Country) ? "Chưa cập nhật" : Model.Country)</div>
            </div>

            <div class="form-group-ailearn full-width">
                <label class="small font-weight-bold text-muted">Giới thiệu bản thân (Bio)</label>
                <div class="p-3 border rounded bg-light font-weight-medium min-vh-10" style="white-space: pre-wrap;">@(string.IsNullOrWhiteSpace(Model.Bio) ? "Bạn chưa có bài tự giới thiệu nào." : Model.Bio)</div>
            </div>
        </div>

        <h3 class="h5 font-weight-bold mt-5 mb-4 border-bottom pb-2">Cài đặt tài khoản</h3>
        <div class="profile-form-grid">
            <div class="form-group-ailearn">
                <label class="small font-weight-bold text-muted">Ngôn ngữ</label>
                <div class="p-3 border rounded bg-light font-weight-medium">@(Model.Language ?? "vi-VN")</div>
            </div>

            <div class="form-group-ailearn">
                <label class="small font-weight-bold text-muted">Múi giờ</label>
                <div class="p-3 border rounded bg-light font-weight-medium">@(Model.Timezone ?? "Asia/Ho_Chi_Minh")</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}

@model List<DuAnTotNghiep.Models.ViewModels.Student.StudentQuizItemViewModel>
@{
    Layout = "_AILearnLayout";
    ViewData["Title"] = "Bài tập trắc nghiệm";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-clipboard-list me-2"></i>Bài tập & Kiểm tra</h2>
        <p class="text-muted mb-0">Hệ thống tổng hợp tất cả bài tập từ các khóa học của bạn</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="fa-solid fa-inbox fa-3x mb-3 text-secondary"></i>
            <h5>Bạn chưa có bài tập nào!</h5>
            <p class="text-muted">Các bài tập sẽ xuất hiện ở đây khi bạn tham gia các khóa học.</p>
            <a href="/Courses" class="btn btn-primary mt-2">Khám phá khóa học ngay</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var quiz in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition-all">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                    <i class="fa-solid fa-book-open me-1"></i> @quiz.CourseName
                                </span>
                                @if (quiz.IsCompleted)
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2" title="Đã hoàn thành">
                                        <i class="fa-solid fa-check-circle"></i> Điểm cao nhất: @quiz.HighestScore
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2" title="Chưa làm">
                                        <i class="fa-regular fa-circle"></i> Chưa làm
                                    </span>
                                }
                            </div>
                            
                            <h5 class="card-title fw-bold mb-3">@quiz.QuizTitle</h5>
                            
                            <div class="d-flex gap-3 text-muted small mb-4">
                                <div><i class="fa-regular fa-circle-question me-1"></i>@quiz.TotalQuestions câu hỏi</div>
                                <div><i class="fa-regular fa-clock me-1"></i>@quiz.TimeLimit phút</div>
                            </div>
                            
                            @if (quiz.LastAttemptDate.HasValue)
                            {
                                <p class="small text-muted mb-4"><i class="fa-regular fa-calendar-check me-1"></i>Làm lần cuối: @quiz.LastAttemptDate.Value.ToString("dd/MM/yyyy HH:mm")</p>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <a href="/Quiz/Take/@quiz.TopicId" class="btn btn-@(quiz.IsCompleted ? "outline-primary" : "primary") w-100 rounded-pill">
                                @(quiz.IsCompleted ? "Làm lại bài" : "Bắt đầu làm bài") <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
    .transition-all {
        transition: all 0.2s ease;
    }
</style>

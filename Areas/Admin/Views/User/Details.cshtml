@model DuAnTotNghiep.Areas.Admin.ViewModels.AdminUserProfileViewModel
@{
    ViewData["Title"] = "Chi tiết tài khoản";

    var roleCode = (Model.RoleName ?? string.Empty).ToUpperInvariant();
    var statusCode = (Model.Status ?? string.Empty).ToUpperInvariant();
    var roleLabel = roleCode switch
    {
        "ADMIN" => "Quản trị viên",
        "TEACHER" => "Giáo viên",
        "STUDENT" => "Học viên",
        _ => Model.RoleName
    };
    var roleClass = roleCode switch
    {
        "ADMIN" => "bg-purple-100 text-purple-800 border-purple-200",
        "TEACHER" => "bg-blue-100 text-blue-800 border-blue-200",
        _ => "bg-slate-100 text-slate-800 border-slate-200"
    };
    var statusLabel = statusCode switch
    {
        "ACTIVE" => "Đang hoạt động",
        "LOCKED" => "Đã khóa",
        "DELETED" => "Đã xóa",
        "PENDING" => "Chờ duyệt",
        _ => Model.Status
    };
    var statusClass = statusCode switch
    {
        "ACTIVE" => "bg-emerald-100 text-emerald-800 border-emerald-200",
        "LOCKED" => "bg-amber-100 text-amber-800 border-amber-200",
        "DELETED" => "bg-red-100 text-red-800 border-red-200",
        _ => "bg-slate-100 text-slate-800 border-slate-200"
    };
    var statusDotClass = statusCode switch
    {
        "ACTIVE" => "bg-emerald-500",
        "LOCKED" => "bg-amber-500",
        "DELETED" => "bg-red-500",
        _ => "bg-slate-500"
    };
    var avatarUrl = !string.IsNullOrWhiteSpace(Model.AvatarUrl)
        ? Model.AvatarUrl
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName)}&background=F1F5F9&color=475569";
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Chi tiết tài khoản</h1>
            <p class="mt-1 text-sm text-slate-500">Xem hồ sơ, trạng thái đăng nhập và thao tác quản trị cho người dùng.</p>
        </div>
        <a asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Quay lại
        </a>
    </div>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-4">
                <img class="h-16 w-16 rounded-2xl border border-slate-100 object-cover shadow-sm" src="@avatarUrl" alt="@Model.FullName" />
                <div>
                    <h2 class="text-xl font-bold text-slate-900">@Model.FullName</h2>
                    <p class="text-sm text-slate-500">@Model.Email</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        <span class="inline-flex items-center rounded-md border px-2.5 py-1 text-xs font-bold @roleClass">@roleLabel</span>
                        <span class="inline-flex items-center rounded-md border px-2.5 py-1 text-xs font-bold @statusClass">
                            <span class="mr-1.5 h-1.5 w-1.5 rounded-full @statusDotClass"></span>
                            @statusLabel
                        </span>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3 text-sm sm:min-w-80">
                <div class="rounded-xl bg-slate-50 p-3">
                    <p class="text-xs font-bold uppercase text-slate-500">Ngày tạo</p>
                    <p class="mt-1 font-semibold text-slate-900">@Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="rounded-xl bg-slate-50 p-3">
                    <p class="text-xs font-bold uppercase text-slate-500">Đăng nhập lỗi</p>
                    <p class="mt-1 font-semibold text-slate-900">@Model.FailedLoginCount lần</p>
                </div>
            </div>
        </div>
    </section>

    <div class="grid gap-6 lg:grid-cols-3">
        <section class="lg:col-span-2 rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500">Thông tin hồ sơ</h3>
            </div>
            <div class="divide-y divide-slate-100">
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Họ và tên</dt>
                    <dd class="text-sm font-semibold text-slate-900 sm:col-span-2">@Model.FullName</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Email đăng nhập</dt>
                    <dd class="text-sm font-semibold text-slate-900 sm:col-span-2">@Model.Email</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Số điện thoại</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Ngày sinh</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Giới tính</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.Gender) ? "Chưa cập nhật" : Model.Gender)</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Quốc gia</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.Country) ? "Chưa cập nhật" : Model.Country)</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Tiểu sử</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.Bio) ? "Chưa cập nhật" : Model.Bio)</dd>
                </div>
            </div>
        </section>

        <aside class="space-y-6">
            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500">Bảo mật đăng nhập</h3>
                <dl class="mt-4 space-y-4 text-sm">
                    <div>
                        <dt class="font-bold text-slate-500">Ngày đăng ký</dt>
                        <dd class="mt-1 font-semibold text-slate-900">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                    </div>
                    <div>
                        <dt class="font-bold text-slate-500">Đăng nhập gần nhất</dt>
                        <dd class="mt-1 font-semibold text-slate-900">@(Model.LastLoginAt.HasValue ? Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm:ss") : "Chưa từng đăng nhập")</dd>
                    </div>
                    <div>
                        <dt class="font-bold text-slate-500">Đăng nhập sai</dt>
                        <dd class="mt-1 font-semibold text-slate-900">@Model.FailedLoginCount lần</dd>
                    </div>
                    <div>
                        <dt class="font-bold text-slate-500">Khóa tạm thời</dt>
                        <dd class="mt-1">
                            @if (Model.LockoutUntil.HasValue && Model.LockoutUntil.Value > DateTime.Now)
                            {
                                <span class="inline-flex rounded-md border border-red-200 bg-red-50 px-2.5 py-1 text-xs font-bold text-red-700">
                                    Đến @Model.LockoutUntil.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex rounded-md border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700">Không bị khóa tạm thời</span>
                            }
                        </dd>
                    </div>
                </dl>
            </section>

            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500">Thao tác quản trị</h3>
                <div class="mt-4 space-y-3">
                    @if (statusCode == "ACTIVE")
                    {
                        <form asp-action="Lock" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn KHÓA tài khoản này không? Người dùng sẽ bị chặn đăng nhập ngay lập tức.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.UserId" />
                            <button type="submit" class="admin-action-primary admin-action-lock">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                Khóa tài khoản
                            </button>
                        </form>
                    }
                    else if (statusCode == "LOCKED")
                    {
                        <form asp-action="Unlock" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn MỞ KHÓA tài khoản này không? Người dùng sẽ được phép đăng nhập lại.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.UserId" />
                            <button type="submit" class="admin-action-primary admin-action-unlock">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
                                Mở khóa tài khoản
                            </button>
                        </form>
                    }

                    <a asp-action="ResetPassword" asp-route-id="@Model.UserId" class="admin-action-primary admin-action-reset">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                        Reset mật khẩu
                    </a>
                    <a asp-controller="Achievements" asp-action="UserAchievements" asp-route-userId="@Model.UserId" class="btn btn-primary w-100">Quản lý huy hiệu</a>
                    <a asp-action="Statistics" asp-route-id="@Model.UserId" class="btn btn-info w-100">Thống kê</a>

                    <form asp-action="ChangeRole" method="post" class="mt-3 space-y-3 rounded border bg-light p-3" onsubmit="return confirm('Xác nhận đổi role cho tài khoản này?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="UserId" value="@Model.UserId" />
                        <label class="form-label">Thay đổi role</label>
                        <select name="NewRoleId" class="form-select">
                            <option value="1">ADMIN</option>
                            <option value="2">TEACHER</option>
                            <option value="3">STUDENT</option>
                        </select>
                        <button type="submit" class="btn btn-primary w-100">Lưu role</button>
                    </form>
                </div>
            </section>
        </aside>
    </div>
</div>

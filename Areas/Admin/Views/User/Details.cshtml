@model DuAnTotNghiep.Areas.Admin.ViewModels.AdminUserProfileViewModel
@{
    ViewData["Title"] = "Chi tiết tài khoản";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb & Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mb-2">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Quản lý Tài Khoản</a></li>
                    <li class="breadcrumb-item active text-primary font-weight-bold" aria-current="page">Chi tiết</li>
                </ol>
            </nav>
            <h2 class="h3 mb-0 text-gray-800 font-weight-bold">Chi tiết Tài Khoản</h2>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-medium">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Main Info Card -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-person-badge me-2"></i> Thông tin cơ bản</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Họ và tên</div>
                        <div class="col-sm-8 text-dark fw-medium">@Model.FullName</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Email đăng nhập</div>
                        <div class="col-sm-8 text-dark fw-medium">@Model.Email</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Ngày đăng ký</div>
                        <div class="col-sm-8 text-dark fw-medium">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Đăng nhập gần nhất</div>
                        <div class="col-sm-8 text-dark fw-medium">
                            @(Model.LastLoginAt.HasValue ? Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm:ss") : "Chưa từng đăng nhập")
                        </div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Số lần đăng nhập sai</div>
                        <div class="col-sm-8 text-dark fw-medium">
                            <span class="badge @(Model.FailedLoginCount > 0 ? "bg-warning text-dark" : "bg-success text-white") rounded-pill px-3 py-1">
                                @Model.FailedLoginCount lần
                            </span>
                        </div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Trạng thái khóa tạm thời</div>
                        <div class="col-sm-8 text-dark fw-medium">
                            @if (Model.LockoutUntil.HasValue && Model.LockoutUntil.Value > DateTime.Now)
                            {
                                <span class="badge bg-danger text-white rounded-pill px-3 py-1">
                                    <i class="bi bi-clock-history me-1"></i> Bị khóa đến @Model.LockoutUntil.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success text-white rounded-pill px-3 py-1">Không bị khóa</span>
                            }
                        </div>
                    </div>

                    <hr class="text-muted opacity-25">

                    <h6 class="mt-4 mb-3 font-weight-bold text-primary"><i class="bi bi-person-lines-fill me-2"></i> Chi tiết Hồ sơ</h6>

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Số điện thoại</div>
                        <div class="col-sm-8 text-dark fw-medium">@(string.IsNullOrEmpty(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Ngày sinh</div>
                        <div class="col-sm-8 text-dark fw-medium">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Giới tính</div>
                        <div class="col-sm-8 text-dark fw-medium">@(string.IsNullOrEmpty(Model.Gender) ? "Chưa cập nhật" : Model.Gender)</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Quốc gia</div>
                        <div class="col-sm-8 text-dark fw-medium">@(string.IsNullOrEmpty(Model.Country) ? "Chưa cập nhật" : Model.Country)</div>
                    </div>
                    <hr class="text-muted opacity-25">

                    <div class="row">
                        <div class="col-sm-4 text-muted font-weight-bold small text-uppercase">Tiểu sử</div>
                        <div class="col-sm-8 text-dark fw-medium">@(string.IsNullOrEmpty(Model.Bio) ? "Chưa cập nhật" : Model.Bio)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Role & Status Card -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-shield-check me-2"></i> Phân quyền & Trạng thái</h6>
                </div>
                <div class="card-body p-4 text-center">

                    <div class="mb-5">
                        <p class="text-muted font-weight-bold small text-uppercase mb-2">Vai trò hiện tại</p>
                        @{
                            var roleClass = Model.RoleName switch
                            {
                                "ADMIN" => "bg-danger text-white",
                                "TEACHER" => "bg-info text-dark",
                                _ => "bg-secondary text-white"
                            };
                        }
                        <span class="badge @roleClass rounded-pill px-4 py-2 fs-6">@Model.RoleName</span>
                    </div>

                    <div class="mb-4">
                        <p class="text-muted font-weight-bold small text-uppercase mb-2">Trạng thái tài khoản</p>
                        @{
                            var statusClass = Model.Status switch
                            {
                                "ACTIVE" => "bg-success text-white",
                                "LOCKED" => "bg-warning text-dark",
                                "DELETED" => "bg-danger text-white",
                                _ => "bg-secondary text-white"
                            };
                        }
                        <span class="badge @statusClass rounded-pill px-4 py-2 fs-6 mb-4 d-inline-block">@Model.Status</span>
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="d-grid gap-2 mt-4">
                        <form asp-action="ToggleLock" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn thay đổi trạng thái khóa của tài khoản này không?');">
                            <input type="hidden" name="id" value="@Model.UserId" />
                            <button type="submit" class="btn @(Model.Status == "ACTIVE" ? "btn-warning text-white" : "btn-success") rounded-pill w-100 fw-medium">
                                <i class="bi @(Model.Status == "ACTIVE" ? "bi-lock-fill" : "bi-unlock-fill") me-2"></i>
                                @(Model.Status == "ACTIVE" ? "Khóa tài khoản" : "Mở khóa tài khoản")
                            </button>
                        </form>

                        <a asp-action="ResetPassword" asp-route-id="@Model.UserId" class="btn btn-danger rounded-pill w-100 fw-medium">
                            <i class="bi bi-key-fill me-2"></i> Reset Password
                        </a>

                        <a asp-controller="Achievements" asp-action="UserAchievements" asp-route-userId="@Model.UserId" class="btn btn-primary rounded-pill w-100 fw-medium">
                            <i class="bi bi-award-fill me-2"></i> Quản lý Huy hiệu
                        </a>

                        <a asp-action="Statistics" asp-route-id="@Model.UserId" class="btn btn-info rounded-pill w-100 fw-medium text-white">
                            <i class="bi bi-bar-chart-fill me-2"></i> Thống kê
                        </a>

                        <!-- Đổi Role form -->
                        <form asp-action="ChangeRole" method="post" class="mt-3 p-3 border rounded bg-light" onsubmit="return confirm('Xác nhận đổi Role?');">
                            <input type="hidden" name="UserId" value="@Model.UserId" />
                            <label class="form-label font-weight-bold text-muted small text-uppercase">Thay đổi Role</label>
                            <div class="input-group">
                                <select name="NewRoleId" class="form-select">
                                    <option value="1">ADMIN</option>
                                    <option value="2">TEACHER</option>
                                    <option value="3">STUDENT</option>
                                </select>
                                <button type="submit" class="btn btn-primary fw-medium">Lưu</button>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


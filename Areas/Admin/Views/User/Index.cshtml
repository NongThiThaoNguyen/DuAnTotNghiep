@model DuAnTotNghiep.Areas.Admin.ViewModels.UserListViewModel
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800 font-weight-bold">Quản lý Tài Khoản</h2>
    </div>

    <!-- Filter Card -->
    <div class="card shadow-sm mb-4 border-0 rounded-3">
        <div class="card-body bg-light rounded-3">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label font-weight-bold text-secondary small">Tìm kiếm</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" asp-for="Filter.Keyword" placeholder="Nhập họ tên, email...">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label font-weight-bold text-secondary small">Vai trò</label>
                        <select class="form-select" asp-for="Filter.Role">
                            <option value="">Tất cả vai trò</option>
                            <option value="ADMIN">Quản trị viên (ADMIN)</option>
                            <option value="TEACHER">Giáo viên (TEACHER)</option>
                            <option value="STUDENT">Học viên (STUDENT)</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label font-weight-bold text-secondary small">Trạng thái</label>
                        <select class="form-select" asp-for="Filter.Status">
                            <option value="">Tất cả trạng thái</option>
                            <option value="ACTIVE">Hoạt động (ACTIVE)</option>
                            <option value="LOCKED">Đã khóa (LOCKED)</option>
                            <option value="PENDING">Chờ duyệt (PENDING)</option>
                            <option value="DELETED">Đã xóa (DELETED)</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100 fw-medium">
                            <i class="bi bi-funnel me-1"></i> Lọc dữ liệu
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Data Table Card -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3 text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">STT</th>
                            <th class="px-4 py-3 text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">Họ tên</th>
                            <th class="px-4 py-3 text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">Email</th>
                            <th class="px-4 py-3 text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">Vai trò</th>
                            <th class="px-4 py-3 text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">Trạng thái</th>
                            <th class="px-4 py-3 text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">Ngày tạo</th>
                            <th class="px-4 py-3 text-end text-secondary text-uppercase" style="font-size: 0.75rem; font-weight: 600;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Users.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    Không tìm thấy dữ liệu phù hợp.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = (Model.Filter.Page - 1) * Model.Filter.PageSize + 1;
                            foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td class="px-4 py-3">@stt</td>
                                    <td class="px-4 py-3 fw-medium">@user.FullName</td>
                                    <td class="px-4 py-3 text-muted">@user.Email</td>
                                    <td class="px-4 py-3">
                                        @{
                                            var roleClass = user.RoleName switch
                                            {
                                                "ADMIN" => "bg-danger text-white",
                                                "TEACHER" => "bg-info text-dark",
                                                _ => "bg-secondary text-white"
                                            };
                                        }
                                        <span class="badge @roleClass rounded-pill px-3 py-2" style="font-weight: 500;">@user.RoleName</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        @{
                                            var statusClass = user.Status switch
                                            {
                                                "ACTIVE" => "bg-success text-white",
                                                "LOCKED" => "bg-warning text-dark",
                                                "DELETED" => "bg-danger text-white",
                                                _ => "bg-secondary text-white"
                                            };
                                        }
                                        <span class="badge @statusClass rounded-pill px-3 py-2" style="font-weight: 500;">@user.Status</span>
                                    </td>
                                    <td class="px-4 py-3 text-muted">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3 text-end">
                                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-medium">
                                            Chi tiết
                                        </a>
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white py-3 border-0">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.Filter.Page == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-Keyword="@Model.Filter.Keyword" 
                               asp-route-Role="@Model.Filter.Role" 
                               asp-route-Status="@Model.Filter.Status" 
                               asp-route-Page="@(Model.Filter.Page - 1)">Trước</a>
                        </li>
                        
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.Filter.Page == i ? "active" : "")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-Keyword="@Model.Filter.Keyword" 
                                   asp-route-Role="@Model.Filter.Role" 
                                   asp-route-Status="@Model.Filter.Status" 
                                   asp-route-Page="@i">@i</a>
                            </li>
                        }
                        
                        <li class="page-item @(Model.Filter.Page == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-Keyword="@Model.Filter.Keyword" 
                               asp-route-Role="@Model.Filter.Role" 
                               asp-route-Status="@Model.Filter.Status" 
                               asp-route-Page="@(Model.Filter.Page + 1)">Tiếp</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

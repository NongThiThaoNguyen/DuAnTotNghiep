@model DuAnTotNghiep.Areas.Admin.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Quản lý Tài Khoản</a></li>
            <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@ViewBag.UserId" class="text-decoration-none text-muted">Chi tiết</a></li>
            <li class="breadcrumb-item active text-primary font-weight-bold" aria-current="page">Reset Password</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-danger text-white py-3">
                    <h6 class="m-0 font-weight-bold"><i class="bi bi-key-fill me-2"></i> Đặt lại mật khẩu</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ResetPassword" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn thiết lập lại mật khẩu mới cho tài khoản này?');">
                        <input type="hidden" name="id" value="@ViewBag.UserId" />

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Mật khẩu mới</label>
                            <input type="password" name="newPassword" class="form-control form-control-lg" required minlength="6" />
                            <small class="text-muted">Nhập mật khẩu mới cho tài khoản (ít nhất 6 ký tự).</small>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Details" asp-route-id="@ViewBag.UserId" class="btn btn-outline-secondary">Hủy</a>
                            <button type="submit" class="btn btn-danger"><i class="bi bi-save me-2"></i> Lưu Mật Khẩu</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<DuAnTotNghiep.Models.CompetencyAnalysis>

@{
    ViewData["Title"] = "Quản lý Báo cáo Năng lực";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Ensure proper layout for Admin
}

<!-- Header -->
<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <nav aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-slate-500 mb-1">
                <li><a href="#" class="hover:text-blue-600">Admin</a></li>
                <li><span class="text-slate-400">/</span></li>
                <li class="font-medium text-slate-900" aria-current="page">Báo cáo năng lực</li>
            </ol>
        </nav>
        <h1 class="text-2xl font-bold text-slate-900">Quản lý Báo cáo Năng lực</h1>
    </div>
    <div class="flex gap-2">
        <a href="@Url.Action("AuditLogs")" class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus:outline-none transition-all">
            <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Xem nhật ký kiểm toán
        </a>
        <button class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-slate-300 hover:bg-slate-50">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Xuất dữ liệu
        </button>
    </div>
</div>

<!-- Filter Toolbar -->
<div class="mb-6 rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Search -->
        <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <input type="text" class="block w-full rounded-lg border-0 py-2 pl-10 pr-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" placeholder="Tìm tên, mã học sinh...">
        </div>
        <!-- Level Filter -->
        <select class="block w-full rounded-lg border-0 py-2 pl-3 pr-10 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6">
            <option value="">Tất cả Trình độ</option>
            <option value="A1">A1 - Beginner</option>
            <option value="A2">A2 - Elementary</option>
            <option value="B1">B1 - Intermediate</option>
            <option value="B2">B2 - Upper Intermediate</option>
            <option value="C1">C1 - Advanced</option>
        </select>
        <!-- Status Filter -->
        <select class="block w-full rounded-lg border-0 py-2 pl-3 pr-10 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6">
            <option value="">Tất cả Trạng thái</option>
            <option value="COMPLETED">Hoàn tất</option>
            <option value="PENDING">Đang xử lý</option>
            <option value="FAILED">Lỗi / Fallback</option>
        </select>
        <!-- Date Range (Mockup) -->
        <input type="date" class="block w-full rounded-lg border-0 py-2 pl-3 pr-3 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6">
    </div>
</div>

<!-- Data Table -->
<div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
            <thead class="bg-slate-50 text-slate-700">
                <tr>
                    <th scope="col" class="px-6 py-4 font-semibold">Mã BC</th>
                    <th scope="col" class="px-6 py-4 font-semibold">Học sinh</th>
                    <th scope="col" class="px-6 py-4 font-semibold">Trình độ</th>
                    <th scope="col" class="px-6 py-4 font-semibold">Ngày tạo</th>
                    <th scope="col" class="px-6 py-4 font-semibold text-center">Trạng thái</th>
                    <th scope="col" class="px-6 py-4 font-semibold text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white" id="analysisTableBody">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var studentName = item.Student?.FullName ?? "Unknown";
                        var studentEmail = item.Student?.Email ?? "No email";
                        var levelName = item.CurrentLevel?.Name ?? "Unknown";
                        var isFallback = false; // Pseudo-logic for UI mockup
                        var status = item.Id % 5 == 0 ? "PENDING" : (isFallback ? "FAILED" : "COMPLETED");

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="whitespace-nowrap px-6 py-4 font-mono text-slate-500">#REP-@item.Id</td>
                            <td class="whitespace-nowrap px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-100 text-blue-600 font-bold text-xs">
                                        @studentName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <p class="font-medium text-slate-900">@studentName</p>
                                        <p class="text-xs text-slate-500">@studentEmail</p>
                                    </div>
                                </div>
                            </td>
                            <td class="whitespace-nowrap px-6 py-4">
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-800">
                                    @levelName
                                </span>
                            </td>
                            <td class="whitespace-nowrap px-6 py-4 text-slate-500">
                                @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="whitespace-nowrap px-6 py-4 text-center">
                                @if (status == "COMPLETED")
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-medium text-emerald-800 ring-1 ring-inset ring-emerald-200">
                                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Hoàn tất
                                    </span>
                                }
                                else if (status == "PENDING")
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-2.5 py-1 text-xs font-medium text-amber-800 ring-1 ring-inset ring-amber-200">
                                        <span class="h-3 w-3 animate-spin rounded-full border-2 border-amber-500 border-t-transparent"></span> Đang xử lý
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 px-2.5 py-1 text-xs font-medium text-red-800 ring-1 ring-inset ring-red-200">
                                        <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span> AI Lỗi / Rule-based
                                    </span>
                                }
                            </td>
                            <td class="whitespace-nowrap px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="rounded-lg p-1.5 text-slate-400 hover:bg-blue-50 hover:text-blue-600 transition-colors" title="Xem chi tiết">
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-slate-500">
                            <svg class="mx-auto h-12 w-12 text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                            <p>Không tìm thấy báo cáo nào khớp với điều kiện lọc.</p>
                            <button class="mt-2 text-sm text-blue-600 hover:underline">Xóa tất cả bộ lọc</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="flex items-center justify-between border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
        <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-slate-700">
                    Đang xem <span class="font-medium">1</span> đến <span class="font-medium">@Model?.Count()</span> trên tổng số <span class="font-medium">@Model?.Count()</span> kết quả
                </p>
            </div>
            <div>
                <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                    <a href="#" class="relative inline-flex items-center rounded-l-md px-2 py-2 text-slate-400 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:z-20 focus:outline-offset-0">
                        <span class="sr-only">Previous</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd"/></svg>
                    </a>
                    <a href="#" aria-current="page" class="relative z-10 inline-flex items-center bg-blue-600 px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600">1</a>
                    <a href="#" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-slate-900 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:z-20 focus:outline-offset-0">2</a>
                    <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-slate-700 ring-1 ring-inset ring-slate-300 focus:outline-offset-0">...</span>
                    <a href="#" class="relative inline-flex items-center rounded-r-md px-2 py-2 text-slate-400 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:z-20 focus:outline-offset-0">
                        <span class="sr-only">Next</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg>
                    </a>
                </nav>
            </div>
        </div>
    </div>
</div>

@functions {
    // Temporary helper extension mockup for the view
    public static class CompetencyAnalysisExtensions {
        public static bool IsAiFallback(DuAnTotNghiep.Models.CompetencyAnalysis a) => false;
    }
}

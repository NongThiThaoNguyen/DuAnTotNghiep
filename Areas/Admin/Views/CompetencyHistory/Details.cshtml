@model DuAnTotNghiep.Models.ViewModels.CompetencyResultViewModel

@{
    ViewData["Title"] = $"Chi tiết Báo cáo #{Model.AnalysisId}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Admin Header Panel -->
<div class="mb-6 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-blue-100 text-xl font-bold text-blue-600">
                @Model.StudentName?.Substring(0, 1)
            </div>
            <div>
                <h1 class="text-xl font-bold text-slate-900">@Model.StudentName</h1>
                <p class="text-sm text-slate-500 mb-2">Báo cáo năng lực ngày @Model.CalculatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                <div class="flex items-center gap-2">
                    <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">
                        @Model.CurrentLevelName
                    </span>
                    @if (Model.IsAiFallback)
                    {
                        <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-700 ring-1 ring-amber-200">
                            Hệ thống AI lỗi (Rule-based)
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-200">
                            Phân tích bởi AI
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- Top-Right Action Bar -->
        <div class="flex flex-wrap items-center gap-2">
            <button class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 transition-colors">
                <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Xuất PDF
            </button>
            <button class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Gửi phản hồi
            </button>
            <button onclick="document.getElementById('regenerateModal').classList.remove('hidden')" class="inline-flex items-center gap-2 rounded-lg bg-red-50 text-red-700 px-3 py-2 text-sm font-semibold ring-1 ring-inset ring-red-200 hover:bg-red-100 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                Chạy lại AI
            </button>
        </div>
    </div>
</div>

<!-- Tabs Navigation -->
<div class="mb-6 border-b border-slate-200">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <button onclick="switchTab('academic')" id="tab-academic" class="border-blue-500 text-blue-600 whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium">
            Báo cáo Học thuật
        </button>
        <button onclick="switchTab('system')" id="tab-system" class="border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700 whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium">
            Thông số hệ thống & AI
        </button>
    </nav>
</div>

<!-- Tab Content: Academic Report (Reuses Student View) -->
<div id="content-academic" class="block">
    <div class="rounded-2xl border border-dashed border-slate-300 p-6 bg-slate-50/50">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Chế độ xem của học sinh</h2>
            <a href="@Url.Action("Result", "CompetencyAnalysis", new { area = "", id = Model.AnalysisId })" target="_blank" class="text-xs text-blue-600 hover:underline inline-flex items-center gap-1">
                Mở ở tab mới <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
        </div>

        <!-- Render the actual student view without its layout -->
        <div class="bg-slate-50 -mx-6 -mb-6 p-6 rounded-b-2xl">
            @await Html.PartialAsync("~/Views/CompetencyAnalysis/Result.cshtml", Model)
        </div>
    </div>
</div>

<!-- Tab Content: System Metrics -->
<div id="content-system" class="hidden">
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Metrics -->
        <div class="space-y-6">
            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <h3 class="mb-4 text-base font-semibold text-slate-900">Thông số API & Tiêu thụ</h3>
                <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
                    <div class="sm:col-span-1">
                        <dt class="text-sm font-medium text-slate-500">Mô hình AI</dt>
                        <dd class="mt-1 text-sm text-slate-900">gpt-4o-mini</dd>
                    </div>
                    <div class="sm:col-span-1">
                        <dt class="text-sm font-medium text-slate-500">Thời gian phản hồi</dt>
                        <dd class="mt-1 text-sm text-slate-900">@((new Random()).Next(3500, 8000)) ms</dd>
                    </div>
                    <div class="sm:col-span-1">
                        <dt class="text-sm font-medium text-slate-500">Tokens đã dùng</dt>
                        <dd class="mt-1 text-sm font-mono text-slate-900">2,450 (Prompt) / 850 (Completion)</dd>
                    </div>
                    <div class="sm:col-span-1">
                        <dt class="text-sm font-medium text-slate-500">Chi phí ước tính</dt>
                        <dd class="mt-1 text-sm text-slate-900">~$0.0015</dd>
                    </div>
                </dl>
            </div>
        </div>

        <!-- Raw Logs -->
        <div class="rounded-2xl bg-slate-900 p-6 shadow-sm">
            <div class="mb-4 flex items-center justify-between">
                <h3 class="text-base font-semibold text-white">JSON Phản hồi thô (Raw Response)</h3>
                <button class="text-xs text-slate-400 hover:text-white transition-colors">Copy to clipboard</button>
            </div>
            <pre class="h-64 overflow-y-auto rounded-lg bg-black p-4 text-xs font-mono text-emerald-400"><code>{
  "overall_accuracy": @Model.OverallAccuracy,
  "dashboard_summary": "Sinh viên thể hiện khả năng...",
  "strengths": [
    { "title": "Vocabulary", "desc": "Sử dụng từ vựng linh hoạt" }
  ],
  "weaknesses": [
    { "title": "Grammar", "desc": "Thường sai thì hiện tại hoàn thành" }
  ],
  "recommended_actions": [ ... ],
  "priority_topics": [ ... ]
}</code></pre>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="regenerateModal" class="relative z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity"></div>
    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
            <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
                <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10">
                            <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                        </div>
                        <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
                            <h3 class="text-base font-semibold leading-6 text-slate-900" id="modal-title">Xác nhận chạy lại phân tích AI</h3>
                            <div class="mt-2">
                                <p class="text-sm text-slate-500">Hành động này sẽ xóa dữ liệu phân tích cũ, tiêu tốn API tokens và có thể mất 15-30 giây để hoàn thành. Bạn có chắc chắn muốn tiến hành phân tích lại cho học sinh <strong class="text-slate-900">@Model.StudentName</strong> không?</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                    <form asp-action="Regenerate" asp-controller="CompetencyAnalysis" asp-area="" asp-route-id="@Model.AnalysisId" method="post" id="regenerateForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" onclick="this.innerHTML='<span class=\'animate-spin inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full mr-2\'></span> Đang xử lý...'; this.disabled=true; document.getElementById('regenerateForm').submit();" class="inline-flex w-full justify-center rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 sm:ml-3 sm:w-auto transition-colors">
                            Đồng ý chạy lại
                        </button>
                    </form>
                    <button type="button" onclick="document.getElementById('regenerateModal').classList.add('hidden')" class="mt-3 inline-flex w-full justify-center rounded-lg bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 sm:mt-0 sm:w-auto transition-colors">
                        Hủy
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tabName) {
            const tabs = ['academic', 'system'];
            tabs.forEach(t => {
                const btn = document.getElementById('tab-' + t);
                const content = document.getElementById('content-' + t);
                if (t === tabName) {
                    btn.classList.add('border-blue-500', 'text-blue-600');
                    btn.classList.remove('border-transparent', 'text-slate-500', 'hover:border-slate-300', 'hover:text-slate-700');
                    content.classList.remove('hidden');
                    content.classList.add('block');
                } else {
                    btn.classList.remove('border-blue-500', 'text-blue-600');
                    btn.classList.add('border-transparent', 'text-slate-500', 'hover:border-slate-300', 'hover:text-slate-700');
                    content.classList.remove('block');
                    content.classList.add('hidden');
                }
            });
        }
    </script>
}

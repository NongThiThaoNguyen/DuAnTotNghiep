@model IReadOnlyList<DuAnTotNghiep.Models.SystemSetting>
@{
    ViewData["Title"] = "Cài đặt hệ thống";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">
            @TempData["Error"]
        </div>
    }

    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Cài đặt hệ thống</h1>
            <p class="mt-1 text-sm text-slate-500">Chỉnh sửa các cấu hình chung đang được lưu trong hệ thống.</p>
        </div>
        <span class="inline-flex w-fit items-center rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600">
            @Model.Count cấu hình
        </span>
    </div>

    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
        @if (Model.Count == 0)
        {
            <div class="px-6 py-12 text-center">
                <h2 class="text-base font-semibold text-slate-800">Chưa có cấu hình</h2>
                <p class="mt-1 text-sm text-slate-500">Bảng system_settings hiện chưa có dữ liệu để hiển thị.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="w-64 px-5 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Key</th>
                            <th class="min-w-80 px-5 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Value</th>
                            <th class="min-w-72 px-5 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Description</th>
                            <th class="w-36 px-5 py-3 text-right text-xs font-bold uppercase tracking-wider text-slate-500">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var setting in Model.OrderBy(s => s.SettingKey))
                        {
                            var isSecret = setting.SettingKey.Contains("Password", StringComparison.OrdinalIgnoreCase)
                                || setting.SettingKey.Contains("Secret", StringComparison.OrdinalIgnoreCase)
                                || setting.SettingKey.Contains("ApiKey", StringComparison.OrdinalIgnoreCase);

                            <tr class="align-top hover:bg-slate-50/70">
                                <td class="px-5 py-4">
                                    <div class="break-all font-mono text-sm font-semibold text-slate-800">@setting.SettingKey</div>
                                    <div class="mt-1 text-xs text-slate-400">
                                        Cập nhật: @(setting.UpdatedAt == default ? "Chưa có" : setting.UpdatedAt.ToString("dd/MM/yyyy HH:mm"))
                                    </div>
                                </td>
                                <td class="px-5 py-4">
                                    <form asp-action="Update" method="post" id="setting-form-@setting.Id" class="min-w-72">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="key" value="@setting.SettingKey" />
                                        @if (isSecret)
                                        {
                                            <input type="password" name="value" value="@setting.SettingValue" autocomplete="new-password" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-800 outline-hidden transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" />
                                        }
                                        else
                                        {
                                            <textarea name="value" rows="2" class="w-full resize-y rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-800 outline-hidden transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">@setting.SettingValue</textarea>
                                        }
                                    </form>
                                </td>
                                <td class="px-5 py-4 text-sm leading-6 text-slate-600">
                                    @(string.IsNullOrWhiteSpace(setting.Description) ? "Không có mô tả" : setting.Description)
                                </td>
                                <td class="px-5 py-4 text-right">
                                    <button type="submit" form="setting-form-@setting.Id" class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-hidden focus:ring-2 focus:ring-blue-500/30">
                                        Lưu
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

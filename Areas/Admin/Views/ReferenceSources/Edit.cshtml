@model DuAnTotNghiep.Models.ViewModels.Admin.ReferenceSources.EditReferenceSourceViewModel
@using DuAnTotNghiep.Models.Enums
@using DuAnTotNghiep.Helpers
@{
    ViewData["Title"] = "Chỉnh sửa nguồn tham khảo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h2 class="mt-4">Chỉnh sửa nguồn tham khảo hợp pháp</h2>

    <div class="row mt-4">
        <div class="col-md-8">
            <!-- Cảnh báo tự động hạ trạng thái đối với nguồn đã duyệt -->
            @if (Model.Status == ReferenceReviewStatus.APPROVED)
            {
                <div class="alert alert-warning mb-4">
                    <h5><i class="fas fa-exclamation-triangle"></i> Cảnh báo thu hồi phê duyệt</h5>
                    <p class="mb-0">Nguồn tham khảo này đã được phê duyệt. Việc thay đổi địa chỉ URL, bằng chứng tuân thủ, loại nguồn, ghi chú bản quyền hoặc chính sách sử dụng sẽ <strong>tự động thu hồi phê duyệt</strong> và chuyển nguồn về trạng thái <strong>Chờ duyệt (Pending Review)</strong> để ban kiểm duyệt đánh giá lại.</p>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Cập nhật thông tin nguồn tham khảo</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-controller="ReferenceSources" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Status" />

                        <!-- Hiển thị trạng thái tĩnh -->
                        <div class="mb-3">
                            <label class="form-label d-block">Trạng thái hiện tại</label>
                            <span class="badge @ReferenceHelper.GetReviewStatusBadgeClass(Model.Status) fs-6 py-2 px-3">
                                @ReferenceHelper.GetReviewStatusLabel(Model.Status)
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SourceName" class="form-label">Tên nguồn tham khảo <span class="text-danger">*</span></label>
                            <input asp-for="SourceName" class="form-control" required />
                            <span asp-validation-for="SourceName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SourceUrl" class="form-label">Địa chỉ URL</label>
                            <input asp-for="SourceUrl" class="form-control" type="url" />
                            <span asp-validation-for="SourceUrl" class="text-danger"></span>
                            <small class="text-muted">Nhập link trang chủ hoặc link chi tiết nguồn tham khảo (Bắt buộc đối với nguồn bên ngoài).</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ComplianceEvidenceUrl" class="form-label">URL bằng chứng tuân thủ</label>
                            <input asp-for="ComplianceEvidenceUrl" class="form-control" type="url" />
                            <span asp-validation-for="ComplianceEvidenceUrl" class="text-danger"></span>
                            <small class="text-muted">Link bằng chứng giấy phép, điều khoản sử dụng hoặc tài liệu xác minh bản quyền.</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SourceType" class="form-label">Loại nguồn tham khảo <span class="text-danger">*</span></label>
                                <select asp-for="SourceType" class="form-select" asp-items="ViewBag.SourceTypes" required>
                                    <option value="">-- Chọn loại nguồn --</option>
                                </select>
                                <span asp-validation-for="SourceType" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="UsagePolicy" class="form-label">Chính sách sử dụng</label>
                                <select asp-for="UsagePolicy" class="form-select" asp-items="ViewBag.UsagePolicies">
                                    <option value="">-- Chọn chính sách --</option>
                                </select>
                                <span asp-validation-for="UsagePolicy" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Author" class="form-label">Tác giả</label>
                                <input asp-for="Author" class="form-control" />
                                <span asp-validation-for="Author" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Organization" class="form-label">Tổ chức</label>
                                <input asp-for="Organization" class="form-control" />
                                <span asp-validation-for="Organization" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả tóm tắt</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LicenseNote" class="form-label">Ghi chú bản quyền / Giấy phép</label>
                            <textarea asp-for="LicenseNote" class="form-control" rows="4" placeholder="Ví dụ: Sử dụng theo giấy phép CC-BY, hoặc chỉ lưu liên kết ngoài... (Bắt buộc đối với nguồn bên ngoài)."></textarea>
                            <span asp-validation-for="LicenseNote" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActiveSwitch">
                            <label class="form-check-label" for="IsActiveSwitch">Cho phép hoạt động (IsActive)</label>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-warning"><i class="fas fa-save"></i> Lưu cập nhật</button>
                            <a asp-action="Details" asp-controller="ReferenceSources" asp-route-id="@Model.Id" class="btn btn-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

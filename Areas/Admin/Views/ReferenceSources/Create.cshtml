@model DuAnTotNghiep.Models.ViewModels.Admin.ReferenceSources.CreateReferenceSourceViewModel
@{
    ViewData["Title"] = "Thêm nguồn tham khảo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h2 class="mt-4">Thêm nguồn tham khảo hợp pháp mới</h2>

    <div class="row mt-4">
        <div class="col-md-8">
            <!-- Cảnh báo bản quyền nghiêm ngặt -->
            <div class="alert alert-warning mb-4">
                <h5><i class="fas fa-exclamation-triangle"></i> Cảnh báo bản quyền</h5>
                <p class="mb-0">Hệ thống chỉ lưu trữ thông tin tham khảo và siêu dữ liệu (metadata). <strong>Tuyệt đối không lưu trữ hay tải lên các tệp tin chứa nội dung có bản quyền</strong> (như PDF, DOCX, PPTX, hình ảnh hoặc video) tại màn hình này.</p>
            </div>

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin nguồn tham khảo</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" asp-controller="ReferenceSources" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="SourceName" class="form-label">Tên nguồn tham khảo <span class="text-danger">*</span></label>
                            <input asp-for="SourceName" class="form-control" placeholder="Ví dụ: Cambridge Dictionary, Oxford Practice..." required />
                            <span asp-validation-for="SourceName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SourceUrl" class="form-label">Địa chỉ URL</label>
                            <input asp-for="SourceUrl" class="form-control" type="url" placeholder="https://example.com" />
                            <span asp-validation-for="SourceUrl" class="text-danger"></span>
                            <small class="text-muted">Nhập link trang chủ hoặc link chi tiết nguồn tham khảo (Bắt buộc đối với nguồn bên ngoài).</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SourceType" class="form-label">Loại nguồn tham khảo <span class="text-danger">*</span></label>
                                <select asp-for="SourceType" class="form-select" asp-items="ViewBag.SourceTypes" required>
                                    <option value="">-- Chọn loại nguồn --</option>
                                </select>
                                <span asp-validation-for="SourceType" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="UsagePolicy" class="form-label">Chính sách sử dụng</label>
                                <select asp-for="UsagePolicy" class="form-select" asp-items="ViewBag.UsagePolicies">
                                    <option value="">-- Chọn chính sách --</option>
                                </select>
                                <span asp-validation-for="UsagePolicy" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Author" class="form-label">Tác giả</label>
                                <input asp-for="Author" class="form-control" placeholder="Tác giả hoặc người biên soạn..." />
                                <span asp-validation-for="Author" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Organization" class="form-label">Tổ chức</label>
                                <input asp-for="Organization" class="form-control" placeholder="Tên nhà xuất bản, tổ chức sở hữu..." />
                                <span asp-validation-for="Organization" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả tóm tắt</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Thông tin mô tả tóm tắt về nguồn tham khảo..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LicenseNote" class="form-label">Ghi chú bản quyền / Giấy phép</label>
                            <textarea asp-for="LicenseNote" class="form-control" rows="4" placeholder="Ví dụ: Sử dụng theo giấy phép CC-BY, hoặc chỉ lưu liên kết ngoài không sao chép... (Bắt buộc đối với nguồn bên ngoài)."></textarea>
                            <span asp-validation-for="LicenseNote" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Thêm mới</button>
                            <a asp-action="Index" asp-controller="ReferenceSources" class="btn btn-secondary">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

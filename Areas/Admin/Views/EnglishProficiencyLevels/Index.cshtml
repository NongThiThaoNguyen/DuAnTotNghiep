@model IEnumerable<DuAnTotNghiep.Models.DTOs.Level.LevelListItemDto>
@{
    ViewData["Title"] = "English Proficiency Levels";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h2 class="mt-4">English Proficiency Levels</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (User.IsInRole("Admin"))
    {
        <div class="mb-3">
            <a asp-action="Create" class="btn btn-primary">Create New Level</a>
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Order Index</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@item.OrderIndex</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                             @if (item.IsActive)
                             {
                                 <form asp-action="Deactivate" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn ngừng hoạt động (Deactivate) Level này?');">
                                     <button type="submit" class="btn btn-sm btn-danger">Deactivate</button>
                                 </form>
                                 <form asp-action="Archive" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn lưu trữ (Archive) Level này?');">
                                     <button type="submit" class="btn btn-sm btn-secondary">Archive</button>
                                 </form>
                             }
                             else
                             {
                                 <form asp-action="Restore" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn khôi phục (Restore) Level này?');">
                                     <button type="submit" class="btn btn-sm btn-success">Restore</button>
                                 </form>
                             }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

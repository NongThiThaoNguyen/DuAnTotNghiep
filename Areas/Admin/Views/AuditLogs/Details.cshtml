@model DuAnTotNghiep.Models.AuditLog
@{
    ViewData["Title"] = "Chi tiết Audit Log";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="w-full">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Chi tiết lịch sử</h2>
            <p class="text-sm text-slate-500 mt-1">Thông tin chi tiết về hành động của hệ thống.</p>
        </div>
        <a asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-slate-300 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-50 focus:ring-4 focus:ring-slate-100 transition-all shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-xs border border-slate-200 overflow-hidden mb-6">
                <div class="p-5 border-b border-slate-200 bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">Thông tin cơ bản</h3>
                </div>
                <div class="p-5 space-y-4">
                    <div>
                        <span class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Thời gian</span>
                        <span class="text-sm text-slate-800">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</span>
                    </div>
                    <div>
                        <span class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Người thực hiện</span>
                        @if (Model.User != null)
                        {
                            <span class="text-sm text-slate-800 font-medium">@Model.User.FullName</span>
                            <span class="text-xs text-slate-500 block">@Model.User.Email</span>
                        }
                        else
                        {
                            <span class="text-sm text-slate-500 italic">Hệ thống</span>
                        }
                    </div>
                    <div>
                        <span class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Hành động</span>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                            @Model.Action
                        </span>
                    </div>
                    <div>
                        <span class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Đối tượng</span>
                        <span class="text-sm text-slate-800">@Model.EntityName <span class="text-slate-500 text-xs">(ID: @Model.EntityId)</span></span>
                    </div>
                    <div>
                        <span class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">IP Address</span>
                        <span class="text-sm text-slate-800">@Model.IpAddress</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl shadow-xs border border-slate-200 overflow-hidden">
                <div class="p-5 border-b border-slate-200 bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">Dữ liệu thay đổi</h3>
                </div>
                <div class="p-5">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <h4 class="text-sm font-bold text-slate-600 mb-3">Dữ liệu cũ (Old Value)</h4>
                            <div class="bg-slate-50 rounded-xl border border-slate-200 p-4 h-96 overflow-y-auto">
                                @if (!string.IsNullOrEmpty(Model.OldValue))
                                {
                                    <pre class="text-xs text-slate-700 whitespace-pre-wrap font-mono">@Model.OldValue</pre>
                                }
                                else
                                {
                                    <div class="h-full flex items-center justify-center">
                                        <span class="text-sm text-slate-400 italic">Không có dữ liệu</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-slate-600 mb-3">Dữ liệu mới (New Value)</h4>
                            <div class="bg-slate-50 rounded-xl border border-slate-200 p-4 h-96 overflow-y-auto">
                                @if (!string.IsNullOrEmpty(Model.NewValue))
                                {
                                    <pre class="text-xs text-slate-700 whitespace-pre-wrap font-mono">@Model.NewValue</pre>
                                }
                                else
                                {
                                    <div class="h-full flex items-center justify-center">
                                        <span class="text-sm text-slate-400 italic">Không có dữ liệu</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

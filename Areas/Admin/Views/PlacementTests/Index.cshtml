@using DuAnTotNghiep.Models.DTOs.PlacementTest
@model DuAnTotNghiep.Models.DTOs.PagedResult<PlacementTestListItemDto>

@{
    ViewData["Title"] = "Quản lý Placement Test";
    var filter = ViewBag.Filter as PlacementTestFilterDto;
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Quản lý Đề thi đầu vào</h1>
        <p class="text-slate-500 text-sm mt-1">Danh sách các bài test đánh giá năng lực</p>
    </div>
    <a asp-action="Create" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo đề thi mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-4 p-4 text-green-700 bg-green-100 rounded-lg">
        @TempData["SuccessMessage"]
    </div>
}

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
    <div class="p-4 border-b border-slate-200 bg-slate-50">
        <form method="get" class="flex flex-wrap gap-4 items-end">
            <div class="w-full md:w-auto flex-1">
                <label class="block text-sm font-medium text-slate-700 mb-1">Tìm kiếm</label>
                <input type="text" name="Title" value="@filter?.Title" placeholder="Nhập tên đề thi..." class="w-full rounded-lg border-slate-300 focus:border-blue-500 focus:ring-blue-500 shadow-sm px-4 py-2 border">
            </div>
            
            <div class="w-full md:w-48">
                <label class="block text-sm font-medium text-slate-700 mb-1">Trạng thái</label>
                <select name="Status" class="w-full rounded-lg border-slate-300 focus:border-blue-500 focus:ring-blue-500 shadow-sm px-4 py-2 border">
                    <option value="">-- Tất cả --</option>
                    <option value="DRAFT" selected="@(filter?.Status == "DRAFT")">DRAFT</option>
                    <option value="PUBLISHED" selected="@(filter?.Status == "PUBLISHED")">PUBLISHED</option>
                    <option value="ARCHIVED" selected="@(filter?.Status == "ARCHIVED")">ARCHIVED</option>
                </select>
            </div>

            <div class="w-full md:w-48">
                <label class="block text-sm font-medium text-slate-700 mb-1">Target Level</label>
                <select name="TargetLevelId" asp-items="ViewBag.TargetLevels" class="w-full rounded-lg border-slate-300 focus:border-blue-500 focus:ring-blue-500 shadow-sm px-4 py-2 border">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>

            <div class="w-full md:w-auto">
                <button type="submit" class="w-full md:w-auto px-6 py-2 bg-slate-800 text-white font-medium rounded-lg hover:bg-slate-700 transition-colors">Lọc</button>
            </div>
        </form>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-600">
            <thead class="bg-slate-50 border-b border-slate-200 text-slate-700">
                <tr>
                    <th class="px-6 py-4 font-semibold">Tên đề thi</th>
                    <th class="px-6 py-4 font-semibold">Trình độ</th>
                    <th class="px-6 py-4 font-semibold text-center">T.Gian (p)</th>
                    <th class="px-6 py-4 font-semibold text-center">Tổng điểm</th>
                    <th class="px-6 py-4 font-semibold text-center">Trạng thái</th>
                    <th class="px-6 py-4 font-semibold text-center">Số Attempt</th>
                    <th class="px-6 py-4 font-semibold text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-medium text-slate-900">@item.Title</div>
                                <div class="text-xs text-slate-400 mt-1">Tạo ngày: @item.CreatedAt.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td class="px-6 py-4">
                                @if (item.TargetLevelName != null)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                                        @item.TargetLevelName
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center">@(item.TimeLimitMinutes?.ToString() ?? "N/A")</td>
                            <td class="px-6 py-4 text-center font-medium">@item.TotalScore</td>
                            <td class="px-6 py-4 text-center">
                                @if (item.Status == "DRAFT")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800">DRAFT</span>
                                }
                                else if (item.Status == "PUBLISHED")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">PUBLISHED</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">ARCHIVED</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="font-medium @(item.AttemptCount > 0 ? "text-blue-600" : "text-slate-400")">@item.AttemptCount</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="admin-icon-actions">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="admin-icon-btn admin-icon-view" title="Chi tiết đề thi" aria-label="Chi tiết đề thi">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="admin-icon-btn admin-icon-edit" title="Chỉnh sửa đề thi" aria-label="Chỉnh sửa đề thi">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-slate-500">
                            Không tìm thấy dữ liệu phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Paging -->
    @if (Model.TotalPages > 1)
    {
        <div class="p-4 border-t border-slate-200 flex items-center justify-between bg-slate-50">
            <span class="text-sm text-slate-500">Hiển thị trang @Model.PageIndex trên tổng @Model.TotalPages trang</span>
            <div class="flex gap-1">
                @if (Model.PageIndex > 1)
                {
                    <a href="?PageIndex=@(Model.PageIndex - 1)&Title=@(filter?.Title)&Status=@(filter?.Status)&TargetLevelId=@(filter?.TargetLevelId)" class="px-3 py-1 border border-slate-300 rounded text-slate-600 hover:bg-slate-100">Trước</a>
                }
                
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a href="?PageIndex=@(Model.PageIndex + 1)&Title=@(filter?.Title)&Status=@(filter?.Status)&TargetLevelId=@(filter?.TargetLevelId)" class="px-3 py-1 border border-slate-300 rounded text-slate-600 hover:bg-slate-100">Tiếp</a>
                }
            </div>
        </div>
    }
</div>

@model DuAnTotNghiep.Areas.Admin.ViewModels.AchievementFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa huy hiệu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="w-full max-w-3xl">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Chỉnh sửa huy hiệu</h2>
            <p class="text-sm text-slate-500 mt-1">Cập nhật thông tin cho huy hiệu trong hệ thống.</p>
        </div>
        <a asp-action="Index" class="flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors bg-slate-100 hover:bg-slate-200 px-4 py-2.5 rounded-xl">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại
        </a>
    </div>

    <form asp-action="Edit" method="post" class="bg-white rounded-2xl shadow-xs border border-slate-200 overflow-hidden">
        <input type="hidden" asp-for="Id" />
        <div class="p-6 sm:p-8 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Code -->
                <div>
                    <label asp-for="Code" class="block text-sm font-bold text-slate-700 mb-1.5"></label>
                    <input asp-for="Code" class="block w-full px-4 py-2.5 border border-slate-300 rounded-xl leading-5 bg-white focus:outline-hidden focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-all" placeholder="VD: FIRST_LOGIN" />
                    <span asp-validation-for="Code" class="text-xs text-red-500 mt-1.5 block"></span>
                </div>

                <!-- Title -->
                <div>
                    <label asp-for="Title" class="block text-sm font-bold text-slate-700 mb-1.5"></label>
                    <input asp-for="Title" class="block w-full px-4 py-2.5 border border-slate-300 rounded-xl leading-5 bg-white focus:outline-hidden focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-all" placeholder="VD: Đăng nhập lần đầu" />
                    <span asp-validation-for="Title" class="text-xs text-red-500 mt-1.5 block"></span>
                </div>
            </div>

            <!-- Description -->
            <div>
                <label asp-for="Description" class="block text-sm font-bold text-slate-700 mb-1.5"></label>
                <textarea asp-for="Description" rows="3" class="block w-full px-4 py-2.5 border border-slate-300 rounded-xl leading-5 bg-white focus:outline-hidden focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-all resize-none" placeholder="Mô tả chi tiết cách nhận huy hiệu này..."></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-500 mt-1.5 block"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- IconUrl -->
                <div>
                    <label asp-for="IconUrl" class="block text-sm font-bold text-slate-700 mb-1.5"></label>
                    <div class="flex gap-3">
                        <input asp-for="IconUrl" id="iconUrlInput" class="block w-full px-4 py-2.5 border border-slate-300 rounded-xl leading-5 bg-white focus:outline-hidden focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-all" placeholder="/images/badges/badge-1.png" />
                    </div>
                    <span asp-validation-for="IconUrl" class="text-xs text-red-500 mt-1.5 block"></span>
                </div>

                <!-- XpReward -->
                <div>
                    <label asp-for="XpReward" class="block text-sm font-bold text-slate-700 mb-1.5"></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-amber-500">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        </div>
                        <input asp-for="XpReward" type="number" class="block w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-xl leading-5 bg-white focus:outline-hidden focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-all" />
                    </div>
                    <span asp-validation-for="XpReward" class="text-xs text-red-500 mt-1.5 block"></span>
                </div>
            </div>

            <!-- IsActive -->
            <div class="flex items-center gap-3 pt-2">
                <div class="relative flex items-start">
                    <div class="flex items-center h-6">
                        <input asp-for="IsActive" type="checkbox" class="w-5 h-5 text-blue-600 border-slate-300 rounded-md focus:ring-blue-500 focus:ring-2 transition-all cursor-pointer">
                    </div>
                    <div class="ml-3 text-sm">
                        <label asp-for="IsActive" class="font-medium text-slate-700 cursor-pointer">Kích hoạt huy hiệu này ngay lập tức</label>
                        <p class="text-slate-500 text-xs mt-0.5">Nếu bỏ chọn, huy hiệu sẽ bị ẩn khỏi hệ thống.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Submit -->
        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-end gap-3">
            <button type="submit" class="flex justify-center items-center gap-2 px-6 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 focus:ring-4 focus:ring-blue-500/20 transition-all shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

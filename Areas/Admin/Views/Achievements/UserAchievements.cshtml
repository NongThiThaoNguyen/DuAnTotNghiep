@model DuAnTotNghiep.Areas.Admin.ViewModels.UserAchievementDetailViewModel
@{
    ViewData["Title"] = "Quản lý huy hiệu người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="w-full">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 mb-6 rounded-xl bg-emerald-50 text-emerald-800 border border-emerald-200 flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                <span class="font-medium text-sm">@TempData["SuccessMessage"]</span>
            </div>
        </div>
    }

    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Huy hiệu của học viên</h2>
            <p class="text-sm text-slate-500 mt-1">Quản lý và cấp phát huy hiệu cho tài khoản này.</p>
        </div>
        <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors bg-slate-100 hover:bg-slate-200 px-4 py-2.5 rounded-xl">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại chi tiết User
        </a>
    </div>

    <!-- User Info Card -->
    <div class="bg-white rounded-2xl shadow-xs border border-slate-200 p-6 mb-8 flex items-center gap-6">
        <img src="@Model.AvatarUrl" alt="@Model.FullName" class="w-16 h-16 rounded-full object-cover border border-slate-200" onerror="this.src='/images/default-avatar.png';" />
        <div>
            <h3 class="text-lg font-bold text-slate-800">@Model.FullName</h3>
            <p class="text-sm text-slate-500">@Model.Email</p>
        </div>
    </div>

    <!-- Achievements Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @foreach (var item in Model.Achievements)
        {
            <div class="bg-white rounded-2xl shadow-xs border @(item.IsUnlocked ? "border-amber-200 bg-amber-50/30" : "border-slate-200") overflow-hidden flex flex-col relative transition-all">
                @if (item.IsUnlocked)
                {
                    <div class="absolute top-3 right-3 bg-emerald-100 text-emerald-700 text-[10px] font-bold px-2 py-1 rounded-full border border-emerald-200 z-10 flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        SỞ HỮU
                    </div>
                }

                <div class="p-6 flex flex-col items-center text-center flex-1">
                    <div class="w-20 h-20 rounded-full flex items-center justify-center mb-4 @(item.IsUnlocked ? "bg-amber-100 border-2 border-amber-300" : "bg-slate-100 border border-slate-200 opacity-60")">
                        @if (!string.IsNullOrEmpty(item.IconUrl))
                        {
                            <img src="@item.IconUrl" alt="@item.Title" class="w-12 h-12 object-contain @(item.IsUnlocked ? "" : "grayscale")" onerror="this.src='/images/default-badge.png';" />
                        }
                        else
                        {
                            <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                        }
                    </div>
                    <h4 class="font-bold text-slate-800 text-lg mb-1 leading-tight">@item.Title</h4>
                    @if (item.IsUnlocked)
                    {
                        <p class="text-xs text-amber-600 font-medium mb-4">Đạt được: @item.UnlockedAtFormatted</p>
                    }
                    else
                    {
                        <p class="text-xs text-slate-400 font-medium mb-4">Chưa đạt được</p>
                    }
                </div>

                <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 mt-auto flex justify-center">
                    @if (item.IsUnlocked)
                    {
                        <form asp-action="Revoke" method="post" onsubmit="return confirm('Thu hồi huy hiệu này khỏi học viên?');" class="w-full">
                            <input type="hidden" name="userId" value="@Model.UserId" />
                            <input type="hidden" name="achievementId" value="@item.AchievementId" />
                            <button type="submit" class="w-full px-4 py-2 bg-white text-red-600 border border-red-200 text-sm font-semibold rounded-lg hover:bg-red-50 transition-colors">
                                Thu hồi huy hiệu
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Grant" method="post" class="w-full">
                            <input type="hidden" name="userId" value="@Model.UserId" />
                            <input type="hidden" name="achievementId" value="@item.AchievementId" />
                            <button type="submit" class="w-full px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors">
                                Trao tặng
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
</div>

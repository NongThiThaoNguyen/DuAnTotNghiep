@model List<DuAnTotNghiep.Models.DTOs.Topic.TopicTreeDto>
@{
    ViewData["Title"] = "Cây chủ đề học tập";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h2 class="mt-4">Cây chủ đề học tập</h2>

    <div class="mb-3">
        @if (User.IsInRole("ADMIN"))
        {
            <a asp-action="Create" class="btn btn-primary">Tạo chủ đề</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Xem danh sách</a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <ul class="space-y-3">
                    @foreach (var topic in Model)
                    {
                        @await Html.PartialAsync("_TopicTreeNode", topic)
                    }
                </ul>
            }
            else
            {
                <p>Chưa có chủ đề nào.</p>
            }
        </div>
    </div>
</div>

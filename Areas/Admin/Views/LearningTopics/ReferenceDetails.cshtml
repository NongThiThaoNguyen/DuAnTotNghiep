@model DuAnTotNghiep.Models.ReferenceSource
@using DuAnTotNghiep.Helpers
@using DuAnTotNghiep.Enums
@{
    ViewData["Title"] = "Chi tiết nguồn tham khảo";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h2 class="mt-4">Chi tiết nguồn tham khảo</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mt-3">
                <div class="card-header bg-dark text-white">
                    <h4>@Model.SourceName</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Địa chỉ URL</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.SourceUrl))
                            {
                                <a href="@Model.SourceUrl" target="_blank">@Model.SourceUrl</a>
                            }
                            else
                            {
                                <span class="text-muted">Không có URL</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Loại nguồn tham khảo</dt>
                        <dd class="col-sm-8"><strong>@ReferenceHelper.GetSourceTypeLabel(Model.SourceType)</strong></dd>

                        <dt class="col-sm-4">Chính sách sử dụng</dt>
                        <dd class="col-sm-8">@ReferenceHelper.GetUsagePolicyLabel(Model.UsagePolicy)</dd>

                        <dt class="col-sm-4">Trạng thái phê duyệt</dt>
                        <dd class="col-sm-8">
                            <span class="badge @ReferenceHelper.GetReviewStatusBadgeClass(Model.Status)">
                                @ReferenceHelper.GetReviewStatusLabel(Model.Status)
                            </span>
                        </dd>

                        <dt class="col-sm-4">Trạng thái hoạt động</dt>
                        <dd class="col-sm-8">
                            @(Model.IsActive ? "Đang hoạt động (Active)" : "Ngừng hoạt động (Inactive)")
                        </dd>

                        <hr />

                        <dt class="col-sm-4">Giấy phép & Bản quyền</dt>
                        <dd class="col-sm-8" style="white-space: pre-wrap;">@(string.IsNullOrEmpty(Model.LicenseNote) ? "Không có ghi chú giấy phép." : Model.LicenseNote)</dd>

                        <hr />

                        <dt class="col-sm-4">Người tạo nguồn</dt>
                        <dd class="col-sm-8">@(Model.CreatedByNavigation?.FullName ?? "Hệ thống") (@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</dd>

                        @if (Model.ApprovedBy.HasValue)
                        {
                            <dt class="col-sm-4">Người phê duyệt</dt>
                            <dd class="col-sm-8">
                                @(Model.ApprovedByNavigation?.FullName ?? "Admin") 
                                @(Model.ApprovedAt.HasValue ? " lúc " + Model.ApprovedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "")
                            </dd>
                        }
                    </dl>
                </div>
                <div class="card-footer">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="EditReference" asp-route-id="@Model.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Chỉnh sửa</a>
                    }
                    <a asp-action="ReferenceSources" class="btn btn-secondary">Quay lại danh sách</a>
                </div>
            </div>

            <!-- Hiển thị các Topic đang liên kết -->
            <div class="card mt-4">
                <div class="card-header bg-light">
                    <h5>Các học phần (Topic) đang sử dụng nguồn này (@Model.TopicReferences.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Mã học phần</th>
                                <th>Tên học phần</th>
                                <th>Ghi chú liên kết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tr in Model.TopicReferences)
                            {
                                <tr>
                                    <td>@tr.Topic?.TopicCode</td>
                                    <td><a asp-action="Details" asp-route-id="@tr.TopicId">@tr.Topic?.Title</a></td>
                                    <td>@tr.Note</td>
                                </tr>
                            }
                            @if (!Model.TopicReferences.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted p-3">Nguồn tham khảo này chưa được liên kết với học phần nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Form kiểm duyệt dành cho Admin -->
        @if (User.IsInRole("Admin") && (Model.Status == ReferenceReviewStatus.PENDING || Model.Status == ReferenceReviewStatus.DRAFT))
        {
            <div class="col-md-4">
                <div class="card mt-3">
                    <div class="card-header bg-warning text-dark">
                        <h5><i class="fas fa-clipboard-check"></i> Kiểm duyệt nguồn tham khảo</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Với vai trò Quản trị viên, bạn có quyền Duyệt hoặc Từ chối nguồn tham khảo này.</p>
                        <form asp-action="ReviewReference" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            
                            <div class="mb-3">
                                <label class="form-label">Quyết định kiểm duyệt</label>
                                <select name="status" class="form-select" required>
                                    <option value="APPROVED">DUYỆT (Approved)</option>
                                    <option value="REJECTED">TỪ CHỐI (Rejected)</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Ghi chú kiểm duyệt</label>
                                <textarea name="note" class="form-control" rows="4" placeholder="Nhập lý do từ chối hoặc hướng dẫn sửa đổi..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-success w-100" onclick="return confirm('Xác nhận lưu quyết định kiểm duyệt?');">Lưu quyết định</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

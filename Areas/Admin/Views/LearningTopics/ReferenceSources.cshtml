@model IEnumerable<DuAnTotNghiep.Models.ReferenceSource>
@using DuAnTotNghiep.Helpers
@using DuAnTotNghiep.Enums
@{
    ViewData["Title"] = "Quản lý nguồn tham khảo";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h2 class="mt-4">Nguồn tham khảo hợp pháp</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" style="white-space: pre-line;">@TempData["ErrorMessage"]</div>
    }

    <!-- Filter Form -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" asp-action="ReferenceSources" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="keyword" class="form-control" placeholder="Tìm theo tên nguồn..." value="@ViewBag.Keyword" />
                </div>
                <div class="col-md-3">
                    <select name="sourceType" class="form-select" asp-items="ViewBag.SourceTypes">
                        <option value="">-- Tất cả loại nguồn --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select" asp-items="ViewBag.Statuses">
                        <option value="">-- Tất cả trạng thái --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100"><i class="fas fa-filter"></i> Lọc</button>
                </div>
            </form>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="mb-3">
            <a asp-action="CreateReference" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm nguồn mới</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại Topics</a>
        </div>
    }

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-bordered table-striped mb-0">
                <thead>
                    <tr>
                        <th>Tên nguồn tham khảo</th>
                        <th>Loại nguồn</th>
                        <th>Chính sách sử dụng</th>
                        <th>Trạng thái</th>
                        <th>Hoạt động</th>
                        <th>Tạo lúc</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.SourceName</strong>
                                @if (!string.IsNullOrEmpty(item.SourceUrl))
                                {
                                    <br />
                                    <small><a href="@item.SourceUrl" target="_blank" class="text-truncate d-inline-block" style="max-width: 250px;">@item.SourceUrl</a></small>
                                }
                            </td>
                            <td>@ReferenceHelper.GetSourceTypeLabel(item.SourceType)</td>
                            <td>@ReferenceHelper.GetUsagePolicyLabel(item.UsagePolicy)</td>
                            <td>
                                <span class="badge @ReferenceHelper.GetReviewStatusBadgeClass(item.Status)">
                                    @ReferenceHelper.GetReviewStatusLabel(item.Status)
                                </span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="text-success"><i class="fas fa-check-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="fas fa-times-circle"></i> Inactive</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="ReferenceDetails" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Chi tiết"><i class="fas fa-info-circle"></i></a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="EditReference" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                        @if (item.Status != ReferenceReviewStatus.ARCHIVED)
                                        {
                                            <form asp-action="ArchiveReference" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn Lưu trữ (Archive) nguồn tham khảo này?\nHành động này cũng sẽ tắt trạng thái hoạt động.');">
                                                <button type="submit" class="btn btn-sm btn-dark" title="Lưu trữ"><i class="fas fa-archive"></i></button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted p-4">Không tìm thấy nguồn tham khảo nào phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

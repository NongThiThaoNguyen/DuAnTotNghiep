@model DuAnTotNghiep.Models.DTOs.Topic.TopicDetailDto
@using DuAnTotNghiep.Models
@{
    ViewData["Title"] = "Chi tiết chủ đề học tập";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var statusCode = (Model.Status ?? string.Empty).ToUpperInvariant();
    string StatusLabel(string? status) => (status ?? string.Empty).ToUpperInvariant() switch
    {
        "ACTIVE" => "Đang hoạt động",
        "INACTIVE" => "Tạm dừng",
        "ARCHIVED" => "Lưu trữ",
        _ => status ?? "-"
    };
    string StatusClass(string? status) => (status ?? string.Empty).ToUpperInvariant() switch
    {
        "ACTIVE" => "bg-emerald-100 text-emerald-800 border-emerald-200",
        "INACTIVE" => "bg-amber-100 text-amber-800 border-amber-200",
        "ARCHIVED" => "bg-slate-100 text-slate-700 border-slate-200",
        _ => "bg-blue-100 text-blue-800 border-blue-200"
    };
    var availableSources = (ViewBag.AvailableSources as IEnumerable<ReferenceSource>)?.ToList() ?? new List<ReferenceSource>();
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Chi tiết chủ đề học tập</h1>
            <p class="mt-1 text-sm text-slate-500">@Model.Name (@Model.TopicCode)</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            @if (User.IsInRole("ADMIN"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Chỉnh sửa</a>
            }
        </div>
    </div>

    @if (statusCode == "INACTIVE")
    {
        <div class="alert alert-warning">Chủ đề này đang tạm dừng, học viên sẽ không thấy nội dung mới từ chủ đề này.</div>
    }
    @if (!Model.CanArchive && !string.IsNullOrWhiteSpace(Model.Reason))
    {
        <div class="alert alert-danger">Không thể khóa/lưu trữ: @Model.Reason</div>
    }

    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-5 py-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-lg font-bold text-slate-900">@Model.Name</h2>
                    <p class="mt-1 text-sm text-slate-500">Mã chủ đề: @Model.TopicCode</p>
                </div>
                <span class="inline-flex items-center rounded-md border px-2.5 py-1 text-xs font-bold @StatusClass(Model.Status)">
                    @StatusLabel(Model.Status)
                </span>
            </div>
        </div>
        <dl class="grid gap-0 sm:grid-cols-2 lg:grid-cols-4">
            <div class="border-b border-slate-100 px-5 py-4 lg:border-r">
                <dt class="text-xs font-bold uppercase text-slate-500">Kỹ năng</dt>
                <dd class="mt-1 font-semibold text-slate-900">@Model.SkillName</dd>
            </div>
            <div class="border-b border-slate-100 px-5 py-4 lg:border-r">
                <dt class="text-xs font-bold uppercase text-slate-500">Trình độ</dt>
                <dd class="mt-1 font-semibold text-slate-900">@Model.LevelName</dd>
            </div>
            <div class="border-b border-slate-100 px-5 py-4 lg:border-r">
                <dt class="text-xs font-bold uppercase text-slate-500">Độ khó</dt>
                <dd class="mt-1 font-semibold text-slate-900">@Model.DifficultyLevel</dd>
            </div>
            <div class="border-b border-slate-100 px-5 py-4">
                <dt class="text-xs font-bold uppercase text-slate-500">Chủ đề cha</dt>
                <dd class="mt-1 font-semibold text-slate-900">@(string.IsNullOrWhiteSpace(Model.ParentTopicName) ? "-" : Model.ParentTopicName)</dd>
            </div>
            <div class="px-5 py-4 sm:col-span-2 lg:col-span-4">
                <dt class="text-xs font-bold uppercase text-slate-500">Mô tả</dt>
                <dd class="mt-1 text-sm text-slate-700 whitespace-pre-line">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả." : Model.Description)</dd>
            </div>
        </dl>
    </section>

    <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold uppercase text-slate-500">Mục tiêu</p>
            <p class="mt-2 text-2xl font-bold text-slate-900">@Model.ObjectiveCount</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold uppercase text-slate-500">Bài học</p>
            <p class="mt-2 text-2xl font-bold text-slate-900">@Model.LessonCount</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold uppercase text-slate-500">Quiz</p>
            <p class="mt-2 text-2xl font-bold text-slate-900">@Model.QuizCount</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold uppercase text-slate-500">Lộ trình</p>
            <p class="mt-2 text-2xl font-bold text-slate-900">@Model.PathCount</p>
        </div>
    </section>

    <div class="grid gap-6 lg:grid-cols-3">
        <section class="lg:col-span-2 space-y-6">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="text-base font-bold text-slate-900">Điều kiện tiên quyết</h2>
                <div class="mt-4">
                    @await Html.PartialAsync("_PrerequisitesPartial", Model.Prerequisites)
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="text-base font-bold text-slate-900">Mục tiêu học tập</h2>
                <div class="mt-4">
                    @await Html.PartialAsync("_ObjectivesPartial", Model.Objectives)
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-base font-bold text-slate-900">Nguồn tham khảo liên kết (@(Model.References?.Count() ?? 0))</h2>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Tên nguồn</th>
                                <th>Loại</th>
                                <th>Bản quyền</th>
                                <th>Ghi chú</th>
                                @if (User.IsInRole("ADMIN") || User.IsInRole("TEACHER"))
                                {
                                    <th class="text-right">Thao tác</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.References != null && Model.References.Any())
                            {
                                foreach (var r in Model.References)
                                {
                                    <tr>
                                        <td>
                                            <div class="font-semibold text-slate-900">@r.SourceName</div>
                                            @if (!r.IsValid)
                                            {
                                                <span class="mt-1 inline-flex rounded-md bg-red-50 px-2 py-0.5 text-xs font-bold text-red-700">@r.SourceStatus</span>
                                            }
                                            else if (r.ValidationLevel == "WARNING")
                                            {
                                                <span class="mt-1 inline-flex rounded-md bg-amber-50 px-2 py-0.5 text-xs font-bold text-amber-700">Chờ duyệt</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(r.SourceUrl))
                                            {
                                                <div class="mt-1 text-xs"><a href="@r.SourceUrl" target="_blank" class="text-blue-600 break-all">@r.SourceUrl</a></div>
                                            }
                                        </td>
                                        <td>@r.SourceType</td>
                                        <td>@r.LicenseNote</td>
                                        <td>@r.Note</td>
                                        @if (User.IsInRole("ADMIN") || User.IsInRole("TEACHER"))
                                        {
                                            <td class="text-right">
                                                <form asp-action="UnlinkSource" asp-controller="LearningTopics" asp-area="Admin" asp-route-topicId="@Model.Id" method="post" class="admin-icon-form" onsubmit="return confirm('Bạn có chắc chắn muốn hủy liên kết nguồn tham khảo này?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="sourceId" value="@r.ReferenceSourceId" />
                                                    <button type="submit" class="admin-icon-btn admin-icon-delete" title="Hủy liên kết" aria-label="Hủy liên kết">
                                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                    </button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(User.IsInRole("ADMIN") || User.IsInRole("TEACHER") ? 5 : 4)" class="text-center text-muted p-4">Chưa có nguồn tham khảo nào liên kết.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.Lessons.Any())
            {
                <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-4"><h2 class="text-base font-bold text-slate-900">Bài học liên quan (@Model.LessonCount)</h2></div>
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead><tr><th>Tiêu đề</th><th>Loại nội dung</th><th>Thời lượng</th><th>Review</th><th>AI</th></tr></thead>
                            <tbody>
                                @foreach (var l in Model.Lessons)
                                {
                                    <tr><td>@l.Title</td><td>@l.ContentType</td><td>@(l.EstimatedMinutes?.ToString() ?? "-") phút</td><td>@l.ReviewStatus</td><td>@(l.IsAiGenerated ? "Có" : "Không")</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (Model.Quizzes.Any())
            {
                <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-4"><h2 class="text-base font-bold text-slate-900">Quiz liên quan (@Model.QuizCount)</h2></div>
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead><tr><th>Tiêu đề</th><th>Loại</th><th>Thời gian</th><th>Điểm đạt</th><th>Trạng thái</th></tr></thead>
                            <tbody>
                                @foreach (var q in Model.Quizzes)
                                {
                                    <tr><td>@q.Title</td><td>@q.QuizType</td><td>@(q.TimeLimitMinutes?.ToString() ?? "-") phút</td><td>@(q.PassingScore?.ToString() ?? "-")</td><td>@q.Status</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (Model.LearningPaths.Any())
            {
                <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-4"><h2 class="text-base font-bold text-slate-900">Lộ trình liên quan (@Model.PathCount)</h2></div>
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead><tr><th>Tiêu đề</th><th>Học viên</th><th>Mô tả</th><th>Trạng thái</th></tr></thead>
                            <tbody>
                                @foreach (var p in Model.LearningPaths)
                                {
                                    <tr><td>@p.Title</td><td>@p.StudentName</td><td>@p.Description</td><td>@p.Status</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </section>

        <aside class="space-y-6">
            @if (User.IsInRole("ADMIN") || User.IsInRole("TEACHER"))
            {
                <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Liên kết nguồn tham khảo</h2>
                    @if (availableSources.Any())
                    {
                        <form asp-action="LinkSource" asp-controller="LearningTopics" asp-area="Admin" asp-route-topicId="@Model.Id" method="post" class="mt-4 space-y-3">
                            @Html.AntiForgeryToken()
                            <div>
                                <label class="form-label">Nguồn đã phê duyệt</label>
                                <select name="sourceId" class="form-select" required>
                                    <option value="">-- Chọn nguồn tham khảo --</option>
                                    @foreach (var source in availableSources)
                                    {
                                        <option value="@source.Id">@source.SourceName (@(source.SourceUrl ?? "Không có URL"))</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Ghi chú liên kết</label>
                                <textarea name="note" class="form-control" rows="3" placeholder="Ví dụ: Đọc chương 1, bài 2..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Thêm nguồn liên kết</button>
                        </form>
                    }
                    else
                    {
                        <p class="mt-4 text-sm text-slate-500">Không có nguồn tham khảo đã phê duyệt khả dụng để liên kết.</p>
                    }
                </section>
            }

            @if (User.IsInRole("ADMIN"))
            {
                <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Thao tác quản trị</h2>
                    <div class="mt-4 space-y-3">
                        @if (statusCode != "ARCHIVED")
                        {
                            <form asp-action="Archive" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn lưu trữ chủ đề này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="admin-action-primary admin-action-lock" @(Model.CanArchive ? "" : "disabled")>Lưu trữ chủ đề</button>
                            </form>
                        }
                        @if (statusCode == "ACTIVE")
                        {
                            <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn tạm dừng chủ đề này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="admin-action-primary admin-action-reset" @(Model.CanDeactivate ? "" : "disabled")>Tạm dừng chủ đề</button>
                            </form>
                        }
                        @if (statusCode == "ARCHIVED" || statusCode == "INACTIVE")
                        {
                            <form asp-action="Restore" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn khôi phục chủ đề này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="admin-action-primary admin-action-unlock">Khôi phục chủ đề</button>
                            </form>
                        }
                    </div>
                </section>
            }
        </aside>
    </div>
</div>

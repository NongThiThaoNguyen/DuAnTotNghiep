@model DuAnTotNghiep.Models.DTOs.Topic.TopicTreeDto

<li class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <div class="font-bold text-slate-900">@Model.Name</div>
            <div class="mt-2 flex flex-wrap gap-2">
                <span class="inline-flex rounded-md bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-700">@Model.DifficultyLevel</span>
                <span class="inline-flex rounded-md bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700">Mã: @Model.TopicCode</span>
            </div>
        </div>
        <div class="admin-icon-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="admin-icon-btn admin-icon-view" title="Chi tiết chủ đề" aria-label="Chi tiết chủ đề">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
            </a>
            @if (User.IsInRole("ADMIN"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="admin-icon-btn admin-icon-edit" title="Chỉnh sửa chủ đề" aria-label="Chỉnh sửa chủ đề">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                </a>
            }
        </div>
    </div>

    @if (Model.Children != null && Model.Children.Any())
    {
        <ul class="mt-3 space-y-3 border-l border-slate-200 pl-4">
            @foreach (var child in Model.Children)
            {
                @await Html.PartialAsync("_TopicTreeNode", child)
            }
        </ul>
    }
</li>

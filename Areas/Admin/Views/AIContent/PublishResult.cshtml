@model DuAnTotNghiep.ViewModels.PublishResultViewModel
@{
    ViewData["Title"] = "Publish Result";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (Model.IsSuccess)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">✓ Publish Successful!</h4>
                    <p>@Model.Message</p>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Published Item Details</h5>
                        <dl class="row">
                            <dt class="col-sm-4">AI Content ID</dt>
                            <dd class="col-sm-8">@Model.AiContentId</dd>

                            <dt class="col-sm-4">Question ID</dt>
                            <dd class="col-sm-8">
                                @Model.PublishedQuestionId
                                @if (!string.IsNullOrEmpty(Model.ViewQuestionLink))
                                {
                                    <a href="@Model.ViewQuestionLink" class="btn btn-sm btn-outline-primary ms-2">View Question</a>
                                }
                            </dd>

                            @if (Model.CreatedQuizId.HasValue)
                            {
                                <dt class="col-sm-4">Draft Quiz Created</dt>
                                <dd class="col-sm-8">
                                    Quiz ID: @Model.CreatedQuizId
                                    <a href="/Admin/Quiz/Edit/@Model.CreatedQuizId" class="btn btn-sm btn-outline-info ms-2">Edit Quiz</a>
                                </dd>
                            }
                        </dl>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">✗ Publish Failed</h4>
                    <p>@Model.ErrorMessage</p>
                </div>
            }

            <div class="d-flex gap-2">
                <a href="/Admin/AIContent/Index" class="btn btn-secondary">Back to List</a>
                <a href="/Admin/AIContent/Details/@Model.AiContentId" class="btn btn-outline-secondary">View Content</a>
            </div>
        </div>
    </div>
</div>

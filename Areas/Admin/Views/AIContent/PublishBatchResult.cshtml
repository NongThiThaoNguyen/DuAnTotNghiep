@model DuAnTotNghiep.ViewModels.PublishBatchResultViewModel
@{
    ViewData["Title"] = "Batch Publish Result";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (Model.IsSuccess)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">✓ Batch Publish Successful!</h4>
                    <p>@Model.Message</p>
                </div>
            }
            else
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">⚠ Batch Publish Completed with Issues</h4>
                    <p>@Model.Message</p>
                    <p>@Model.ErrorMessage</p>
                </div>
            }

            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Batch Statistics</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Batch ID</dt>
                        <dd class="col-sm-8">@Model.BatchId</dd>

                        <dt class="col-sm-4">Successfully Published</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-success">@Model.PublishedCount item@(Model.PublishedCount != 1 ? "s" : "")</span>
                        </dd>

                        @if (Model.FailureCount > 0)
                        {
                            <dt class="col-sm-4">Failed</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-danger">@Model.FailureCount item@(Model.FailureCount != 1 ? "s" : "")</span>
                            </dd>
                        }

                        @if (Model.CreatedQuizId.HasValue)
                        {
                            <dt class="col-sm-4">Draft Quiz Created</dt>
                            <dd class="col-sm-8">
                                Quiz ID: @Model.CreatedQuizId
                                <a href="/Admin/Quiz/Edit/@Model.CreatedQuizId" class="btn btn-sm btn-outline-info ms-2">
                                    Edit Quiz (@Model.PublishedCount questions)
                                </a>
                            </dd>
                        }
                    </dl>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a href="/Admin/AIContent/Index" class="btn btn-secondary">Back to List</a>
                @if (Model.CreatedQuizId.HasValue)
                {
                    <a href="/Admin/Quiz/Edit/@Model.CreatedQuizId" class="btn btn-primary">Open New Quiz</a>
                }
            </div>
        </div>
    </div>
</div>

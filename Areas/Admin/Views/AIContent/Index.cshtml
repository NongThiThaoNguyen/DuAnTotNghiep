@model DuAnTotNghiep.DTOs.PagedResult<DuAnTotNghiep.ViewModels.AiContentListItemViewModel>
@{
    ViewData["Title"] = "AI Content Review";
}

<h2>AI Generated Content Review</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card mb-3">
    <div class="card-body">
        <h5>Pending by Type:</h5>
        @if (ViewBag.PendingByType != null)
        {
            @foreach (var kvp in ViewBag.PendingByType)
            {
                <span class="badge bg-warning">@kvp.Key: @kvp.Value</span>
            }
        }
    </div>
</div>

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <input type="text" name="contentTypeFilter" class="form-control" placeholder="Content Type" value="@ViewBag.ContentTypeFilter" />
        </div>
        <div class="col-md-3">
            <input type="number" name="topicIdFilter" class="form-control" placeholder="Topic ID" value="@ViewBag.TopicIdFilter" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<div class="card mb-3 bg-light">
    <div class="card-body">
        <h6>Bulk Actions</h6>
        <form method="post" asp-area="Admin" asp-controller="AIContent" asp-action="PublishBatch" class="d-inline">
            <div class="input-group">
                <input type="text" name="quizTitle" class="form-control" placeholder="Optional: Quiz title for batch" />
                <div class="input-group-append">
                    <label class="input-group-text">
                        <input type="checkbox" name="createQuizDraft" value="true" />
                        Create Quiz
                    </label>
                    <button type="submit" class="btn btn-outline-primary">📤 Publish All Approved</button>
                </div>
            </div>
        </form>
        <small class="d-block text-muted mt-2">
            Publishes all APPROVED items to Question Bank. Optionally creates a draft quiz with published items.
        </small>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Type</th>
            <th>Question Preview</th>
            <th>Requested By</th>
            <th>Topic</th>
            <th>Status</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @if (!Model.Items.Any())
    {
        <tr><td colspan="8">No pending items.</td></tr>
    }
    else
    {
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.ContentType</td>
                <td>@(item.QuestionPreview?.Substring(0, Math.Min(50, item.QuestionPreview?.Length ?? 0)) ?? "N/A")...</td>
                <td>@item.RequestedByName</td>
                <td>@item.TopicName</td>
                <td><span class="badge bg-warning">@item.ReviewStatus</span></td>
                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td><a class="btn btn-sm btn-info" asp-area="Admin" asp-controller="AIContent" asp-action="Details" asp-route-id="@item.Id">Review</a></td>
            </tr>
        }
    }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @if (Model.PageIndex > 1)
        {
            <li class="page-item"><a class="page-link" asp-area="Admin" asp-controller="AIContent" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">Previous</a></li>
        }
        @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-area="Admin" asp-controller="AIContent" asp-action="Index" asp-route-page="@i">@i</a>
            </li>
        }
        @if (Model.PageIndex < Model.TotalPages)
        {
            <li class="page-item"><a class="page-link" asp-area="Admin" asp-controller="AIContent" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">Next</a></li>
        }
    </ul>
</nav>

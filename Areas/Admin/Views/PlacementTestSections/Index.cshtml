@model List<DuAnTotNghiep.DTOs.PlacementTestSection.PlacementTestSectionDto>

@{
    var test = ViewBag.Test as DuAnTotNghiep.DTOs.PlacementTest.PlacementTestDetailDto;
    ViewData["Title"] = $"Quản lý cấu trúc bài thi: {test?.Title}";
    bool canEdit = test?.Status != "ARCHIVED";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Cấu trúc bài thi (Sections)</h1>
        <p class="text-slate-500 text-sm mt-1">@test?.Title</p>
    </div>
    
    <div class="flex items-center gap-3">
        <a asp-action="Details" asp-controller="PlacementTests" asp-route-id="@test?.Id" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 rounded-lg transition-colors">Trở về Chi tiết bài thi</a>
        
        @if (canEdit)
        {
            <a asp-action="Create" asp-route-placementTestId="@test?.Id" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg shadow-sm transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Thêm Section Mới
            </a>
        }
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-6 p-4 border-l-4 border-red-500 bg-red-50 text-red-800 rounded-r-lg">
        <p class="text-sm">@TempData["ErrorMessage"]</p>
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-6 p-4 text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-lg">
        @TempData["SuccessMessage"]
    </div>
}

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-4 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
        <span class="text-sm font-medium text-slate-700">Danh sách các phần thi (kéo thả để đổi thứ tự)</span>
        @if (canEdit && Model.Count > 1)
        {
            <button id="saveOrderBtn" class="hidden px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-medium rounded-lg transition-colors">Lưu thứ tự mới</button>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="p-8 text-center text-slate-500">
            Bài thi này chưa có Section nào. Hãy thêm Section đầu tiên!
        </div>
    }
    else
    {
        <ul id="sortableSections" class="divide-y divide-slate-100">
            @foreach (var sec in Model)
            {
                <li class="p-4 flex items-center justify-between hover:bg-slate-50 transition-colors group" data-id="@sec.Id">
                    <div class="flex items-center gap-4">
                        @if (canEdit)
                        {
                            <div class="text-slate-300 cursor-move hover:text-slate-500 drag-handle">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                            </div>
                        }
                        
                        <div class="flex flex-col">
                            <span class="font-bold text-slate-800 flex items-center gap-2">
                                Part <span class="order-number">@sec.OrderIndex</span>: @sec.SectionName
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">@sec.SkillName</span>
                            </span>
                            @if (!string.IsNullOrEmpty(sec.Instruction))
                            {
                                <span class="text-sm text-slate-500 mt-1 line-clamp-1">@sec.Instruction</span>
                            }
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-6">
                        <div class="text-right hidden sm:block">
                            <div class="text-xs text-slate-400">Điểm phần thi</div>
                            <div class="font-medium text-slate-900">@sec.MaxScore đ</div>
                        </div>
                        <div class="text-right hidden sm:block">
                            <div class="text-xs text-slate-400">Số câu hỏi</div>
                            <div class="font-medium text-slate-900">@sec.QuestionCount câu</div>
                        </div>

                        <div class="flex items-center gap-2">
                            @if (canEdit)
                            {
                                <a asp-action="Edit" asp-route-placementTestId="@test.Id" asp-route-id="@sec.Id" class="p-2 text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-colors" title="Sửa">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </a>
                                <form asp-action="Delete" asp-route-placementTestId="@test.Id" asp-route-id="@sec.Id" method="post" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa Section này? Hành động không thể hoàn tác nếu chưa có người thi.')">
                                    <button type="submit" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Xóa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var el = document.getElementById('sortableSections');
            if (el) {
                var sortable = Sortable.create(el, {
                    handle: '.drag-handle',
                    animation: 150,
                    onEnd: function () {
                        // Cập nhật lại số thứ tự hiển thị
                        var items = el.querySelectorAll('li');
                        var isChanged = false;
                        items.forEach(function(item, index) {
                            var numberSpan = item.querySelector('.order-number');
                            if(numberSpan.innerText != index + 1) {
                                isChanged = true;
                                numberSpan.innerText = index + 1;
                            }
                        });
                        
                        if (isChanged) {
                            document.getElementById('saveOrderBtn').classList.remove('hidden');
                        }
                    }
                });

                document.getElementById('saveOrderBtn').addEventListener('click', function() {
                    var items = el.querySelectorAll('li');
                    var orderData = [];
                    items.forEach(function(item, index) {
                        orderData.push({
                            SectionId: parseInt(item.getAttribute('data-id')),
                            OrderIndex: index + 1
                        });
                    });

                    fetch('@Url.Action("Reorder", new { placementTestId = test?.Id })', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(orderData)
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            document.getElementById('saveOrderBtn').classList.add('hidden');
                        } else {
                            alert('Lỗi: ' + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Đã xảy ra lỗi khi lưu thứ tự.');
                    });
                });
            }
        });
    </script>
}

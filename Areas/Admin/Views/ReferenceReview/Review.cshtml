@model DuAnTotNghiep.Models.ViewModels.Admin.ReferenceSources.ReferenceSourceDetailsViewModel
@{
    ViewData["Title"] = "Đánh giá nguồn tham khảo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Đánh giá nguồn tham khảo</h1>
            <p class="mt-1 text-sm text-slate-500">Kiểm tra pháp lý, URL và ghi chú trước khi phê duyệt nguồn.</p>
        </div>
        <a asp-action="Pending" asp-controller="ReferenceReview" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">
            Quay lại danh sách
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="grid gap-6 lg:grid-cols-3">
        <section class="lg:col-span-2 rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 class="text-lg font-bold text-slate-900">@Model.SourceName</h2>
                <span class="mt-2 inline-flex rounded-md border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700">@Model.Status</span>
            </div>
            <dl class="divide-y divide-slate-100">
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Địa chỉ URL</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">
                        @if (!string.IsNullOrWhiteSpace(Model.SourceUrl))
                        {
                            <a href="@Model.SourceUrl" target="_blank" class="font-semibold text-blue-600 hover:text-blue-700 break-all">@Model.SourceUrl</a>
                        }
                        else
                        {
                            <span>Không có địa chỉ liên kết URL</span>
                        }
                    </dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Loại nguồn</dt>
                    <dd class="text-sm font-semibold text-slate-900 sm:col-span-2">@Model.SourceType</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Chính sách sử dụng</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(Model.UsagePolicy?.ToString() ?? "Chưa thiết lập")</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Bản quyền</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.LicenseNote) ? "Chưa có ghi chú" : Model.LicenseNote)</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Tác giả</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.Author) ? "-" : Model.Author)</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Tổ chức / Nhà xuất bản</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2">@(string.IsNullOrWhiteSpace(Model.Organization) ? "-" : Model.Organization)</dd>
                </div>
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4">
                    <dt class="text-sm font-bold text-slate-500">Mô tả</dt>
                    <dd class="text-sm text-slate-800 sm:col-span-2 whitespace-pre-line">@(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả chi tiết." : Model.Description)</dd>
                </div>
            </dl>
        </section>

        <aside class="space-y-6">
            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Người tạo</h2>
                <dl class="mt-4 space-y-4 text-sm">
                    <div>
                        <dt class="font-bold text-slate-500">Người đăng ký</dt>
                        <dd class="mt-1 font-semibold text-slate-900">@Model.CreatedByUserName</dd>
                    </div>
                    <div>
                        <dt class="font-bold text-slate-500">Thời gian gửi</dt>
                        <dd class="mt-1 font-semibold text-slate-900">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                    </div>
                </dl>
            </section>

            <section class="rounded-2xl border border-emerald-200 bg-white p-5 shadow-sm">
                <h2 class="text-sm font-bold uppercase tracking-wide text-emerald-700">Phê duyệt</h2>
                <form asp-action="Approve" asp-controller="ReferenceReview" method="post" class="mt-4 space-y-3" onsubmit="return confirm('Xác nhận phê duyệt nguồn tham khảo này?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div>
                        <label for="approveNote" class="form-label">Ghi chú kiểm duyệt</label>
                        <textarea id="approveNote" name="note" rows="3" class="form-control" placeholder="Nhập nhận xét hoặc lưu ý bản quyền nếu cần..."></textarea>
                    </div>
                    <button type="submit" class="admin-action-primary admin-action-unlock">Phê duyệt nguồn</button>
                </form>
            </section>

            <section class="rounded-2xl border border-red-200 bg-white p-5 shadow-sm">
                <h2 class="text-sm font-bold uppercase tracking-wide text-red-700">Từ chối</h2>
                <form asp-action="Reject" asp-controller="ReferenceReview" method="post" class="mt-4 space-y-3" onsubmit="return confirm('Xác nhận từ chối nguồn tham khảo này?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div>
                        <label for="rejectReason" class="form-label">Lý do từ chối</label>
                        <textarea id="rejectReason" name="reason" rows="3" class="form-control" placeholder="Ví dụ: thiếu giấy phép bản quyền hợp lệ, URL hỏng..." required></textarea>
                    </div>
                    <button type="submit" class="admin-action-primary admin-action-reset">Từ chối nguồn</button>
                </form>
            </section>
        </aside>
    </div>
</div>

@model DuAnTotNghiep.Areas.Admin.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan Dashboard";
    Layout = "_AdminLayout";
}

<div class="space-y-8 animate-fade-in">
    <!-- Header Page -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-slate-200 pb-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 font-sans">Tổng quan hệ thống</h1>
            <p class="text-sm text-slate-500 mt-1">Báo cáo phân tích và thống kê số liệu của hệ thống học tập AI Study English.</p>
        </div>
        <div class="flex items-center gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold bg-blue-50 text-blue-700 rounded-lg border border-blue-200">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
                Dữ liệu trực tuyến
            </span>
            <div class="text-sm text-slate-500 font-medium">
                Cập nhật lúc: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")
            </div>
        </div>
    </div>

    <!-- General Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1: Users -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs hover-lift flex flex-col justify-between">
            <div class="flex items-center justify-between">
                <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Tổng người dùng</span>
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
            </div>
            <div class="mt-4">
                <span class="text-3xl font-bold text-slate-900">@Model.TotalUsers.ToString("N0")</span>
                <div class="flex items-center gap-2 mt-1.5 text-xs">
                    <span class="text-slate-500 font-medium">Học sinh: <strong class="text-slate-700">@Model.TotalStudents</strong></span>
                    <span class="text-slate-300">|</span>
                    <span class="text-slate-500 font-medium">Giáo viên: <strong class="text-slate-700">@Model.TotalTeachers</strong></span>
                </div>
            </div>
        </div>

        <!-- Card 2: Courses & Lessons -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs hover-lift flex flex-col justify-between">
            <div class="flex items-center justify-between">
                <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Khóa học & Bài học</span>
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.232.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.232.477-4.5 1.253"></path>
                    </svg>
                </div>
            </div>
            <div class="mt-4">
                <span class="text-3xl font-bold text-slate-900">@Model.TotalCourses.ToString("N0")</span>
                <div class="flex items-center gap-2 mt-1.5 text-xs text-slate-500 font-medium">
                    <span>Tổng số bài học: <strong class="text-slate-700">@Model.TotalLessons</strong></span>
                </div>
            </div>
        </div>

        <!-- Card 3: Quizzes & Placements -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs hover-lift flex flex-col justify-between">
            <div class="flex items-center justify-between">
                <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Quiz & Thi đầu vào</span>
                <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                    </svg>
                </div>
            </div>
            <div class="mt-4">
                <span class="text-3xl font-bold text-slate-900">@Model.TotalQuizzes.ToString("N0")</span>
                <div class="flex items-center gap-2 mt-1.5 text-xs text-slate-500 font-medium">
                    <span>Tổng đề kiểm tra đầu vào: <strong class="text-slate-700">@Model.TotalPlacementTests</strong></span>
                </div>
            </div>
        </div>

        <!-- Card 4: AI Analytis & Recoms -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs hover-lift flex flex-col justify-between">
            <div class="flex items-center justify-between">
                <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Phân tích & Gợi ý AI</span>
                <div class="w-10 h-10 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                </div>
            </div>
            <div class="mt-4">
                <span class="text-3xl font-bold text-slate-900">@Model.TotalAiAnalyses.ToString("N0")</span>
                <div class="flex items-center gap-2 mt-1.5 text-xs text-slate-500 font-medium">
                    <span>Gợi ý học tập của AI: <strong class="text-slate-700">@Model.TotalAiRecommendations</strong></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Secondary Stats Grid (Remaining 4 counters) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Learning Paths -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-sky-50 flex items-center justify-center text-sky-600 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                </svg>
            </div>
            <div>
                <span class="text-xs text-slate-400 font-semibold uppercase tracking-wider block">Lộ trình học tập</span>
                <span class="text-xl font-bold text-slate-800">@Model.TotalLearningPaths.ToString("N0")</span>
            </div>
        </div>

        <!-- Question Bank -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4H6a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-2m-4-1v8m0 0l3-3m-3 3L9 8m-5 5h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h3.172a1 1 0 00.707-.293l2.414-2.414a1 1 0 01.707-.293H20"></path>
                </svg>
            </div>
            <div>
                <span class="text-xs text-slate-400 font-semibold uppercase tracking-wider block">Ngân hàng câu hỏi</span>
                <span class="text-xl font-bold text-slate-800">@Model.TotalQuestionBank.ToString("N0")</span>
            </div>
        </div>

        <!-- Reference Sources -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center text-purple-600 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                </svg>
            </div>
            <div>
                <span class="text-xs text-slate-400 font-semibold uppercase tracking-wider block">Nguồn tài liệu</span>
                <span class="text-xl font-bold text-slate-800">@Model.TotalReferenceSources.ToString("N0")</span>
            </div>
        </div>

        <!-- Other Indicator -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center text-rose-600 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                </svg>
            </div>
            <div>
                <span class="text-xs text-slate-400 font-semibold uppercase tracking-wider block">Mức độ tương tác</span>
                <span class="text-xl font-bold text-slate-800">Hiệu quả</span>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Chart 1: Người dùng theo thời gian -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Người dùng theo thời gian</h3>
            <div class="relative h-72">
                @if (Model.UsersOverTime.Any())
                {
                    <canvas id="usersOverTimeChart"></canvas>
                }
                else
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-12 h-12 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                        </svg>
                        <span class="text-sm font-medium">Chưa có dữ liệu người dùng</span>
                    </div>
                }
            </div>
        </div>

        <!-- Chart 2: Placement Test theo thời gian -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Placement Test theo thời gian</h3>
            <div class="relative h-72">
                @if (Model.PlacementTestsOverTime.Any())
                {
                    <canvas id="placementTestsChart"></canvas>
                }
                else
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-12 h-12 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                        </svg>
                        <span class="text-sm font-medium">Chưa có lượt thi thử nào</span>
                    </div>
                }
            </div>
        </div>

        <!-- Chart 3: Phân tích AI -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Trình độ đề xuất bởi AI</h3>
            <div class="relative h-72">
                @if (Model.AiAnalysisData.Any())
                {
                    <canvas id="aiAnalysisChart"></canvas>
                }
                else
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-12 h-12 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
                        </svg>
                        <span class="text-sm font-medium">Chưa có kết quả phân tích AI</span>
                    </div>
                }
            </div>
        </div>

        <!-- Chart 4: Tiến độ học tập trung bình -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Tiến độ học tập theo kỹ năng (%)</h3>
            <div class="relative h-72">
                @if (Model.LearningProgressData.Any())
                {
                    <canvas id="learningProgressChart"></canvas>
                }
                else
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-12 h-12 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                        </svg>
                        <span class="text-sm font-medium">Chưa có dữ liệu tiến độ của học sinh</span>
                    </div>
                }
            </div>
        </div>

        <!-- Chart 5: Phân bố vai trò -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Cơ cấu tài khoản hệ thống</h3>
            <div class="relative h-72 flex justify-center">
                @if (Model.RoleDistribution.Any())
                {
                    <div class="w-64 h-64">
                        <canvas id="roleDistributionChart"></canvas>
                    </div>
                }
                else
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-12 h-12 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        <span class="text-sm font-medium">Chưa có dữ liệu tài khoản</span>
                    </div>
                }
            </div>
        </div>

        <!-- Chart 6: Phân bố trình độ học viên -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Phân bố trình độ học viên</h3>
            <div class="relative h-72">
                @if (Model.LevelDistribution.Any())
                {
                    <canvas id="levelDistributionChart"></canvas>
                }
                else
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-12 h-12 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                        </svg>
                        <span class="text-sm font-medium">Chưa có dữ liệu trình độ của học sinh</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Lists Section (Recent / New Items) -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
        <!-- 1. Hoạt động gần đây -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <h3 class="text-lg font-bold text-slate-900">Hoạt động học tập gần đây</h3>
                <span class="text-xs font-semibold px-2.5 py-1 bg-slate-100 text-slate-600 rounded-md">Mới nhất</span>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.RecentActivities.Any())
                {
                    @foreach (var act in Model.RecentActivities)
                    {
                        <div class="py-3 flex items-start justify-between gap-4">
                            <div class="flex gap-3">
                                <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 font-bold text-xs shrink-0">
                                    @(string.IsNullOrEmpty(act.UserName) ? "?" : act.UserName.Substring(0, Math.Min(2, act.UserName.Length)).ToUpper())
                                </div>
                                <div>
                                    <span class="text-sm font-bold text-slate-800 block">@act.UserName</span>
                                    <span class="text-xs text-slate-500">
                                        @act.ActivityType: <strong class="text-slate-700">@act.Description</strong>
                                    </span>
                                </div>
                            </div>
                            <div class="text-right">
                                <span class="text-xs text-slate-400 block">@act.CreatedAt.ToString("HH:mm dd/MM")</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="py-8 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-10 h-10 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <span class="text-sm">Chưa ghi nhận hoạt động nào</span>
                    </div>
                }
            </div>
        </div>

        <!-- 2. Placement Test gần đây -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <h3 class="text-lg font-bold text-slate-900">Placement Test gần đây</h3>
                <span class="text-xs font-semibold px-2.5 py-1 bg-amber-50 text-amber-700 rounded-md">Thi thử</span>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.RecentPlacementTests.Any())
                {
                    @foreach (var test in Model.RecentPlacementTests)
                    {
                        <div class="py-3 flex items-start justify-between gap-4">
                            <div>
                                <span class="text-sm font-bold text-slate-800 block">@test.Student.FullName</span>
                                <span class="text-xs text-slate-500">
                                    Đề thi: <strong class="text-slate-700">@test.PlacementTest.Title</strong>
                                </span>
                            </div>
                            <div class="text-right">
                                <span class="text-xs text-slate-400 block">@test.StartedAt.ToString("dd/MM/yyyy")</span>
                                @if (test.TotalScore.HasValue)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-semibold bg-emerald-50 text-emerald-700 rounded-md">
                                        @test.TotalScore.Value.ToString("0.0")đ
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-semibold bg-slate-100 text-slate-600 rounded-md">
                                        @test.Status
                                    </span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="py-8 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-10 h-10 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                        <span class="text-sm">Chưa có bài thi đầu vào nào</span>
                    </div>
                }
            </div>
        </div>

        <!-- 3. AI Recommendation gần đây -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <h3 class="text-lg font-bold text-slate-900">Nhận xét & Gợi ý mới từ AI</h3>
                <span class="text-xs font-semibold px-2.5 py-1 bg-violet-50 text-violet-700 rounded-md">AI Generated</span>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.RecentAiRecommendations.Any())
                {
                    @foreach (var rec in Model.RecentAiRecommendations)
                    {
                        <div class="py-3 flex flex-col gap-1">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-bold text-slate-800">@rec.Student.FullName</span>
                                <span class="text-xs text-slate-400">@rec.CreatedAt.ToString("HH:mm dd/MM")</span>
                            </div>
                            <p class="text-xs text-slate-600 line-clamp-2 italic">"@rec.FeedbackText"</p>
                            @if (!string.IsNullOrEmpty(rec.RecommendedAction))
                            {
                                <span class="text-[11px] font-semibold text-violet-600 block mt-0.5">
                                    Hành động gợi ý: @rec.RecommendedAction
                                </span>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="py-8 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-10 h-10 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span class="text-sm">Chưa có gợi ý AI nào</span>
                    </div>
                }
            </div>
        </div>

        <!-- 4. Question Bank mới -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <h3 class="text-lg font-bold text-slate-900">Câu hỏi ngân hàng mới</h3>
                <span class="text-xs font-semibold px-2.5 py-1 bg-indigo-50 text-indigo-700 rounded-md">Học liệu</span>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.NewQuestionBankItems.Any())
                {
                    @foreach (var q in Model.NewQuestionBankItems)
                    {
                        <div class="py-3 flex items-start justify-between gap-4">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-slate-800 truncate">@q.QuestionText</p>
                                <span class="text-xs text-slate-400 block mt-0.5">
                                    Kỹ năng: <strong class="text-slate-600">@q.Skill.SkillName</strong> | Trình độ: <strong class="text-slate-600">@(q.Level?.Name ?? "N/A")</strong>
                                </span>
                            </div>
                            <div class="shrink-0 text-right">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-semibold bg-emerald-50 text-emerald-700 rounded-md">
                                    @q.ReviewStatus
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="py-8 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-10 h-10 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <span class="text-sm">Chưa có câu hỏi nào</span>
                    </div>
                }
            </div>
        </div>

        <!-- 5. Reference Source mới -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <h3 class="text-lg font-bold text-slate-900">Tài nguyên tham chiếu mới</h3>
                <span class="text-xs font-semibold px-2.5 py-1 bg-purple-50 text-purple-700 rounded-md">Tài liệu</span>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.NewReferenceSources.Any())
                {
                    @foreach (var src in Model.NewReferenceSources)
                    {
                        <div class="py-3 flex items-start justify-between gap-4">
                            <div class="flex-1 min-w-0">
                                <span class="text-sm font-bold text-slate-800 block truncate">@src.SourceName</span>
                                @if (!string.IsNullOrEmpty(src.SourceUrl))
                                {
                                    <a href="@src.SourceUrl" target="_blank" class="text-xs text-blue-600 hover:underline block mt-0.5 truncate">
                                        @src.SourceUrl
                                    </a>
                                }
                            </div>
                            <div class="text-right shrink-0">
                                <span class="text-xs text-slate-400 block">@src.SourceType</span>
                                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-semibold bg-emerald-50 text-emerald-700 rounded-md mt-1">
                                    @src.Status
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="py-8 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-10 h-10 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.232.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.232.477-4.5 1.253"></path>
                        </svg>
                        <span class="text-sm">Chưa có tài nguyên nào</span>
                    </div>
                }
            </div>
        </div>

        <!-- 6. Learning Path mới -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-xs">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <h3 class="text-lg font-bold text-slate-900">Lộ trình học tập mới tạo</h3>
                <span class="text-xs font-semibold px-2.5 py-1 bg-sky-50 text-sky-700 rounded-md">Lộ trình</span>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.NewLearningPaths.Any())
                {
                    @foreach (var path in Model.NewLearningPaths)
                    {
                        <div class="py-3 flex items-start justify-between gap-4">
                            <div>
                                <span class="text-sm font-bold text-slate-800 block">@path.Title</span>
                                <span class="text-xs text-slate-400">
                                    Học sinh: <strong class="text-slate-600">@path.Student.FullName</strong>
                                </span>
                            </div>
                            <div class="text-right shrink-0">
                                <span class="text-xs text-slate-400 block">@path.CreatedAt.ToString("dd/MM/yyyy")</span>
                                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-semibold bg-emerald-50 text-emerald-700 rounded-md mt-1">
                                    @path.Status
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="py-8 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-10 h-10 stroke-current mb-2" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                        </svg>
                        <span class="text-sm">Chưa có lộ trình học tập nào</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- CDN Chart.js to render clean interactive charts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Colors configuration from modern blue palette
            const primaryBlue = '#2563EB';
            const lightBlue = '#DBEAFE';
            const hoverBlue = '#1D4ED8';
            const borderGray = '#E2E8F0';
            const textPrimary = '#0F172A';
            const textSecondary = '#64748B';

            const successColor = '#22C55E';
            const warningColor = '#F59E0B';
            const dangerColor = '#EF4444';
            const violetColor = '#8B5CF6';

            // 1. Chart Users Over Time
            const usersCtx = document.getElementById('usersOverTimeChart');
            if (usersCtx) {
                const data = @Html.Raw(Json.Serialize(Model.UsersOverTime));
                new Chart(usersCtx, {
                    type: 'line',
                    data: {
                        labels: data.map(x => x.label),
                        datasets: [{
                            label: 'Người dùng mới',
                            data: data.map(x => x.value),
                            borderColor: primaryBlue,
                            backgroundColor: 'rgba(37, 99, 235, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { grid: { color: borderGray }, ticks: { color: textSecondary } },
                            x: { grid: { display: false }, ticks: { color: textSecondary } }
                        }
                    }
                });
            }

            // 2. Chart Placement Tests attempts over time
            const testsCtx = document.getElementById('placementTestsChart');
            if (testsCtx) {
                const data = @Html.Raw(Json.Serialize(Model.PlacementTestsOverTime));
                new Chart(testsCtx, {
                    type: 'line',
                    data: {
                        labels: data.map(x => x.label),
                        datasets: [{
                            label: 'Lượt kiểm tra',
                            data: data.map(x => x.value),
                            borderColor: '#F59E0B',
                            backgroundColor: 'rgba(245, 158, 11, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { grid: { color: borderGray }, ticks: { color: textSecondary } },
                            x: { grid: { display: false }, ticks: { color: textSecondary } }
                        }
                    }
                });
            }

            // 3. Chart AI Analysis levels
            const aiCtx = document.getElementById('aiAnalysisChart');
            if (aiCtx) {
                const data = @Html.Raw(Json.Serialize(Model.AiAnalysisData));
                new Chart(aiCtx, {
                    type: 'bar',
                    data: {
                        labels: data.map(x => x.label),
                        datasets: [{
                            data: data.map(x => x.value),
                            backgroundColor: violetColor,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { grid: { color: borderGray }, ticks: { color: textSecondary } },
                            x: { grid: { display: false }, ticks: { color: textSecondary } }
                        }
                    }
                });
            }

            // 4. Chart Learning Progress
            const progressCtx = document.getElementById('learningProgressChart');
            if (progressCtx) {
                const data = @Html.Raw(Json.Serialize(Model.LearningProgressData));
                new Chart(progressCtx, {
                    type: 'bar',
                    data: {
                        labels: data.map(x => x.label),
                        datasets: [{
                            data: data.map(x => x.value),
                            backgroundColor: successColor,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { max: 100, grid: { color: borderGray }, ticks: { color: textSecondary } },
                            x: { grid: { display: false }, ticks: { color: textSecondary } }
                        }
                    }
                });
            }

            // 5. Chart Role Distribution
            const roleCtx = document.getElementById('roleDistributionChart');
            if (roleCtx) {
                const data = @Html.Raw(Json.Serialize(Model.RoleDistribution));
                new Chart(roleCtx, {
                    type: 'doughnut',
                    data: {
                        labels: data.map(x => x.label),
                        datasets: [{
                            data: data.map(x => x.value),
                            backgroundColor: [primaryBlue, successColor, warningColor, dangerColor]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: textSecondary }
                            }
                        }
                    }
                });
            }

            // 6. Chart Level Distribution
            const levelCtx = document.getElementById('levelDistributionChart');
            if (levelCtx) {
                const data = @Html.Raw(Json.Serialize(Model.LevelDistribution));
                new Chart(levelCtx, {
                    type: 'bar',
                    data: {
                        labels: data.map(x => x.label),
                        datasets: [{
                            data: data.map(x => x.value),
                            backgroundColor: '#0EA5E9',
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { grid: { color: borderGray }, ticks: { color: textSecondary } },
                            x: { grid: { display: false }, ticks: { color: textSecondary } }
                        }
                    }
                });
            }
        });
    </script>
}

@model DuAnTotNghiep.Models.ViewModels.Admin.LearningPaths.PathHistoryViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Lịch sử lộ trình";
}

<div class="space-y-6">
    <header class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6" data-legacy-title="Path History">
        <p class="text-xs font-bold uppercase text-blue-600 mb-2">AI Learning Path</p>
        <h1 class="text-2xl font-bold text-slate-900">Lịch sử lộ trình</h1>
        <p class="text-sm text-slate-500 mt-2">Theo dõi tất cả lộ trình đã tạo, trạng thái và người học liên quan.</p>
    </header>

    <section class="bg-white border border-slate-200 rounded-2xl shadow-sm p-4">
        <form method="get" asp-action="PathHistory" class="flex flex-col gap-3 sm:flex-row sm:items-end">
            <div class="flex-1">
                <label for="status" class="block text-sm font-semibold text-slate-700 mb-1">Trạng thái</label>
                <select id="status" name="status" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm">
                    <option value="">Tất cả</option>
                    <option value="ACTIVE" selected="@(Model.Status == "ACTIVE" ? "selected" : null)">ACTIVE</option>
                    <option value="ARCHIVED" selected="@(Model.Status == "ARCHIVED" ? "selected" : null)">ARCHIVED</option>
                    <option value="FAILED" selected="@(Model.Status == "FAILED" ? "selected" : null)">FAILED</option>
                </select>
            </div>
            <button type="submit" class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-700">Lọc</button>
        </form>
    </section>

    <section class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-left text-xs font-bold uppercase text-slate-500">
                    <tr>
                        <th class="px-4 py-3">Lộ trình</th>
                        <th class="px-4 py-3">Học viên</th>
                        <th class="px-4 py-3">Trạng thái</th>
                        <th class="px-4 py-3">AI</th>
                        <th class="px-4 py-3">Ngày tạo</th>
                        <th class="px-4 py-3 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Paths)
                    {
                        <tr>
                            <td class="px-4 py-3 font-semibold text-slate-900">@item.Title</td>
                            <td class="px-4 py-3 text-slate-600">@item.StudentName</td>
                            <td class="px-4 py-3">
                                <span class="rounded-full bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700">@item.Status</span>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@(item.GeneratedByAi ? "AI tạo" : "Thủ công")</td>
                            <td class="px-4 py-3 text-slate-600">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-3 text-right">
                                <div class="admin-icon-actions">
                                    <a class="admin-icon-btn admin-icon-view" asp-action="PathDetail" asp-route-id="@item.PathId" title="Chi tiết lộ trình" aria-label="Chi tiết lộ trình">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Paths.Any())
                    {
                        <tr>
                            <td class="px-4 py-6 text-center text-slate-500" colspan="6">Không có lộ trình phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <nav class="flex items-center justify-between text-sm text-slate-600" aria-label="Pagination">
        <span>Trang @Model.Page / @Model.TotalPages</span>
        <div class="flex gap-2">
            <a class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-semibold @(Model.Page <= 1 ? "pointer-events-none opacity-50" : "")"
               asp-action="PathHistory" asp-route-page="@(Model.Page - 1)" asp-route-status="@Model.Status">Trước</a>
            <a class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-semibold @(Model.Page >= Model.TotalPages ? "pointer-events-none opacity-50" : "")"
               asp-action="PathHistory" asp-route-page="@(Model.Page + 1)" asp-route-status="@Model.Status">Sau</a>
        </div>
    </nav>
</div>

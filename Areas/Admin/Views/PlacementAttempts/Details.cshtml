@model DuAnTotNghiep.ViewModels.Admin.PlacementAttemptDetailViewModel
@{
    ViewData["Title"] = "Attempt Details";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Attempt Details</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="row">
        <!-- Main Info -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">General Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th>Student:</th>
                                <td>@Model.StudentName</td>
                            </tr>
                            <tr>
                                <th>Test:</th>
                                <td>@Model.TestTitle</td>
                            </tr>
                            <tr>
                                <th>Total Score:</th>
                                <td><strong class="text-success">@Model.TotalScore</strong></td>
                            </tr>
                            <tr>
                                <th>Level:</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.EstimatedLevel))
                                    {
                                        <span class="badge bg-info">@Model.EstimatedLevel</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Status:</th>
                                <td>
                                    <span class="badge @(Model.Status == "GRADED" ? "bg-success" : (Model.Status == "SUBMITTED" ? "bg-warning" : "bg-secondary"))">
                                        @Model.Status
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Started At:</th>
                                <td>@Model.StartedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <th>Submitted At:</th>
                                <td>@(Model.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- AI Status -->
        <div class="col-md-8 mb-4">
            <div class="card h-100">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">AI Competency Analysis</h5>
                    @if (Model.AiAnalysisStatus == "Failed")
                    {
                        <form asp-controller="PlacementTests" asp-action="RetryAiAnalysis" method="post" class="m-0 p-0">
                            <input type="hidden" name="attemptId" value="@Model.AttemptId" />
                            <button type="submit" class="btn btn-sm btn-outline-light">
                                <i class="fas fa-sync"></i> Retry AI Analysis
                            </button>
                        </form>
                    }
                </div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                    @if (Model.AiAnalysisStatus == "Completed")
                    {
                        <div class="text-center text-success mb-3">
                            <i class="fas fa-check-circle fa-4x mb-3"></i>
                            <h4>Analysis Completed</h4>
                        </div>
                        <p class="text-muted">
                            The AI has successfully analyzed the student's performance. Detailed insights can be viewed in the student's learning profile or the corresponding Competency Analysis record.
                        </p>
                    }
                    else if (Model.AiAnalysisStatus == "Pending" || Model.AiAnalysisStatus == "Running")
                    {
                        <div class="text-center text-primary mb-3">
                            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <h4>AI is analyzing... (@Model.AiAnalysisStatus)</h4>
                        </div>
                    }
                    else if (Model.AiAnalysisStatus == "Failed")
                    {
                        <div class="text-center text-danger mb-3">
                            <i class="fas fa-exclamation-triangle fa-4x mb-3"></i>
                            <h4>Analysis Failed</h4>
                        </div>
                        <p class="text-muted">The background process encountered an error while analyzing the results.</p>
                    }
                    else
                    {
                        <div class="text-center text-secondary mb-3">
                            <i class="fas fa-robot fa-4x mb-3"></i>
                            <h4>Not Available</h4>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Skill Performance -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Skill Performance</h5>
                </div>
                <div class="card-body">
                    @if (Model.SkillScores.Any())
                    {
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Skill</th>
                                        <th>Score</th>
                                        <th>Percentage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var skill in Model.SkillScores)
                                    {
                                        <tr>
                                            <td><strong>@skill.SkillName</strong></td>
                                            <td>@skill.EarnedScore / @skill.MaxScore</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="progress flex-grow-1 me-2" style="height: 10px;">
                                                        <div class="progress-bar @(skill.Percentage >= 80 ? "bg-success" : (skill.Percentage >= 50 ? "bg-warning" : "bg-danger"))" 
                                                             role="progressbar" 
                                                             style="width: @skill.Percentage%" 
                                                             aria-valuenow="@skill.Percentage" 
                                                             aria-valuemin="0" 
                                                             aria-valuemax="100"></div>
                                                    </div>
                                                    <span style="min-width: 45px">@skill.Percentage%</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">No Skill Data Available</div>
                    }
                </div>
            </div>
        </div>

        <!-- Topic Performance -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Topic Performance</h5>
                </div>
                <div class="card-body">
                    @if (Model.TopicScores.Any())
                    {
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Topic</th>
                                        <th>Score</th>
                                        <th>Percentage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var topic in Model.TopicScores)
                                    {
                                        <tr>
                                            <td><strong>@topic.TopicName</strong></td>
                                            <td>@topic.EarnedScore / @topic.MaxScore</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="progress flex-grow-1 me-2" style="height: 10px;">
                                                        <div class="progress-bar @(topic.Percentage >= 80 ? "bg-success" : (topic.Percentage >= 50 ? "bg-warning" : "bg-danger"))" 
                                                             role="progressbar" 
                                                             style="width: @topic.Percentage%" 
                                                             aria-valuenow="@topic.Percentage" 
                                                             aria-valuemin="0" 
                                                             aria-valuemax="100"></div>
                                                    </div>
                                                    <span style="min-width: 45px">@topic.Percentage%</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">No Topic Data Available</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@model DuAnTotNghiep.Models.User
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var avatar = string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName ?? "GV")}&background=6C63FF&color=fff" : Model.AvatarUrl;
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Hồ sơ cá nhân</h1>
        <p class="text-muted m-0 small">Quản lý và cập nhật thông tin cá nhân của bạn trên hệ thống.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card-ailearn p-4">
            
            <!-- Avatar Section -->
            <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
                <img src="@avatar" alt="Avatar" class="user-avatar-sidebar border border-2 border-primary" style="width: 56px; height: 56px;" onerror="this.src='https://ui-avatars.com/api/?name=GV&background=6C63FF&color=fff';" />
                <div>
                    <h4 class="text-dark font-weight-bold mb-1 fs-5">@Model.FullName</h4>
                    <p class="text-muted small mb-0">Tài khoản: @Model.Email | Quyền: Giảng viên</p>
                </div>
            </div>

            <form asp-action="Update" method="post" class="d-flex flex-column gap-3">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PasswordHash" />
                <input type="hidden" asp-for="RoleId" />
                <input type="hidden" asp-for="Status" />

                <!-- FullName -->
                <div>
                    <label asp-for="FullName" class="form-label text-muted small uppercase font-weight-bold mb-1">Họ và tên</label>
                    <input asp-for="FullName" class="form-control border-1 rounded-3" required />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="form-label text-muted small uppercase font-weight-bold mb-1">Email liên hệ</label>
                    <input asp-for="Email" type="email" class="form-control border-1 rounded-3" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <!-- Phone -->
                <div>
                    <label asp-for="Phone" class="form-label text-muted small uppercase font-weight-bold mb-1">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control border-1 rounded-3" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <!-- AvatarUrl -->
                <div>
                    <label asp-for="AvatarUrl" class="form-label text-muted small uppercase font-weight-bold mb-1">Đường dẫn ảnh đại diện (Avatar URL)</label>
                    <input asp-for="AvatarUrl" class="form-control border-1 rounded-3" placeholder="http://example.com/avatar.jpg..." />
                    <span asp-validation-for="AvatarUrl" class="text-danger small"></span>
                </div>

                <!-- Submit buttons -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-primary-ailearn">
                        <i class="fa-solid fa-save me-1"></i> Cập nhật hồ sơ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

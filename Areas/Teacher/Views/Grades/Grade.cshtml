@model DuAnTotNghiep.Models.ViewModels.Teacher.PracticeSubmissionDetailViewModel
@{
    ViewData["Title"] = "Chấm bài";
}

<div class="max-w-3xl mx-auto py-6 px-4 font-sans space-y-6">
    <div>
        <a asp-action="Pending" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">Quay lại bài chờ chấm</a>
        <h1 class="text-2xl font-black text-slate-900 leading-tight mt-3">@Model.TaskTitle</h1>
        <p class="text-slate-500 text-sm">@Model.StudentName - @Model.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm space-y-5">
        <div>
            <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Yêu cầu</div>
            <p class="text-sm text-slate-700">@Model.TaskDescription</p>
        </div>
        <div>
            <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Bài làm</div>
            <div class="text-sm text-slate-800 bg-slate-50 border border-slate-150 rounded-xl p-4 whitespace-pre-line">@Model.StudentAnswer</div>
        </div>
        <form asp-action="Grade" asp-route-id="@Model.Id" method="post" class="space-y-4">
            <div class="space-y-1.5">
                <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Điểm</label>
                <input name="score" value="@Model.Score" type="number" step="0.1" min="0" max="100" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" required />
            </div>
            <div class="space-y-1.5">
                <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Phản hồi</label>
                <textarea name="feedback" rows="5" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl">@Model.TeacherFeedback</textarea>
            </div>
            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a asp-action="Pending" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold text-xs">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold text-xs">Lưu điểm</button>
            </div>
        </form>
    </div>
</div>

@model IEnumerable<DuAnTotNghiep.Models.QuizQuestion>
@{
    ViewData["Title"] = "Ngân hàng câu hỏi Quiz";
    var keyword = ViewBag.Keyword as string;
    var quizId = ViewBag.QuizId as int?;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="max-w-7xl mx-auto py-6 px-4 space-y-6 font-sans">
    
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-black text-slate-900 leading-tight">Ngân hàng câu hỏi Quiz</h1>
            <p class="text-slate-500 text-sm">Danh sách chi tiết các câu hỏi trắc nghiệm trên toàn hệ thống.</p>
        </div>
        <a href="/Teacher/Quizzes" class="text-xs font-bold text-blue-600 hover:text-blue-700">&larr; Danh sách Quiz</a>
    </div>

    <!-- Filters Section -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs">
        <form method="get" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
            <!-- Keyword Search -->
            <div class="md:col-span-2">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Tìm kiếm</label>
                <div class="relative">
                    <input type="text" name="keyword" value="@keyword" placeholder="Nhập nội dung câu hỏi..." class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50" />
                    <svg class="w-4 h-4 text-slate-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
            </div>

            <!-- Quiz Filter -->
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Bài Quiz</label>
                <select name="quizId" asp-items="ViewBag.QuizzesList" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50">
                    <option value="">Tất cả bài Quiz</option>
                </select>
            </div>

            <!-- Action buttons -->
            <div class="flex items-end gap-2">
                <button type="submit" class="flex-1 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-sm cursor-pointer text-center">Lọc</button>
                <a href="/Teacher/Quizzes/QuestionBank" class="p-2 text-sm font-bold text-slate-500 border border-slate-200 hover:bg-slate-50 rounded-xl transition-all cursor-pointer" title="Làm mới">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H12V4"></path></svg>
                </a>
            </div>
        </form>
    </div>

    <!-- Question Cards -->
    <div class="space-y-4">
        @if (!Model.Any())
        {
            <div class="bg-white p-12 text-center rounded-2xl border border-slate-200 text-slate-400">
                Không tìm thấy câu hỏi nào.
            </div>
        }
        @foreach (var q in Model)
        {
            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-3">
                <div class="flex flex-wrap items-center justify-between gap-2 border-b border-slate-100 pb-3">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-600 border border-blue-100">
                            Loại: @q.Question.QuestionType
                        </span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">
                            Điểm: @q.Points đ
                        </span>
                    </div>
                    <span class="text-xs text-slate-500 font-semibold">Thuộc Quiz: @q.Quiz.Title</span>
                </div>

                <div class="text-sm font-bold text-slate-900 leading-relaxed">
                    @q.Question.QuestionText
                </div>

                <!-- Correct Answer Display -->
                @if (!string.IsNullOrEmpty(q.Question.CorrectAnswer))
                {
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-150 text-xs text-slate-700 space-y-1">
                        <span class="font-bold text-green-600">Đáp án đúng / Hướng dẫn:</span>
                        <p class="font-mono bg-white p-2 rounded-lg border border-slate-100 mt-1 select-all">@q.Question.CorrectAnswer</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(q.Question.Explanation))
                {
                    <div class="text-xs text-slate-500 leading-relaxed italic">
                        <span class="font-bold text-slate-600 block">Giải thích:</span>
                        @q.Question.Explanation
                    </div>
                }
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="flex justify-center gap-1.5 pt-2">
            @for (int p = 1; p <= totalPages; p++)
            {
                <a href="/Teacher/Quizzes/QuestionBank?page=@p&keyword=@keyword&quizId=@quizId" class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs border transition-all @(currentPage == p ? "bg-blue-600 text-white border-blue-600" : "bg-white text-slate-600 border-slate-200 hover:bg-slate-50")">
                    @p
                </a>
            }
        </div>
    }

</div>

@model DuAnTotNghiep.Models.ViewModels.Teacher.QuizIndexViewModel
@{
    ViewData["Title"] = "Quiz - " + Model.TopicTitle;
}

@section Styles {
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Quản lý Quiz</h1>
        <p class="text-muted m-0 small">@Model.TopicTitle</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.TopicId" class="btn btn-secondary-ailearn">Khóa học</a>
        <a asp-action="Create" asp-route-topicId="@Model.TopicId" class="btn btn-primary-ailearn">
            <i class="fa-solid fa-plus me-1"></i> Tạo Quiz mới
        </a>
    </div>
</div>

<div class="card-ailearn p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr class="text-muted small font-weight-bold uppercase bg-light">
                    <th class="py-3 px-4">Tên Quiz</th>
                    <th class="py-3 px-4 text-center">Câu hỏi</th>
                    <th class="py-3 px-4 text-center">Lượt làm</th>
                    <th class="py-3 px-4 text-center">Điểm TB</th>
                    <th class="py-3 px-4 text-center">Trạng thái</th>
                    <th class="py-3 px-4 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Quizzes.Any())
                {
                    <tr>
                        <td colspan="6" class="py-4 text-center text-muted small">Khóa học này chưa có Quiz nào.</td>
                    </tr>
                }
                @foreach (var quiz in Model.Quizzes)
                {
                    <tr>
                        <td class="py-3 px-4">
                            <div class="d-flex flex-col">
                                <span class="font-weight-bold text-dark">@quiz.Title</span>
                                <span class="text-muted small line-clamp-1">@(quiz.Description ?? "Không có mô tả.")</span>
                            </div>
                        </td>
                        <td class="py-3 px-4 text-center">@quiz.QuestionCount</td>
                        <td class="py-3 px-4 text-center">@quiz.AttemptCount</td>
                        <td class="py-3 px-4 text-center font-weight-semibold">@quiz.AverageScore.ToString("0.0")</td>
                        <td class="py-3 px-4 text-center"><span class="purple-badge">@quiz.Status</span></td>
                        <td class="py-3 px-4 text-end">
                            <div class="d-flex justify-content-end gap-2 align-items-center">
                                <a asp-action="Results" asp-route-id="@quiz.Id" class="btn btn-outline-primary btn-sm py-1 px-2 fs-7">Kết quả</a>
                                <a asp-action="Edit" asp-route-id="@quiz.Id" class="btn btn-outline-secondary btn-sm p-1 px-2" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@quiz.Id" asp-route-topicId="@Model.TopicId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm p-1 px-2" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

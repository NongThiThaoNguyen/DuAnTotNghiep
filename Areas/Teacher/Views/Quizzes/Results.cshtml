@model List<DuAnTotNghiep.Models.ViewModels.Teacher.QuizAttemptResultViewModel>
@{
    ViewData["Title"] = "Kết quả Quiz";
    var topicId = ViewBag.TopicId as int? ?? 0;
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Kết quả Quiz</h1>
        <p class="text-muted m-0 small">@ViewBag.QuizTitle</p>
    </div>
    <a asp-action="Index" asp-route-topicId="@topicId" class="btn btn-secondary-ailearn">Quay lại</a>
</div>

<div class="card-ailearn p-0 overflow-hidden">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr class="text-muted small font-weight-bold uppercase bg-light">
                <th class="py-3 px-4">Học viên</th>
                <th class="py-3 px-4 text-center">Điểm</th>
                <th class="py-3 px-4 text-center">Thời gian</th>
                <th class="py-3 px-4 text-end">Nộp lúc</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="py-4 text-center text-muted small">Chưa có lượt làm quiz.</td></tr>
            }
            @foreach (var attempt in Model)
            {
                <tr>
                    <td class="py-3 px-4 font-weight-bold">@attempt.StudentName</td>
                    <td class="py-3 px-4 text-center">@attempt.Score?.ToString("0.0")</td>
                    <td class="py-3 px-4 text-center">@attempt.TimeTaken?.ToString(@"hh\:mm\:ss")</td>
                    <td class="py-3 px-4 text-end">@attempt.SubmittedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@model DuAnTotNghiep.Models.Quiz
@{
    ViewData["Title"] = "Chỉnh sửa Quiz";
}

<div class="max-w-2xl mx-auto py-6 px-4 font-sans space-y-6">
    
    <!-- Breadcrumb back -->
    <div class="flex items-center gap-2">
        <a href="/Teacher/Quizzes" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
    </div>

    <!-- Title Header -->
    <div>
        <h1 class="text-2xl font-black text-slate-900 leading-tight">Chỉnh sửa Quiz</h1>
        <p class="text-slate-500 text-sm">Chỉnh sửa thông số bài Quiz và lưu lại thay đổi.</p>
    </div>

    <!-- Form card -->
    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Edit" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>
            <input type="hidden" asp-for="Id" />

            <!-- Title -->
            <div class="space-y-1.5">
                <label asp-for="Title" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên bài Quiz</label>
                <input asp-for="Title" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required />
                <span asp-validation-for="Title" class="text-xs text-red-500"></span>
            </div>

            <!-- TopicId -->
            <div class="space-y-1.5">
                <label asp-for="TopicId" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Thuộc khóa học</label>
                <select asp-for="TopicId" asp-items="ViewBag.TopicId" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required></select>
                <span asp-validation-for="TopicId" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- QuizType -->
                <div class="space-y-1.5">
                    <label asp-for="QuizType" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Dạng Quiz</label>
                    <select asp-for="QuizType" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="PRACTICE">Luyện tập (PRACTICE)</option>
                        <option value="DIAGNOSTIC">Đánh giá đầu vào (DIAGNOSTIC)</option>
                        <option value="MILESTONE_TEST">Kiểm tra định kỳ (MILESTONE_TEST)</option>
                        <option value="LEVEL_UP">Kiểm tra lên cấp (LEVEL_UP)</option>
                    </select>
                    <span asp-validation-for="QuizType" class="text-xs text-red-500"></span>
                </div>

                <!-- TimeLimitMinutes -->
                <div class="space-y-1.5">
                    <label asp-for="TimeLimitMinutes" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Giới hạn thời gian (Phút)</label>
                    <input asp-for="TimeLimitMinutes" type="number" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required />
                    <span asp-validation-for="TimeLimitMinutes" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- PassingScore -->
                <div class="space-y-1.5">
                    <label asp-for="PassingScore" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Điểm đạt yêu cầu</label>
                    <input asp-for="PassingScore" type="number" step="0.1" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required />
                    <span asp-validation-for="PassingScore" class="text-xs text-red-500"></span>
                </div>

                <!-- Status -->
                <div class="space-y-1.5">
                    <label asp-for="Status" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Trạng thái phát hành</label>
                    <select asp-for="Status" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="PUBLISHED">Công khai (PUBLISHED)</option>
                        <option value="DRAFT">Bản nháp (DRAFT)</option>
                        <option value="PENDING">Chờ duyệt (PENDING)</option>
                        <option value="ARCHIVED">Lưu trữ (ARCHIVED)</option>
                    </select>
                    <span asp-validation-for="Status" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- Description -->
            <div class="space-y-1.5">
                <label asp-for="Description" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Mô tả hướng dẫn làm bài</label>
                <textarea asp-for="Description" rows="4" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-500"></span>
            </div>

            <!-- Submit buttons -->
            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Teacher/Quizzes" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold transition-all text-xs cursor-pointer">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold transition-all text-xs shadow-sm shadow-blue-600/10 cursor-pointer">Lưu thay đổi</button>
            </div>
        </form>
    </div>

</div>

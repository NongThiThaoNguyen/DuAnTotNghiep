@model DuAnTotNghiep.Models.ViewModels.Teacher.EditQuizViewModel
@{
    ViewData["Title"] = "Chỉnh sửa Quiz";
}

<div class="w-full mx-auto py-6 px-4 font-sans space-y-6">
    <div>
        <a asp-action="Index" asp-route-topicId="@Model.TopicId" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">Quay lại danh sách</a>
        <h1 class="text-2xl font-black text-slate-900 leading-tight mt-3">Chỉnh sửa Quiz</h1>
        <p class="text-slate-500 text-sm">@Model.TopicTitle</p>
    </div>

    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-5">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TopicId" />
            <input type="hidden" asp-for="TopicTitle" />
            <div class="space-y-1.5">
                <label asp-for="Title" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên bài Quiz</label>
                <input asp-for="Title" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" required />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                <div class="space-y-1.5">
                    <label asp-for="TimeLimitMinutes" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Thời gian (phút)</label>
                    <input asp-for="TimeLimitMinutes" type="number" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" />
                </div>
                <div class="space-y-1.5">
                    <label asp-for="PassScore" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Điểm qua môn</label>
                    <input asp-for="PassScore" type="number" step="0.1" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" />
                </div>
                <div class="space-y-1.5">
                    <label asp-for="Status" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Trạng thái</label>
                    <select asp-for="Status" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl bg-white">
                        <option value="PUBLISHED">PUBLISHED</option>
                        <option value="DRAFT">DRAFT</option>
                        <option value="ARCHIVED">ARCHIVED</option>
                    </select>
                </div>
            </div>
            <div class="space-y-1.5">
                <label asp-for="Description" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Mô tả</label>
                <textarea asp-for="Description" rows="4" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl"></textarea>
            </div>
            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a asp-action="ManageQuestions" asp-route-id="@Model.Id" class="px-5 py-2.5 rounded-xl border border-blue-200 text-blue-700 bg-blue-50 hover:bg-blue-100 font-bold text-xs"><i class="fa-solid fa-list-check me-1"></i> Quản lý câu hỏi</a>
                <a asp-action="Index" asp-route-topicId="@Model.TopicId" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold text-xs">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold text-xs">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

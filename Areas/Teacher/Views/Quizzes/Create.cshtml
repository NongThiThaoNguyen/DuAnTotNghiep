@model DuAnTotNghiep.Models.ViewModels.Teacher.CreateQuizViewModel
@{
    ViewData["Title"] = "Tạo Quiz mới";
}

<div class="max-w-3xl mx-auto py-6 px-4 font-sans space-y-6">
    <div>
        <a asp-action="Index" asp-route-topicId="@Model.TopicId" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">Quay lại danh sách</a>
        <h1 class="text-2xl font-black text-slate-900 leading-tight mt-3">Tạo Quiz mới</h1>
        <p class="text-slate-500 text-sm">@Model.TopicTitle</p>
    </div>

    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Create" method="post" class="space-y-5" id="quizForm">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>
            <input type="hidden" asp-for="TopicId" />
            <input type="hidden" asp-for="TopicTitle" />

            <div class="space-y-1.5">
                <label asp-for="Title" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên bài Quiz</label>
                <input asp-for="Title" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" required />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label asp-for="TimeLimitMinutes" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Thời gian (phút)</label>
                    <input asp-for="TimeLimitMinutes" type="number" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" />
                </div>
                <div class="space-y-1.5">
                    <label asp-for="PassScore" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Điểm đạt</label>
                    <input asp-for="PassScore" type="number" step="0.1" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" />
                </div>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Description" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Mô tả</label>
                <textarea asp-for="Description" rows="3" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl"></textarea>
            </div>

            <div class="space-y-3">
                <div class="flex items-center justify-between">
                    <h2 class="text-sm font-black text-slate-900">Câu hỏi</h2>
                    <button type="button" id="addQuestion" class="px-3 py-2 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold text-xs">Thêm câu hỏi</button>
                </div>
                <div id="questions" class="space-y-4">
                    @for (var i = 0; i < Model.Questions.Count; i++)
                    {
                        <div class="question-block border border-slate-200 rounded-xl p-4 space-y-3">
                            <input name="Questions[@i].QuestionText" value="@Model.Questions[i].QuestionText" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Nội dung câu hỏi" />
                            <input type="hidden" name="Questions[@i].QuestionType" value="MCQ" />
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                @for (var j = 0; j < 4; j++)
                                {
                                    <input name="Questions[@i].Options[@j]" value="@(Model.Questions[i].Options.ElementAtOrDefault(j) ?? "")" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án @(j + 1)" />
                                }
                            </div>
                            <input name="Questions[@i].CorrectAnswer" value="@Model.Questions[i].CorrectAnswer" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án đúng, nhập đúng nội dung một đáp án" />
                            <input name="Questions[@i].Points" value="@Model.Questions[i].Points" type="number" step="0.1" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Điểm" />
                        </div>
                    }
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a asp-action="Index" asp-route-topicId="@Model.TopicId" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold text-xs">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold text-xs">Tạo Quiz</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const container = document.getElementById('questions');
            document.getElementById('addQuestion')?.addEventListener('click', () => {
                const i = container.querySelectorAll('.question-block').length;
                const html = `<div class="question-block border border-slate-200 rounded-xl p-4 space-y-3">
                    <input name="Questions[${i}].QuestionText" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Nội dung câu hỏi" />
                    <input type="hidden" name="Questions[${i}].QuestionType" value="MCQ" />
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <input name="Questions[${i}].Options[0]" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án 1" />
                        <input name="Questions[${i}].Options[1]" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án 2" />
                        <input name="Questions[${i}].Options[2]" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án 3" />
                        <input name="Questions[${i}].Options[3]" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án 4" />
                    </div>
                    <input name="Questions[${i}].CorrectAnswer" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Đáp án đúng" />
                    <input name="Questions[${i}].Points" value="1" type="number" step="0.1" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Điểm" />
                </div>`;
                container.insertAdjacentHTML('beforeend', html);
            });
        })();
    </script>
}

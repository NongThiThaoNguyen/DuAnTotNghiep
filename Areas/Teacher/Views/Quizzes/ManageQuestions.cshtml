@model DuAnTotNghiep.Models.ViewModels.Teacher.QuizManageViewModel
@{
    ViewData["Title"] = "Quản lý câu hỏi";
}

<div class="w-full mx-auto py-6 px-4 font-sans space-y-6">
    <!-- Breadcrumb back -->
    <div class="flex items-center justify-between">
        <div>
            <a href="/Teacher/Quizzes?topicId=@Model.TopicId" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Quay lại danh sách
            </a>
            <h1 class="text-2xl font-black text-slate-900 leading-tight mt-2">Quản lý câu hỏi: @Model.Title</h1>
            <p class="text-slate-500 text-sm">Quản lý danh sách câu hỏi trắc nghiệm của bài kiểm tra này.</p>
        </div>
        <div class="flex gap-2">
            <button type="button" class="btn btn-outline-primary btn-sm rounded-xl px-4 font-bold" data-bs-toggle="modal" data-bs-target="#modalAddManual">
                <i class="fa-solid fa-plus me-1"></i> Thêm thủ công
            </button>
            <button type="button" class="btn btn-outline-success btn-sm rounded-xl px-4 font-bold" data-bs-toggle="modal" data-bs-target="#modalImportFile">
                <i class="fa-solid fa-file-import me-1"></i> Import Word / Excel
            </button>
            <button type="button" class="btn btn-primary-ailearn btn-sm rounded-xl px-4 font-bold" data-bs-toggle="modal" data-bs-target="#modalAI">
                <i class="fa-solid fa-robot me-1"></i> Tạo bằng AI
            </button>
        </div>
    </div>

    <!-- Question List -->
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
        @if (Model.Questions == null || !Model.Questions.Any())
        {
            <div class="text-center py-10">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 text-slate-400 mb-4">
                    <i class="fa-regular fa-folder-open text-2xl"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-700">Chưa có câu hỏi nào</h3>
                <p class="text-slate-500 text-sm mt-1">Hãy thêm câu hỏi mới bằng cách tạo thủ công, Import từ File hoặc sử dụng AI.</p>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions[i];
                    <div class="border border-slate-200 rounded-xl p-4">
                        <div class="flex justify-between items-start">
                            <div>
                                <span class="font-bold text-sm text-blue-600">Câu @(i + 1):</span>
                                <span class="text-slate-800 font-medium ms-2">@q.QuestionText</span>
                                <span class="badge bg-slate-100 text-slate-600 ms-2 text-xs">@q.Points Điểm</span>
                            </div>
                            <!-- Delete Question -->
                            <form asp-action="DeleteQuestion" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xoá câu hỏi này?');">
                                <input type="hidden" name="quizId" value="@Model.Id" />
                                <input type="hidden" name="questionId" value="@q.GetHashCode()" /> <!-- Update when real QuestionId is ready -->
                                <button type="submit" class="text-red-500 hover:text-red-700 p-1">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                        <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2 ps-4">
                            @foreach (var opt in q.Options)
                            {
                                var isCorrect = string.Equals(opt, q.CorrectAnswer, StringComparison.OrdinalIgnoreCase);
                                <div class="text-sm px-3 py-2 rounded-lg @(isCorrect ? "bg-green-50 border border-green-200 text-green-700 font-medium" : "bg-slate-50 border border-slate-200 text-slate-600")">
                                    @if(isCorrect) { <i class="fa-solid fa-check-circle me-1"></i> }
                                    @opt
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Modal Add Manual -->
<div class="modal fade" id="modalAddManual" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-2xl shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="font-black text-slate-800 text-lg">Thêm câu hỏi mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddQuestion" method="post">
                <div class="modal-body space-y-4">
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    
                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 uppercase">Nội dung câu hỏi</label>
                        <textarea name="QuestionText" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" rows="3" required></textarea>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase">Đáp án A</label>
                            <input name="Options[0]" class="w-full px-4 py-2 text-sm border border-slate-200 rounded-xl" required />
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase">Đáp án B</label>
                            <input name="Options[1]" class="w-full px-4 py-2 text-sm border border-slate-200 rounded-xl" required />
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase">Đáp án C</label>
                            <input name="Options[2]" class="w-full px-4 py-2 text-sm border border-slate-200 rounded-xl" />
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase">Đáp án D</label>
                            <input name="Options[3]" class="w-full px-4 py-2 text-sm border border-slate-200 rounded-xl" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 uppercase">Đáp án đúng (Copy y hệt nội dung của 1 trong 4 đáp án trên)</label>
                        <input name="CorrectAnswer" class="w-full px-4 py-2.5 text-sm border border-green-200 rounded-xl bg-green-50 focus:ring-green-500" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary rounded-xl" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary-ailearn rounded-xl">Thêm câu hỏi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Import File -->
<div class="modal fade" id="modalImportFile" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-2xl shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="font-black text-slate-800 text-lg">Import từ File (Word / Excel)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ImportQuestions" method="post" enctype="multipart/form-data">
                <div class="modal-body space-y-4">
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    
                    <div class="bg-blue-50 p-3 rounded-xl border border-blue-100 text-sm text-blue-800 mb-3">
                        <strong>Lưu ý cấu trúc file:</strong>
                        <ul class="list-disc ms-4 mt-1">
                            <li><strong>Excel:</strong> Cột A (Câu hỏi), Cột B-E (4 Đáp án), Cột F (Đáp án đúng).</li>
                            <li><strong>Word:</strong> Cứ 6 dòng liên tiếp là 1 câu: Dòng 1 (Câu hỏi), Dòng 2-5 (4 Đáp án), Dòng 6 (Đáp án đúng). Bỏ qua dòng trống.</li>
                        </ul>
                        <div class="mt-3 flex gap-2">
                            <a href="/Teacher/Quizzes/DownloadSample?format=excel" class="btn btn-sm btn-outline-primary bg-white py-1 text-xs font-bold"><i class="fa-solid fa-download me-1"></i> File mẫu Excel</a>
                            <a href="/Teacher/Quizzes/DownloadSample?format=word" class="btn btn-sm btn-outline-primary bg-white py-1 text-xs font-bold"><i class="fa-solid fa-download me-1"></i> File mẫu Word</a>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 uppercase">Chọn file (.docx, .xlsx)</label>
                        <input type="file" name="importFile" accept=".xlsx,.docx" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary rounded-xl" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success rounded-xl text-white font-bold">Import file</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Tạo bằng AI -->
<div class="modal fade" id="modalAI" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-2xl shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="font-black text-slate-800 text-lg">Tạo câu hỏi bằng AI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GenerateAIQuestions" method="post">
                <div class="modal-body space-y-4">
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    <input type="hidden" name="topicId" value="@Model.TopicId" />
                    <input type="hidden" name="SkillId" value="1" />
                    
                    <div class="bg-blue-50 p-3 rounded-xl border border-blue-100 text-sm text-blue-800 mb-3">
                        Hệ thống sẽ dựa trên tên khóa học, mô tả và số lượng bạn yêu cầu để tự động sinh câu hỏi.
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 uppercase">Số lượng câu hỏi cần tạo</label>
                        <input type="number" name="NumberOfQuestions" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" value="5" min="1" max="20" required />
                    </div>
                    
                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 uppercase">Ghi chú cho AI (Tuỳ chọn, vd: dễ, khó...)</label>
                        <input type="text" name="AdditionalInstructions" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" placeholder="Chỉ tập trung vào phần phát âm..." />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary rounded-xl" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary-ailearn rounded-xl font-bold">
                        <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Bắt đầu sinh AI
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

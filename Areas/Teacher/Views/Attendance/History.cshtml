@model IEnumerable<DuAnTotNghiep.Models.Attendance>
@{
    ViewData["Title"] = "Lịch sử điểm danh";
}

<div class="max-w-7xl mx-auto py-6 px-4 space-y-6 font-sans">
    
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-black text-slate-900 leading-tight">Lịch sử điểm danh</h1>
            <p class="text-slate-500 text-sm">Xem lịch sử chuyên cần của lớp học theo bộ lọc thời gian.</p>
        </div>
        <a href="/Teacher/Attendance" class="text-xs font-bold text-blue-600 hover:text-blue-700">&larr; Quay lại điểm danh</a>
    </div>

    <!-- Filters Section -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs">
        <form method="get" class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
            <!-- Topic Filter -->
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Khóa học</label>
                <select name="topicId" asp-items="ViewBag.TopicsList" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50">
                    <option value="">Tất cả khóa học</option>
                </select>
            </div>

            <!-- Start Date -->
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Từ ngày</label>
                <input type="date" name="startDate" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50" />
            </div>

            <!-- End Date -->
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Đến ngày</label>
                <input type="date" name="endDate" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50" />
            </div>

            <!-- Action buttons -->
            <div class="flex gap-2">
                <button type="submit" class="flex-1 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-sm cursor-pointer text-center">Tìm kiếm</button>
                <a href="/Teacher/Attendance/History" class="p-2 text-sm font-bold text-slate-500 border border-slate-200 hover:bg-slate-50 rounded-xl transition-all cursor-pointer" title="Làm mới">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H12V4"></path></svg>
                </a>
            </div>
        </form>
    </div>

    <!-- Table List -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50/50 text-slate-400 text-xs font-bold uppercase tracking-wider">
                        <th class="py-3.5 px-6">Ngày điểm danh</th>
                        <th class="py-3.5 px-6">Khóa học</th>
                        <th class="py-3.5 px-6">Học viên</th>
                        <th class="py-3.5 px-6 text-center">Trạng thái</th>
                        <th class="py-3.5 px-6">Ghi chú</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-8 text-center text-slate-400">Không tìm thấy bản ghi điểm danh nào.</td>
                        </tr>
                    }
                    @foreach (var record in Model)
                    {
                        var statusColor = record.Status switch
                        {
                            "PRESENT" => "bg-green-50 text-green-700 border-green-100",
                            "LATE" => "bg-amber-50 text-amber-600 border-amber-100",
                            "EXCUSED" => "bg-blue-50 text-blue-600 border-blue-100",
                            _ => "bg-red-50 text-red-600 border-red-100"
                        };

                        <tr class="hover:bg-slate-50/40 transition-colors">
                            <td class="py-4 px-6 font-bold text-slate-800">@record.AttendanceDate.ToString("dd/MM/yyyy")</td>
                            <td class="py-4 px-6 font-semibold text-slate-700">@record.Topic.Title</td>
                            <td class="py-4 px-6 font-medium text-slate-600">@record.Student.FullName</td>
                            <td class="py-4 px-6 text-center">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold border @statusColor">
                                    @record.Status
                                </span>
                            </td>
                            <td class="py-4 px-6 text-slate-500 italic text-xs">@(record.Remarks ?? "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

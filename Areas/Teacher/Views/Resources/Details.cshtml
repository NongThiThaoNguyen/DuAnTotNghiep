@model DuAnTotNghiep.Models.ReferenceSource
@{
    ViewData["Title"] = "Chi tiết học liệu - " + Model.SourceName;
}

<div class="max-w-3xl mx-auto py-6 px-4 font-sans space-y-6">
    
    <!-- Navigation back -->
    <div class="flex items-center justify-between">
        <a href="/Teacher/Resources" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
        <a href="/Teacher/Resources/Edit/@Model.Id" class="px-4 py-2 rounded-xl border border-slate-200 text-slate-750 hover:bg-slate-50 font-bold transition-all text-xs flex items-center gap-1.5 cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            Chỉnh sửa tài liệu
        </a>
    </div>

    <!-- Content Card -->
    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm space-y-6">
        <div class="space-y-2 border-b border-slate-100 pb-4">
            <div class="flex items-center gap-2">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-600 border border-blue-100">
                    Phân loại: @Model.SourceType
                </span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">
                    Chính sách: @Model.UsagePolicy
                </span>
            </div>
            
            <h1 class="text-2xl font-black text-slate-900 leading-tight">@Model.SourceName</h1>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 text-sm">
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Tác giả</span>
                <span class="text-slate-800 font-semibold mt-0.5 block">@(Model.Author ?? "N/A")</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Tổ chức / NXB</span>
                <span class="text-slate-800 font-semibold mt-0.5 block">@(Model.Organization ?? "N/A")</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Ghi chú giấy phép</span>
                <span class="text-slate-800 font-semibold mt-0.5 block">@(Model.LicenseNote ?? "N/A")</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Trạng thái duyệt</span>
                <span class="text-slate-800 font-semibold mt-0.5 block">@Model.Status</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SourceUrl))
        {
            <div class="p-4 bg-blue-50 border border-blue-150 rounded-xl flex flex-col items-start gap-1">
                <span class="text-xs font-semibold text-blue-800">Liên kết tài nguyên:</span>
                <a href="@Model.SourceUrl" target="_blank" class="text-xs font-bold text-blue-600 underline break-all">@Model.SourceUrl</a>
            </div>
        }

        <!-- Description -->
        <div class="space-y-2">
            <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Mô tả chi tiết</span>
            <div class="text-sm text-slate-700 leading-relaxed whitespace-pre-line bg-slate-50/50 p-4 border border-slate-150 rounded-xl">
                @(Model.Description ?? "Không có mô tả chi tiết.")
            </div>
        </div>
    </div>

</div>

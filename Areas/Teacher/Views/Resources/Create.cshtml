@model DuAnTotNghiep.Models.ReferenceSource
@using DuAnTotNghiep.Models.Enums
@{
    ViewData["Title"] = "Thêm học liệu mới";
}

<div class="w-full mx-auto py-6 px-4 font-sans space-y-6">
    
    <!-- Breadcrumb back -->
    <div class="flex items-center gap-2">
        <a href="/Teacher/Resources" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
    </div>

    <!-- Title Header -->
    <div>
        <h1 class="text-2xl font-black text-slate-900 leading-tight">Tải lên học liệu mới</h1>
        <p class="text-slate-500 text-sm">Điền đầy đủ thông tin sách, podcast, tài liệu, hoặc liên kết ngoài để học viên tham khảo.</p>
    </div>

    <!-- Form card -->
    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Create" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>

            <!-- SourceName -->
            <div class="space-y-1.5">
                <label asp-for="SourceName" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên học liệu</label>
                <input asp-for="SourceName" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Ví dụ: Cambridge English Grammar in Use..." required />
                <span asp-validation-for="SourceName" class="text-xs text-red-500"></span>
            </div>

            <!-- SourceUrl -->
            <div class="space-y-1.5">
                <label asp-for="SourceUrl" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Đường dẫn tài liệu (Link PDF, Audio, Drive...)</label>
                <input asp-for="SourceUrl" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="http://example.com/document.pdf..." />
                <span asp-validation-for="SourceUrl" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- SourceType -->
                <div class="space-y-1.5">
                    <label asp-for="SourceType" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Phân loại nguồn</label>
                    <select asp-for="SourceType" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="@ReferenceSourceType.TEACHER_CREATED">Giảng viên biên soạn</option>
                        <option value="@ReferenceSourceType.OFFICIAL">Nguồn chính thống (OFFICIAL)</option>
                        <option value="@ReferenceSourceType.OPEN_LICENSE">Giấy phép mở (OPEN_LICENSE)</option>
                        <option value="@ReferenceSourceType.REFERENCE_ONLY">Chỉ tham khảo (REFERENCE_ONLY)</option>
                    </select>
                    <span asp-validation-for="SourceType" class="text-xs text-red-500"></span>
                </div>

                <!-- UsagePolicy -->
                <div class="space-y-1.5">
                    <label asp-for="UsagePolicy" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Chính sách sử dụng</label>
                    <select asp-for="UsagePolicy" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="@ReferenceUsagePolicy.REFERENCE_ONLY">Chỉ tham khảo</option>
                        <option value="@ReferenceUsagePolicy.OPEN_LICENSE">Phát hành miễn phí (OPEN_LICENSE)</option>
                        <option value="@ReferenceUsagePolicy.RESTRICTED">Giới hạn sử dụng (RESTRICTED)</option>
                    </select>
                    <span asp-validation-for="UsagePolicy" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- Author -->
                <div class="space-y-1.5">
                    <label asp-for="Author" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tác giả</label>
                    <input asp-for="Author" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Tên tác giả..." />
                    <span asp-validation-for="Author" class="text-xs text-red-500"></span>
                </div>

                <!-- Organization -->
                <div class="space-y-1.5">
                    <label asp-for="Organization" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tổ chức / Nhà xuất bản</label>
                    <input asp-for="Organization" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Ví dụ: Cambridge University Press..." />
                    <span asp-validation-for="Organization" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- LicenseNote -->
            <div class="space-y-1.5">
                <label asp-for="LicenseNote" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Ghi chú bản quyền / Giấy phép</label>
                <input asp-for="LicenseNote" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Ghi chú sử dụng CC-BY-SA, All Rights Reserved..." />
                <span asp-validation-for="LicenseNote" class="text-xs text-red-500"></span>
            </div>

            <!-- Description -->
            <div class="space-y-1.5">
                <label asp-for="Description" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tóm tắt mô tả tài liệu</label>
                <textarea asp-for="Description" rows="4" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Tóm tắt ngắn gọn nội dung và giá trị sử dụng học tập..."></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-500"></span>
            </div>

            <!-- Submit buttons -->
            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Teacher/Resources" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold transition-all text-xs cursor-pointer">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold transition-all text-xs shadow-sm shadow-blue-600/10 cursor-pointer">Tải lên</button>
            </div>
        </form>
    </div>

</div>

@model IEnumerable<DuAnTotNghiep.Models.SystemSetting>
@{
    ViewData["Title"] = "Cấu hình hệ thống";
}

<div class="max-w-4xl mx-auto py-8 px-4 font-sans space-y-8">
    
    <!-- Title Header -->
    <div class="border-b border-slate-100 pb-4">
        <h1 class="text-2xl font-black text-slate-900 leading-tight">Cài đặt hệ thống</h1>
        <p class="text-slate-500 text-sm mt-1">Quản lý và điều chỉnh các cấu hình chung liên quan đến việc học và vận hành.</p>
    </div>

    <!-- Main Settings Card -->
    <div class="bg-white rounded-3xl border border-slate-200 shadow-md p-8 relative overflow-hidden">
        <!-- Top decorative gradient line -->
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-purple-500 via-indigo-500 to-blue-500"></div>

        <form asp-action="Update" method="post">
            <div class="flex flex-col gap-6">
                @if (!Model.Any())
                {
                    <div class="text-center py-10 text-slate-400 space-y-3">
                        <div class="w-16 h-16 bg-slate-50 text-slate-400 rounded-full flex items-center justify-center mx-auto border border-slate-100 shadow-xs">
                            <i class="fa-solid fa-sliders text-xl"></i>
                        </div>
                        <h4 class="text-slate-700 font-bold text-sm">Chưa có cấu hình</h4>
                        <p class="text-slate-400 text-xs max-w-xs mx-auto">Hiện tại chưa có cấu hình hệ thống nào được thiết lập cho vai trò của bạn.</p>
                    </div>
                }
                @foreach (var setting in Model)
                {
                    <div class="border-b border-slate-100 pb-4 last:border-b-0 last:pb-0 space-y-2.5">
                        <div>
                            <span class="font-bold text-slate-800 text-sm block">@setting.SettingKey</span>
                            <span class="text-slate-400 text-xs d-block mt-0.5">@(setting.Description ?? "Không có mô tả.")</span>
                        </div>
                        <input type="text" name="settingsData[@setting.Id]" value="@setting.SettingValue" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all font-medium text-slate-700 bg-slate-50/30" required />
                    </div>
                }
            </div>

            @if (Model.Any())
            {
                <div class="flex items-center justify-end gap-3 pt-5 border-t border-slate-100 mt-6">
                    <button type="submit" class="btn btn-primary-ailearn">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                        Lưu cấu hình
                    </button>
                </div>
            }
        </form>
    </div>
</div>

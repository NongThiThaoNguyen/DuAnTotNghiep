@model IEnumerable<DuAnTotNghiep.Models.PracticeTask>
@{
    ViewData["Title"] = "Quản lý Bài tập";
    var keyword = ViewBag.Keyword as string;
    var topicId = ViewBag.TopicId as int?;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

@section Styles {
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Quản lý Bài tập</h1>
        <p class="text-muted m-0 small">Tạo và giao bài tập viết luận (Essay), phát âm hoặc thực hành kỹ năng cho học viên.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Teacher/Assignments/Submissions" class="btn btn-secondary-ailearn">
            Bài làm học viên nộp
        </a>
        <a href="/Teacher/Assignments/Create@(topicId.HasValue ? "?topicId=" + topicId.Value : "")" class="btn btn-primary-ailearn">
            <i class="fa-solid fa-plus me-1"></i> Thêm bài tập mới
        </a>
    </div>
</div>

<!-- Filters Section -->
<div class="card-ailearn mb-4">
    <form method="get" class="row g-3 align-items-end">
        <!-- Keyword Search -->
        <div class="col-md-5">
            <label class="form-label text-muted small uppercase font-weight-bold">Tìm kiếm</label>
            <div class="search-box w-100">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" name="keyword" value="@keyword" placeholder="Nhập tên bài tập, từ khóa..." />
            </div>
        </div>

        <!-- Topic Filter -->
        <div class="col-md-4">
            <label class="form-label text-muted small uppercase font-weight-bold">Khóa học</label>
            <select name="topicId" asp-items="ViewBag.Topics" class="form-select border-1 rounded-3">
                <option value="">Tất cả khóa học</option>
            </select>
        </div>

        <!-- Action buttons -->
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary-ailearn flex-grow-1 btn-sm">Lọc</button>
            <a href="/Teacher/Assignments" class="btn btn-secondary-ailearn btn-sm" title="Làm mới">
                <i class="fa-solid fa-rotate"></i>
            </a>
        </div>
    </form>
</div>

<!-- Table List Card -->
<div class="card-ailearn p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr class="text-muted small font-weight-bold uppercase bg-light">
                    <th class="py-3 px-4">Bài tập</th>
                    <th class="py-3 px-4">Thuộc khóa học</th>
                    <th class="py-3 px-4 text-center">Dạng bài tập</th>
                    <th class="py-3 px-4 text-center">Trình độ</th>
                    <th class="py-3 px-4 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="py-4 text-center text-muted small">Không tìm thấy bài tập nào.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="py-3 px-4">
                            <div class="d-flex flex-col max-w-sm">
                                <span class="font-weight-bold text-dark">@item.Title</span>
                                <span class="text-muted small line-clamp-1">Yêu cầu: @item.Instruction</span>
                            </div>
                        </td>
                        <td class="py-3 px-4 text-muted">@(item.Topic?.Title ?? "Tổng quát")</td>
                        <td class="py-3 px-4 text-center">
                            <span class="purple-badge">@item.TaskType</span>
                        </td>
                        <td class="py-3 px-4 text-center text-dark font-weight-semibold">@item.DifficultyLevel</td>
                        <td class="py-3 px-4 text-end">
                            <div class="d-flex justify-content-end gap-2 align-items-center">
                                <a href="/Teacher/Assignments/Submissions?taskId=@item.Id" class="btn btn-outline-secondary btn-sm py-1 px-2 fs-7" title="Xem bài nộp">
                                    Xem bài nộp
                                </a>
                                <a href="/Teacher/Assignments/Edit/@item.Id" class="btn btn-outline-secondary btn-sm p-1 px-2" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a href="/Teacher/Assignments/Delete/@item.Id" class="btn btn-outline-danger btn-sm p-1 px-2" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <div class="d-flex justify-content-center gap-2 mt-4">
        @for (int p = 1; p <= totalPages; p++)
        {
            <a href="/Teacher/Assignments?page=@p&keyword=@keyword&topicId=@topicId" class="btn @(currentPage == p ? "btn-primary-ailearn" : "btn-secondary-ailearn") btn-sm px-3">
                @p
            </a>
        }
    </div>
}

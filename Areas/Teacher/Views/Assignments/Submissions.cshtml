@model IEnumerable<DuAnTotNghiep.Models.PracticeSubmission>
@{
    ViewData["Title"] = "Bài tập học viên nộp";
    var taskId = ViewBag.TaskId as int?;
    var status = ViewBag.Status as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="max-w-7xl mx-auto py-6 px-4 space-y-6 font-sans">
    
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-black text-slate-900 leading-tight">Bài làm học viên nộp</h1>
            <p class="text-slate-500 text-sm">Chấm điểm và phản hồi bài thực hành kỹ năng (nói, viết luận) của học viên.</p>
        </div>
        <a href="/Teacher/Assignments" class="text-xs font-bold text-blue-600 hover:text-blue-700">&larr; Danh sách bài tập</a>
    </div>

    <!-- Filters Section -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-xs">
        <form method="get" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
            <!-- Task Filter -->
            <div class="md:col-span-2">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Bài tập</label>
                <select name="taskId" asp-items="ViewBag.Tasks" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50">
                    <option value="">Tất cả bài tập</option>
                </select>
            </div>

            <!-- Status Filter -->
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Trạng thái</label>
                <select name="status" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-slate-50/50">
                    <option value="">Tất cả</option>
                    <option value="SUBMITTED">Học viên mới nộp (SUBMITTED)</option>
                    <option value="AI_REVIEWED">AI đã nhận xét (AI_REVIEWED)</option>
                    <option value="TEACHER_REVIEWED">Giáo viên đã chấm (TEACHER_REVIEWED)</option>
                </select>
            </div>

            <!-- Action buttons -->
            <div class="flex items-end gap-2">
                <button type="submit" class="flex-1 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-sm cursor-pointer text-center">Lọc</button>
                <a href="/Teacher/Assignments/Submissions" class="p-2 text-sm font-bold text-slate-500 border border-slate-200 hover:bg-slate-50 rounded-xl transition-all cursor-pointer" title="Làm mới">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H12V4"></path></svg>
                </a>
            </div>
        </form>
    </div>

    <!-- Table List -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50/50 text-slate-400 text-xs font-bold uppercase tracking-wider">
                        <th class="py-3.5 px-6">Học viên</th>
                        <th class="py-3.5 px-6">Đề bài</th>
                        <th class="py-3.5 px-6 text-center">Trạng thái</th>
                        <th class="py-3.5 px-6 text-center">Điểm số</th>
                        <th class="py-3.5 px-6 text-center">Thời gian nộp</th>
                        <th class="py-3.5 px-6 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="py-8 text-center text-slate-400">Không tìm thấy bài nộp nào.</td>
                        </tr>
                    }
                    @foreach (var sub in Model)
                    {
                        <tr class="hover:bg-slate-50/40 transition-colors">
                            <td class="py-4 px-6 font-bold text-slate-800">@sub.Student.FullName</td>
                            <td class="py-4 px-6 font-medium text-slate-700">@sub.PracticeTask.Title</td>
                            <td class="py-4 px-6 text-center">
                                @if (sub.Status == "SUBMITTED")
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-amber-50 text-amber-600 border border-amber-100">Chờ chấm</span>
                                }
                                else if (sub.Status == "AI_REVIEWED")
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-purple-50 text-purple-600 border border-purple-100">AI nhận xét</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">Đã chấm</span>
                                }
                            </td>
                            <td class="py-4 px-6 text-center font-bold text-slate-850">
                                @(sub.Score.HasValue ? sub.Score.Value.ToString("0.0") + "đ" : "Chưa chấm")
                            </td>
                            <td class="py-4 px-6 text-center text-slate-450 text-xs">@sub.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="py-4 px-6 text-right">
                                <a href="/Teacher/Assignments/Grade/@sub.Id" class="text-xs font-bold text-blue-600 hover:text-blue-700">
                                    @(sub.Status == "TEACHER_REVIEWED" ? "Xem lại" : "Chấm điểm")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="flex justify-center gap-1.5 pt-2">
            @for (int p = 1; p <= totalPages; p++)
            {
                <a href="/Teacher/Assignments/Submissions?page=@p&taskId=@taskId&status=@status" class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs border transition-all @(currentPage == p ? "bg-blue-600 text-white border-blue-600" : "bg-white text-slate-600 border-slate-200 hover:bg-slate-50")">
                    @p
                </a>
            }
        </div>
    }

</div>

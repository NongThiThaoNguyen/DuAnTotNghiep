@model DuAnTotNghiep.Models.PracticeTask
@{
    ViewData["Title"] = "Chỉnh sửa bài tập";
}

<div class="w-full mx-auto py-6 px-4 font-sans space-y-6">
    
    <!-- Breadcrumb back -->
    <div class="flex items-center gap-2">
        <a href="/Teacher/Assignments" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
    </div>

    <!-- Title Header -->
    <div>
        <h1 class="text-2xl font-black text-slate-900 leading-tight">Chỉnh sửa bài tập</h1>
        <p class="text-slate-500 text-sm">Chỉnh sửa các trường thông tin của bài tập và lưu lại thay đổi.</p>
    </div>

    <!-- Form card -->
    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Edit" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>
            <input type="hidden" asp-for="Id" />

            <!-- Title -->
            <div class="space-y-1.5">
                <label asp-for="Title" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên bài tập</label>
                <input asp-for="Title" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required />
                <span asp-validation-for="Title" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- TopicId -->
                <div class="space-y-1.5">
                    <label asp-for="TopicId" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Khóa học đính kèm</label>
                    <select asp-for="TopicId" asp-items="ViewBag.TopicId" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required></select>
                    <span asp-validation-for="TopicId" class="text-xs text-red-500"></span>
                </div>

                <!-- SkillId -->
                <div class="space-y-1.5">
                    <label asp-for="SkillId" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Kỹ năng đánh giá</label>
                    <select asp-for="SkillId" asp-items="ViewBag.SkillId" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required></select>
                    <span asp-validation-for="SkillId" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- TaskType -->
                <div class="space-y-1.5">
                    <label asp-for="TaskType" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Dạng bài tập</label>
                    <select asp-for="TaskType" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="SHORT_ANSWER">Trả lời ngắn (SHORT_ANSWER)</option>
                        <option value="MCQ">Trắc nghiệm (MCQ)</option>
                        <option value="TRUE_FALSE">Đúng / Sai (TRUE_FALSE)</option>
                        <option value="LISTENING">Luyện nghe (LISTENING)</option>
                    </select>
                    <span asp-validation-for="TaskType" class="text-xs text-red-500"></span>
                </div>

                <!-- Difficulty -->
                <div class="space-y-1.5">
                    <label asp-for="DifficultyLevel" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Độ khó</label>
                    <select asp-for="DifficultyLevel" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="BASIC">Cơ bản (BASIC)</option>
                        <option value="MEDIUM">Trung bình (MEDIUM)</option>
                        <option value="ADVANCED">Nâng cao (ADVANCED)</option>
                    </select>
                    <span asp-validation-for="DifficultyLevel" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <!-- Status -->
                <div class="space-y-1.5">
                    <label asp-for="Status" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Trạng thái giao bài</label>
                    <select asp-for="Status" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                        <option value="PUBLISHED">Đã giao (PUBLISHED)</option>
                        <option value="DRAFT">Bản nháp (DRAFT)</option>
                        <option value="PENDING">Chờ duyệt (PENDING)</option>
                        <option value="ARCHIVED">Lưu trữ (ARCHIVED)</option>
                    </select>
                    <span asp-validation-for="Status" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- Instruction -->
            <div class="space-y-1.5">
                <label asp-for="Instruction" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Yêu cầu & Đề bài bài tập</label>
                <textarea asp-for="Instruction" rows="6" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required></textarea>
                <span asp-validation-for="Instruction" class="text-xs text-red-500"></span>
            </div>

            <!-- Submit buttons -->
            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Teacher/Assignments" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold transition-all text-xs cursor-pointer">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold transition-all text-xs shadow-sm shadow-blue-600/10 cursor-pointer">Lưu thay đổi</button>
            </div>
        </form>
    </div>

</div>

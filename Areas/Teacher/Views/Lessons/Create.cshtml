@model DuAnTotNghiep.Models.OriginalLesson
@{
    ViewData["Title"] = "Thêm bài học mới";
}

<div class="max-w-2xl mx-auto py-6 px-4 font-sans space-y-6">
    
    <!-- Breadcrumb back -->
    <div class="flex items-center gap-2">
        <a href="/Teacher/Lessons" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
    </div>

    <!-- Title Header -->
    <div>
        <h1 class="text-2xl font-black text-slate-900 leading-tight">Thêm bài học mới</h1>
        <p class="text-slate-500 text-sm">Điền đầy đủ thông tin bài học và đính kèm vào khóa học tương ứng.</p>
    </div>

    <!-- Form card -->
    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Create" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>

            <!-- Title -->
            <div class="space-y-1.5">
                <label asp-for="Title" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên bài học</label>
                <input asp-for="Title" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Nhập tiêu đề bài học..." required />
                <span asp-validation-for="Title" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                <!-- TopicId -->
                <div class="sm:col-span-2 space-y-1.5">
                    <label asp-for="TopicId" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Thuộc khóa học</label>
                    <select asp-for="TopicId" asp-items="ViewBag.TopicId" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required></select>
                    <span asp-validation-for="TopicId" class="text-xs text-red-500"></span>
                </div>

                <!-- EstimatedMinutes -->
                <div class="space-y-1.5">
                    <label asp-for="EstimatedMinutes" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Thời lượng (Phút)</label>
                    <input asp-for="EstimatedMinutes" type="number" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" value="15" required />
                    <span asp-validation-for="EstimatedMinutes" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- ContentType -->
            <div class="space-y-1.5">
                <label asp-for="ContentType" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Dạng tài liệu bài giảng</label>
                <select asp-for="ContentType" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white" required>
                    <option value="TEXT">Bài đọc văn bản (TEXT)</option>
                    <option value="AUDIO_LINK">Link âm thanh/Podcast (AUDIO_LINK)</option>
                    <option value="VIDEO_LINK">Link video bài giảng (VIDEO_LINK)</option>
                    <option value="REFERENCE_LINK">Tài liệu tham khảo mở (REFERENCE_LINK)</option>
                </select>
                <span asp-validation-for="ContentType" class="text-xs text-red-500"></span>
            </div>

            <!-- Summary -->
            <div class="space-y-1.5">
                <label asp-for="Summary" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tóm tắt bài học</label>
                <input asp-for="Summary" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Tóm tắt ngắn gọn mục tiêu, nội dung..." />
                <span asp-validation-for="Summary" class="text-xs text-red-500"></span>
            </div>

            <!-- Content -->
            <div class="space-y-1.5">
                <label asp-for="Content" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Nội dung bài học / Link đính kèm</label>
                <textarea asp-for="Content" rows="8" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Nhập nội dung bài giảng chi tiết hoặc dán URL bài giảng ở đây..." required></textarea>
                <span asp-validation-for="Content" class="text-xs text-red-500"></span>
            </div>

            <!-- Submit buttons -->
            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Teacher/Lessons" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-770 hover:bg-slate-50 font-bold transition-all text-xs cursor-pointer">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold transition-all text-xs shadow-sm shadow-blue-600/10 cursor-pointer">Lưu bài học</button>
            </div>
        </form>
    </div>

</div>

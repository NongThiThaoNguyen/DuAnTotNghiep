@model DuAnTotNghiep.Models.ViewModels.Teacher.LessonDetailViewModel
@{
    ViewData["Title"] = "Chi tiết bài học - " + Model.Title;
}

<div class="max-w-3xl mx-auto py-6 px-4 font-sans space-y-6">
    <div class="flex items-center justify-between">
        <a asp-action="Index" asp-route-courseId="@Model.TopicId" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">Quay lại bài học</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="px-4 py-2 rounded-xl border border-slate-200 text-slate-750 hover:bg-slate-50 font-bold text-xs">Chỉnh sửa bài học</a>
    </div>

    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm space-y-6">
        <div class="space-y-2 border-b border-slate-100 pb-4">
            <div class="flex items-center gap-2">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-600 border border-blue-100">
                    Khóa học: @Model.TopicTitle
                </span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">
                    @Model.Status
                </span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-slate-50 text-slate-650 border border-slate-200">
                    @(Model.EstimatedMinutes ?? 0) phút
                </span>
            </div>

            <h1 class="text-2xl font-black text-slate-900 leading-tight">@Model.Title</h1>
            <p class="text-slate-500 text-xs italic">Tóm tắt: @(Model.Summary ?? "Không có tóm tắt.")</p>
        </div>

        <div class="prose prose-slate max-w-none text-sm text-slate-800 leading-relaxed space-y-4 whitespace-pre-line bg-slate-50/50 p-6 rounded-xl border border-slate-150">
            @Html.Raw(Model.Content)
        </div>
    </div>
</div>

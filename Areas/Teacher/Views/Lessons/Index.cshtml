@model DuAnTotNghiep.Models.ViewModels.Teacher.LessonIndexViewModel
@{
    ViewData["Title"] = "Bài học - " + Model.CourseTitle;
}

@section Styles {
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Bài học trong khóa</h1>
        <p class="text-muted m-0 small">@Model.CourseTitle</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-secondary-ailearn">
            <i class="fa-solid fa-arrow-left me-1"></i> Khóa học
        </a>
        <a asp-action="Create" asp-route-courseId="@Model.CourseId" class="btn btn-primary-ailearn">
            <i class="fa-solid fa-plus me-1"></i> Thêm bài học mới
        </a>
    </div>
</div>

<div class="card-ailearn p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr class="text-muted small font-weight-bold uppercase bg-light">
                    <th class="py-3 px-4 text-center">#</th>
                    <th class="py-3 px-4">Bài học</th>
                    <th class="py-3 px-4 text-center">Thời lượng</th>
                    <th class="py-3 px-4 text-center">Trạng thái</th>
                    <th class="py-3 px-4 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Lessons.Any())
                {
                    <tr>
                        <td colspan="5" class="py-4 text-center text-muted small">Khóa học này chưa có bài học nào.</td>
                    </tr>
                }
                @foreach (var item in Model.Lessons)
                {
                    <tr>
                        <td class="py-3 px-4 text-center text-muted">@item.OrderIndex</td>
                        <td class="py-3 px-4">
                            <div class="d-flex flex-col">
                                <span class="font-weight-bold text-dark">@item.Title</span>
                                <span class="text-muted small line-clamp-1">@(item.Summary ?? "Không có tóm tắt.")</span>
                            </div>
                        </td>
                        <td class="py-3 px-4 text-center text-dark font-weight-semibold">@(item.EstimatedMinutes ?? 0) phút</td>
                        <td class="py-3 px-4 text-center">
                            <span class="purple-badge">@item.Status</span>
                        </td>
                        <td class="py-3 px-4 text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm p-1 px-2" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm p-1 px-2" title="Chi tiết">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" asp-route-courseId="@Model.CourseId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm p-1 px-2" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model DuAnTotNghiep.Models.ViewModels.Teacher.CreateCourseViewModel
@{
    ViewData["Title"] = "Tạo khóa học mới";
}

<div class="max-w-2xl mx-auto py-6 px-4 font-sans space-y-6">
    <div>
        <a asp-action="Index" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">Quay lại danh sách</a>
        <h1 class="text-2xl font-black text-slate-900 leading-tight mt-3">Tạo khóa học mới</h1>
        <p class="text-slate-500 text-sm">Điền đầy đủ thông tin để tạo khóa học mới trên hệ thống.</p>
    </div>

    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm">
        <form asp-action="Create" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>

            <div class="space-y-1.5">
                <label asp-for="Title" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tên khóa học</label>
                <input asp-for="Title" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" required />
                <span asp-validation-for="Title" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label asp-for="SkillId" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Kỹ năng</label>
                    <select asp-for="SkillId" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl bg-white" required>
                        @foreach (var skill in Model.SkillOptions)
                        {
                            <option value="@skill.Id">@skill.Name</option>
                        }
                    </select>
                    <span asp-validation-for="SkillId" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5">
                    <label asp-for="ProficiencyLevelId" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Trình độ</label>
                    <select asp-for="ProficiencyLevelId" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl bg-white">
                        <option value="">Không chọn</option>
                        @foreach (var level in Model.LevelOptions)
                        {
                            <option value="@level.Id">@level.Code - @level.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label asp-for="DifficultyLevel" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Độ khó</label>
                    <select asp-for="DifficultyLevel" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl bg-white" required>
                        <option value="BASIC">Cơ bản</option>
                        <option value="MEDIUM">Trung bình</option>
                        <option value="ADVANCED">Nâng cao</option>
                    </select>
                </div>
                <div class="space-y-1.5">
                    <label asp-for="EstimatedMinutes" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Thời lượng dự tính</label>
                    <input asp-for="EstimatedMinutes" type="number" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl" />
                </div>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Description" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider">Mô tả khóa học</label>
                <textarea asp-for="Description" rows="4" class="w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl"></textarea>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a asp-action="Index" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold text-xs">Hủy</a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold text-xs">Lưu khóa học</button>
            </div>
        </form>
    </div>
</div>

@model DuAnTotNghiep.Models.ViewModels.Teacher.CourseIndexViewModel
@{
    ViewData["Title"] = "Khóa học giảng dạy";
}

@section Styles {
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Khóa học giảng dạy</h1>
        <p class="text-muted m-0 small">Quản lý nội dung học tập, phân loại theo kỹ năng và trình độ.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary-ailearn">
        <i class="fa-solid fa-plus me-1"></i> Tạo khóa học mới
    </a>
</div>

<div class="card-ailearn mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label text-muted small uppercase font-weight-bold">Tìm kiếm</label>
            <div class="search-box w-100">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" name="search" value="@Model.Search" placeholder="Nhập tên khóa học, mã..." />
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label text-muted small uppercase font-weight-bold">Kỹ năng</label>
            <select name="skill" class="form-select border-1 rounded-3">
                <option value="">Tất cả</option>
                @foreach (var option in Model.SkillOptions)
                {
                    <option value="@option.Code" selected="@(Model.Skill == option.Code ? "selected" : null)">@option.Name</option>
                }
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary-ailearn flex-grow-1 btn-sm">Tìm kiếm</button>
            <a asp-action="Index" class="btn btn-secondary-ailearn btn-sm" title="Làm mới">
                <i class="fa-solid fa-rotate"></i>
            </a>
        </div>
    </form>
</div>

<div class="course-grid-ailearn">
    @if (!Model.Courses.Any())
    {
        <div class="card-ailearn col-span-full w-100 text-center py-5 text-muted">
            Không tìm thấy khóa học nào khớp với bộ lọc.
        </div>
    }

    @{
        int index = 0;
    }
    @foreach (var course in Model.Courses)
    {
        string thumbBg = $"linear-gradient(135deg, {(index % 3 == 0 ? "#7B6DFF, #6C63FF" : index % 3 == 1 ? "#4ADE80, #22C55E" : "#60A5FA, #3B82F6")}, #08142E)";
        index++;

        <div class="course-card-wrapper-item">
            <div class="card-ailearn course-card-ailearn hoverable">
                <div class="course-card-thumb" style="height: 140px;">
                    <div style="width: 100%; height: 100%; background: @thumbBg; display: flex; align-items: center; justify-content: center; color: white;">
                        <i class="fa-solid fa-graduation-cap" style="font-size: 2.5rem; opacity: 0.25;"></i>
                    </div>
                    <span class="course-card-tag">@course.DifficultyLevel</span>
                </div>

                <div class="course-card-info p-0">
                    <div>
                        <div class="d-flex gap-1.5 mb-2">
                            <span class="purple-badge">@course.SkillName</span>
                            @if (!string.IsNullOrWhiteSpace(course.LevelName))
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                    @course.LevelName
                                </span>
                            }
                            @if (!course.IsActive)
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill">
                                    Inactive
                                </span>
                            }
                        </div>

                        <h3 class="fs-6 text-dark font-weight-bold mb-1">@course.Title</h3>
                        <p class="text-muted small mb-3">@(course.Description ?? "Không có mô tả chi tiết.")</p>
                    </div>

                    <div class="course-card-meta">
                        <div class="course-card-meta-item">
                            <i class="fa-solid fa-book-open"></i>
                            <span>@course.LessonCount bài học</span>
                        </div>
                        <div class="course-card-meta-item">
                            <i class="fa-solid fa-users"></i>
                            <span>@course.StudentCount học viên</span>
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-outline-secondary btn-sm p-1 px-2" title="Sửa">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm p-1 px-2" title="Chi tiết">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@course.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm p-1 px-2" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

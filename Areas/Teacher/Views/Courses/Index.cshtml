@model IEnumerable<DuAnTotNghiep.Models.LearningTopic>
@{
    ViewData["Title"] = "Khóa học giảng dạy";
    var keyword = ViewBag.Keyword as string;
    var skillId = ViewBag.SkillId as int?;
    var levelId = ViewBag.LevelId as int?;
    var difficulty = ViewBag.Difficulty as string;
    var status = ViewBag.Status as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

@section Styles {
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Khóa học giảng dạy</h1>
        <p class="text-muted m-0 small">Quản lý nội dung học tập, phân loại theo kỹ năng và trình độ.</p>
    </div>
    <a href="/Teacher/Courses/Create" class="btn btn-primary-ailearn">
        <i class="fa-solid fa-plus me-1"></i> Tạo khóa học mới
    </a>
</div>

<!-- Filters Section -->
<div class="card-ailearn mb-4">
    <form method="get" class="row g-3 align-items-end">
        <!-- Keyword Search -->
        <div class="col-md-4">
            <label class="form-label text-muted small uppercase font-weight-bold">Tìm kiếm</label>
            <div class="search-box w-100">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" name="keyword" value="@keyword" placeholder="Nhập tên khóa học, mã..." />
            </div>
        </div>

        <!-- Skill Filter -->
        <div class="col-md-3">
            <label class="form-label text-muted small uppercase font-weight-bold">Kỹ năng</label>
            <select name="skillId" asp-items="ViewBag.Skills" class="form-select border-1 rounded-3">
                <option value="">Tất cả</option>
            </select>
        </div>

        <!-- Level Filter -->
        <div class="col-md-3">
            <label class="form-label text-muted small uppercase font-weight-bold">Trình độ</label>
            <select name="levelId" asp-items="ViewBag.Levels" class="form-select border-1 rounded-3">
                <option value="">Tất cả</option>
            </select>
        </div>

        <!-- Action buttons -->
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary-ailearn flex-grow-1 btn-sm">Tìm kiếm</button>
            <a href="/Teacher/Courses" class="btn btn-secondary-ailearn btn-sm" title="Làm mới">
                <i class="fa-solid fa-rotate"></i>
            </a>
        </div>
    </form>
</div>

<!-- Courses Grid -->
<div class="course-grid-ailearn">
    @if (!Model.Any())
    {
        <div class="card-ailearn col-span-full w-100 text-center py-5 text-muted">
            Không tìm thấy khóa học nào khớp với bộ lọc.
        </div>
    }
    @{
        int index = 0;
    }
    @foreach (var topic in Model)
    {
        string thumbBg = $"linear-gradient(135deg, {(index % 3 == 0 ? "#7B6DFF, #6C63FF" : index % 3 == 1 ? "#4ADE80, #22C55E" : "#60A5FA, #3B82F6")}, #08142E)";
        index++;

        <div class="course-card-wrapper-item">
            <div class="card-ailearn course-card-ailearn hoverable">
                <!-- Thumbnail -->
                <div class="course-card-thumb" style="height: 140px;">
                    <div style="width: 100%; height: 100%; background: @thumbBg; display: flex; align-items: center; justify-content: center; color: white;">
                        <i class="fa-solid fa-graduation-cap" style="font-size: 2.5rem; opacity: 0.25;"></i>
                    </div>
                    <span class="course-card-tag">@topic.DifficultyLevel</span>
                </div>

                <!-- Card Details -->
                <div class="course-card-info p-0">
                    <div>
                        <div class="d-flex gap-1.5 mb-2">
                            <span class="purple-badge">
                                @(topic.Skill?.SkillName ?? "Tổng quát")
                            </span>
                            @if (topic.Level != null)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                    @topic.Level.Code
                                </span>
                            }
                        </div>
                        
                        <h3 class="fs-6 text-dark font-weight-bold mb-1">@topic.Title</h3>
                        <p class="text-muted small mb-3">@(topic.Description ?? "Không có mô tả chi tiết.")</p>
                    </div>

                    <!-- Bottom metadata & actions -->
                    <div class="course-card-meta">
                        <div class="course-card-meta-item">
                            <i class="fa-solid fa-book-open"></i>
                            <span>@topic.OriginalLessons.Count bài học</span>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="/Teacher/Courses/Edit/@topic.Id" class="btn btn-outline-secondary btn-sm p-1 px-2" title="Sửa">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <a href="/Teacher/Courses/Details/@topic.Id" class="btn btn-outline-primary btn-sm p-1 px-2" title="Chi tiết">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a href="/Teacher/Courses/Delete/@topic.Id" class="btn btn-outline-danger btn-sm p-1 px-2" title="Xóa">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <div class="d-flex justify-content-center gap-2 mt-4">
        @for (int p = 1; p <= totalPages; p++)
        {
            <a href="/Teacher/Courses?page=@p&keyword=@keyword&skillId=@skillId&levelId=@levelId&difficulty=@difficulty&status=@status" class="btn @(currentPage == p ? "btn-primary-ailearn" : "btn-secondary-ailearn") btn-sm px-3">
                @p
            </a>
        }
    </div>
}

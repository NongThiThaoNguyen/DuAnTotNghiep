@model DuAnTotNghiep.Models.ViewModels.Teacher.CourseDetailViewModel
@{
    ViewData["Title"] = "Chi tiết khóa học - " + Model.Title;
}

<div class="max-w-4xl mx-auto py-6 px-4 font-sans space-y-8">
    <div class="flex items-center justify-between">
        <a asp-action="Index" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">Quay lại danh sách</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="px-4 py-2 rounded-xl border border-slate-200 text-slate-750 hover:bg-slate-50 font-bold text-xs">Chỉnh sửa</a>
    </div>

    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm space-y-4">
        <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-50 text-blue-600 border border-blue-100">
                Kỹ năng: @Model.SkillName
            </span>
            @if (!string.IsNullOrWhiteSpace(Model.LevelName))
            {
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-50 text-green-700 border border-green-100">
                    Trình độ: @Model.LevelCode (@Model.LevelName)
                </span>
            }
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-50 text-amber-600 border border-amber-100">
                Độ khó: @Model.DifficultyLevel
            </span>
        </div>

        <h1 class="text-2xl font-black text-slate-900 leading-tight">@Model.Title</h1>
        <p class="text-slate-650 text-sm leading-relaxed">@(Model.Description ?? "Không có mô tả chi tiết.")</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-4 border-t border-slate-100 text-xs text-slate-500">
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Mã chủ đề</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@(Model.TopicCode ?? "N/A")</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Thời lượng</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@(Model.EstimatedMinutes ?? 0) phút</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Thứ tự</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@Model.OrderIndex</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Trạng thái</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@Model.Status</span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
        <div class="flex items-center justify-between border-b border-slate-100 pb-3">
            <h3 class="text-base font-bold text-slate-900">Bài học trong khóa (@Model.Lessons.Count)</h3>
            <a href="/Teacher/Lessons/Create?courseId=@Model.Id" class="text-xs font-bold text-blue-600 hover:text-blue-700">+ Thêm bài học mới</a>
        </div>

        <div class="divide-y divide-slate-100">
            @if (!Model.Lessons.Any())
            {
                <p class="text-slate-400 text-xs py-4 text-center">Khóa học này chưa có bài học nào.</p>
            }
            @foreach (var lesson in Model.Lessons)
            {
                <div class="py-3 flex items-center justify-between text-sm hover:bg-slate-50/55 px-2 rounded-lg">
                    <div class="flex flex-col">
                        <span class="font-semibold text-slate-800">@lesson.Title</span>
                        <span class="text-xs text-slate-450">Thời lượng: @(lesson.EstimatedMinutes ?? 0) phút | Trạng thái: @lesson.Status</span>
                    </div>
                    <a href="/Teacher/Lessons/Edit/@lesson.Id" class="text-xs font-bold text-slate-500 hover:text-blue-600">Sửa</a>
                </div>
            }
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
        <div class="flex items-center justify-between border-b border-slate-100 pb-3">
            <h3 class="text-base font-bold text-slate-900">Bài trắc nghiệm Quiz (@Model.Quizzes.Count)</h3>
            <a href="/Teacher/Quizzes/Create?topicId=@Model.Id" class="text-xs font-bold text-blue-600 hover:text-blue-700">+ Thêm Quiz mới</a>
        </div>

        <div class="divide-y divide-slate-100">
            @if (!Model.Quizzes.Any())
            {
                <p class="text-slate-400 text-xs py-4 text-center">Khóa học này chưa có bài trắc nghiệm Quiz.</p>
            }
            @foreach (var quiz in Model.Quizzes)
            {
                <div class="py-3 flex items-center justify-between text-sm hover:bg-slate-50/55 px-2 rounded-lg">
                    <div class="flex flex-col">
                        <span class="font-semibold text-slate-800">@quiz.Title</span>
                        <span class="text-xs text-slate-450">@quiz.QuestionCount câu hỏi | Trạng thái: @quiz.Status</span>
                    </div>
                    <a href="/Teacher/Quizzes/Edit/@quiz.Id" class="text-xs font-bold text-slate-500 hover:text-blue-600">Sửa</a>
                </div>
            }
        </div>
    </div>
</div>

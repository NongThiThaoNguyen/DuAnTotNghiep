@model DuAnTotNghiep.Models.LearningTopic
@{
    ViewData["Title"] = "Chi tiết khóa học - " + Model.Title;
}

<div class="max-w-4xl mx-auto py-6 px-4 font-sans space-y-8">
    
    <!-- Breadcrumb back -->
    <div class="flex items-center justify-between">
        <a href="/Teacher/Courses" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
        
        <div class="flex items-center gap-2">
            <a href="/Teacher/Courses/Edit/@Model.Id" class="px-4 py-2 rounded-xl border border-slate-200 text-slate-750 hover:bg-slate-50 font-bold transition-all text-xs flex items-center gap-1.5 cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                Chỉnh sửa
            </a>
        </div>
    </div>

    <!-- Course Overview Card -->
    <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-200 shadow-sm space-y-4">
        <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-50 text-blue-600 border border-blue-100">
                Kỹ năng: @(Model.Skill?.SkillName ?? "Tổng quát")
            </span>
            @if (Model.Level != null)
            {
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-50 text-green-700 border border-green-100">
                    Trình độ: @Model.Level.Code (@Model.Level.Name)
                </span>
            }
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-50 text-amber-600 border border-amber-100">
                Độ khó: @Model.DifficultyLevel
            </span>
        </div>

        <h1 class="text-2xl font-black text-slate-900 leading-tight">@Model.Title</h1>
        <p class="text-slate-650 text-sm leading-relaxed">@(Model.Description ?? "Không có mô tả chi tiết.")</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-4 border-t border-slate-100 text-xs text-slate-500">
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Mã chủ đề</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@(Model.TopicCode ?? "N/A")</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Thời lượng</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@(Model.EstimatedMinutes ?? 0) phút</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Thứ tự hiển thị</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@Model.OrderIndex</span>
            </div>
            <div>
                <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">Trạng thái</span>
                <span class="text-slate-800 font-bold mt-0.5 block">@Model.Status</span>
            </div>
        </div>
    </div>

    <!-- Tab Section: Lessons, Quizzes, Assignments -->
    <div class="space-y-6">
        
        <!-- 1. Danh sách bài học -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    Bài học trong khóa (@Model.OriginalLessons.Count)
                </h3>
                <a href="/Teacher/Lessons/Create?topicId=@Model.Id" class="text-xs font-bold text-blue-600 hover:text-blue-700">+ Thêm bài học mới</a>
            </div>

            <div class="divide-y divide-slate-100">
                @if (!Model.OriginalLessons.Any())
                {
                    <p class="text-slate-400 text-xs py-4 text-center">Khóa học này chưa có bài học nào.</p>
                }
                @foreach (var lesson in Model.OriginalLessons.OrderBy(l => l.Id))
                {
                    <div class="py-3 flex items-center justify-between text-sm hover:bg-slate-50/55 px-2 rounded-lg transition-colors">
                        <div class="flex flex-col">
                            <span class="font-semibold text-slate-800">@lesson.Title</span>
                            <span class="text-xs text-slate-450">Loại: @lesson.ContentType | Thời lượng: @lesson.EstimatedMinutes phút</span>
                        </div>
                        <a href="/Teacher/Lessons/Edit/@lesson.Id" class="text-xs font-bold text-slate-500 hover:text-blue-600">Sửa</a>
                    </div>
                }
            </div>
        </div>

        <!-- 2. Danh sách Quiz -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    Bài trắc nghiệm Quiz (@Model.Quizzes.Count)
                </h3>
                <a href="/Teacher/Quizzes/Create?topicId=@Model.Id" class="text-xs font-bold text-blue-600 hover:text-blue-700">+ Thêm Quiz mới</a>
            </div>

            <div class="divide-y divide-slate-100">
                @if (!Model.Quizzes.Any())
                {
                    <p class="text-slate-400 text-xs py-4 text-center">Khóa học này chưa có bài trắc nghiệm Quiz.</p>
                }
                @foreach (var quiz in Model.Quizzes)
                {
                    <div class="py-3 flex items-center justify-between text-sm hover:bg-slate-50/55 px-2 rounded-lg transition-colors">
                        <div class="flex flex-col">
                            <span class="font-semibold text-slate-800">@quiz.Title</span>
                            <span class="text-xs text-slate-450">Loại: @quiz.QuizType | Thời gian làm bài: @quiz.TimeLimitMinutes phút</span>
                        </div>
                        <a href="/Teacher/Quizzes/Edit/@quiz.Id" class="text-xs font-bold text-slate-500 hover:text-blue-600">Sửa</a>
                    </div>
                }
            </div>
        </div>

        <!-- 3. Danh sách Bài tập -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                    <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    Bài tập rèn luyện (@Model.PracticeTasks.Count)
                </h3>
                <a href="/Teacher/Assignments/Create?topicId=@Model.Id" class="text-xs font-bold text-blue-600 hover:text-blue-700">+ Thêm bài tập mới</a>
            </div>

            <div class="divide-y divide-slate-100">
                @if (!Model.PracticeTasks.Any())
                {
                    <p class="text-slate-400 text-xs py-4 text-center">Khóa học này chưa có bài tập nào.</p>
                }
                @foreach (var task in Model.PracticeTasks)
                {
                    <div class="py-3 flex items-center justify-between text-sm hover:bg-slate-50/55 px-2 rounded-lg transition-colors">
                        <div class="flex flex-col flex-1 pr-4">
                            <span class="font-semibold text-slate-800">@task.Title</span>
                            <span class="text-xs text-slate-450 line-clamp-1">Yêu cầu: @task.Instruction</span>
                        </div>
                        <a href="/Teacher/Assignments/Edit/@task.Id" class="text-xs font-bold text-slate-500 hover:text-blue-600">Sửa</a>
                    </div>
                }
            </div>
        </div>

    </div>

</div>

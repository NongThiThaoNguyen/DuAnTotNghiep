@{
    ViewData["Title"] = "Báo cáo học vụ & Phân tích";

    int totalStudents = ViewBag.TotalStudents ?? 0;
    int totalCourses = ViewBag.TotalCourses ?? 0;
    int totalLessons = ViewBag.TotalLessons ?? 0;
    int totalSubmissions = ViewBag.TotalSubmissions ?? 0;

    var attendanceLabels = ViewBag.AttendanceLabels as List<string> ?? new List<string>();
    var attendanceValues = ViewBag.AttendanceValues as List<int> ?? new List<int>();

    var skillLabels = ViewBag.SkillLabels as List<string> ?? new List<string>();
    var skillValues = ViewBag.SkillValues as List<double> ?? new List<double>();

    var nodeLabels = ViewBag.NodeLabels as List<string> ?? new List<string>();
    var nodeValues = ViewBag.NodeValues as List<int> ?? new List<int>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/statistics.css" asp-append-version="true" />
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Báo cáo & Phân tích chuyên sâu</h1>
        <p class="text-muted m-0 small">Xem biểu đồ phân tích kỹ năng học viên, chuyên cần, và tiến trình hoàn thành bài học.</p>
    </div>
</div>

<!-- Summary Metrics Grid -->
<div class="stats-summary-grid">
    <div class="card-ailearn d-flex flex-column justify-content-between">
        <span class="text-muted small uppercase font-weight-bold tracking-wider">Học viên hoạt động</span>
        <div class="fs-2 font-weight-bold text-primary mt-1">@totalStudents</div>
        <span class="text-muted small mt-1">Tài khoản student active</span>
    </div>
    <div class="card-ailearn d-flex flex-column justify-content-between">
        <span class="text-muted small uppercase font-weight-bold tracking-wider">Khóa học hiện có</span>
        <div class="fs-2 font-weight-bold text-dark mt-1">@totalCourses</div>
        <span class="text-muted small mt-1">Khóa học đang phát hành</span>
    </div>
    <div class="card-ailearn d-flex flex-column justify-content-between">
        <span class="text-muted small uppercase font-weight-bold tracking-wider">Bài giảng biên soạn</span>
        <div class="fs-2 font-weight-bold text-dark mt-1">@totalLessons</div>
        <span class="text-muted small mt-1">Tài liệu học tập chi tiết</span>
    </div>
    <div class="card-ailearn d-flex flex-column justify-content-between">
        <span class="text-muted small uppercase font-weight-bold tracking-wider">Bài làm thực hành</span>
        <div class="fs-2 font-weight-bold text-success mt-1">@totalSubmissions</div>
        <span class="text-muted small mt-1">Tổng lượt nộp bài của lớp</span>
    </div>
</div>

<!-- Charts Row (2 columns) -->
<div class="row g-4 mb-4">
    
    <!-- 1. Attendance Distribution (Donut Display) -->
    <div class="col-md-6">
        <div class="card-ailearn h-100">
            <h3 class="fs-6 text-dark font-weight-bold mb-3 pb-2 border-bottom"><i class="fa-solid fa-user-check text-primary me-2"></i>Phân phối Điểm danh</h3>
            
            <div class="skills-progress-list">
                @if (!attendanceLabels.Any())
                {
                    <p class="text-muted small text-center py-4">Chưa có dữ liệu điểm danh.</p>
                }
                @for (int i = 0; i < attendanceLabels.Count; i++)
                {
                    var label = attendanceLabels[i];
                    var val = attendanceValues[i];
                    var max = attendanceValues.Max();
                    var pct = max > 0 ? (double)val / max * 100 : 0;
                    
                    <div class="skill-progress-item">
                        <div class="skill-progress-header">
                            <span>@label</span>
                            <span>@val lượt</span>
                        </div>
                        <div class="skill-progress-track">
                            <div class="skill-progress-fill listening" style="width: @pct%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 2. Skill Performance Averages (Bar Display) -->
    <div class="col-md-6">
        <div class="card-ailearn h-100">
            <h3 class="fs-6 text-dark font-weight-bold mb-3 pb-2 border-bottom"><i class="fa-solid fa-chart-line text-primary me-2"></i>Điểm số trung bình theo Kỹ năng</h3>
            
            <div class="skills-progress-list">
                @if (!skillLabels.Any())
                {
                    <p class="text-muted small text-center py-4">Chưa có bài viết/bài nói nào được chấm điểm.</p>
                }
                @for (int i = 0; i < skillLabels.Count; i++)
                {
                    var label = skillLabels[i];
                    var val = skillValues[i];
                    
                    <div class="skill-progress-item">
                        <div class="skill-progress-header">
                            <span>@label</span>
                            <span class="text-success font-weight-bold">@val.ToString("0.0")đ</span>
                        </div>
                        <div class="skill-progress-track">
                            <div class="skill-progress-fill speaking" style="width: @(val * 10)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 3. Learning Path Progress Distribution -->
    <div class="col-12 mt-4">
        <div class="card-ailearn">
            <h3 class="fs-6 text-dark font-weight-bold mb-3 pb-2 border-bottom"><i class="fa-solid fa-route text-primary me-2"></i>Tiến trình Node lộ trình của học viên</h3>
            
            <div class="row g-3">
                @if (!nodeLabels.Any())
                {
                    <p class="text-muted small text-center py-4 col-12">Chưa có thông tin tiến trình lộ trình học tập.</p>
                }
                @for (int i = 0; i < nodeLabels.Count; i++)
                {
                    var label = nodeLabels[i];
                    var val = nodeValues[i];
                    var max = nodeValues.Max();
                    var pct = max > 0 ? (double)val / max * 100 : 0;
                    
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 border">
                            <span class="text-muted small uppercase font-weight-bold tracking-wider">Trạng thái: @label</span>
                            <div class="fs-4 font-weight-bold text-dark mt-1">@val bài</div>
                            <div class="progress mt-2" style="height: 5px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: @pct%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

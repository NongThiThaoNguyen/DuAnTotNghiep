@using DuAnTotNghiep.Models
@using System.Security.Claims
@model List<ChatMessage>
@{
    ViewData["Title"] = "Hộp thư tin nhắn";
    var chatSummaries = ViewBag.ChatSummaries as List<DuAnTotNghiep.Areas.Teacher.Controllers.MessagesController.StudentChatSummary> ?? new List<DuAnTotNghiep.Areas.Teacher.Controllers.MessagesController.StudentChatSummary>();
    var selectedStudentId = ViewBag.SelectedStudentId as int?;
    var selectedStudentName = ViewBag.SelectedStudentName as string;
    var selectedStudentAvatar = ViewBag.SelectedStudentAvatar as string;
    
    // Find current user id from Claims
    var teacherIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int currentTeacherId = 0;
    if (teacherIdClaim != null) int.TryParse(teacherIdClaim, out currentTeacherId);
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    <style>
        .chat-sidebar-list {
            border-right: 1px solid var(--border-color);
            background-color: var(--body-bg);
            height: 100%;
            overflow-y: auto;
        }
        .chat-sidebar-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px;
            text-decoration: none;
            color: var(--text-main);
            border-bottom: 1px solid var(--border-color);
            transition: all var(--transition-speed);
        }
        .chat-sidebar-item:hover {
            background-color: rgba(108, 99, 255, 0.05);
            color: var(--primary-color);
        }
        .chat-sidebar-item.active {
            background-color: rgba(108, 99, 255, 0.1);
            border-left: 4px solid var(--primary-color);
            color: var(--primary-color);
        }
        .chat-main-pane {
            display: flex;
            flex-direction: column;
            height: 100%;
            background-color: #FFFFFF;
        }
    </style>
}

<div class="courses-header mb-4">
    <div>
        <h1 class="text-dark m-0 fs-3 font-weight-bold">Hộp thư tin nhắn</h1>
        <p class="text-muted m-0 small">Hỗ trợ và trao đổi trực tiếp với học viên.</p>
    </div>
</div>

<!-- Messages Container -->
<div class="chat-container-ailearn" style="height: calc(100vh - 200px);">
    <div class="row g-0 h-100">
        
        <!-- Left Panel: Chat List (1/3 width) -->
        <div class="col-md-4 h-100 d-flex flex-column chat-sidebar-list">
            <div class="p-3 bg-white border-bottom">
                <span class="text-muted small uppercase font-weight-bold tracking-wider">Danh sách hội thoại</span>
            </div>
            
            <!-- Chat List Scrollable -->
            <div class="flex-grow-1 overflow-y-auto">
                @if (!chatSummaries.Any())
                {
                    <p class="text-muted text-center py-4 small">Không có học viên nào.</p>
                }
                @foreach (var summary in chatSummaries)
                {
                    var isSelected = summary.StudentId == selectedStudentId;
                    var avatar = string.IsNullOrEmpty(summary.StudentAvatar) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(summary.StudentName ?? "HV")}&background=6C63FF&color=fff" : summary.StudentAvatar;

                    <a href="/Teacher/Messages?studentId=@summary.StudentId" class="chat-sidebar-item @(isSelected ? "active" : "")">
                        <img src="@avatar" alt="Avatar" class="user-avatar-sidebar border border-2 border-primary" style="width: 38px; height: 38px;" onerror="this.src='https://ui-avatars.com/api/?name=HV&background=6C63FF&color=fff';" />
                        
                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-baseline">
                                <span class="font-weight-bold text-dark text-sm truncate">@summary.StudentName</span>
                                @if (summary.LastMessageTime.HasValue)
                                {
                                    <span class="text-muted small" style="font-size: 10px;">@summary.LastMessageTime.Value.ToString("HH:mm")</span>
                                }
                            </div>
                            <p class="text-muted small text-truncate mb-0 mt-0.5 font-weight-medium">@summary.LastMessageText</p>
                        </div>

                        @if (summary.UnreadCount > 0)
                        {
                            <span class="badge bg-danger rounded-circle p-1 px-2 small">
                                @summary.UnreadCount
                            </span>
                        }
                    </a>
                }
            </div>
        </div>

        <!-- Right Panel: Conversation Screen (2/3 width) -->
        <div class="col-md-8 h-100 chat-main-pane">
            @if (selectedStudentId.HasValue)
            {
                var currentAvatar = string.IsNullOrEmpty(selectedStudentAvatar) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(selectedStudentName ?? "HV")}&background=6C63FF&color=fff" : selectedStudentAvatar;

                <!-- Active Chat Header -->
                <div class="chat-header-ailearn py-3 bg-white">
                    <div class="chat-tutor-profile">
                        <div class="chat-tutor-avatar">
                            <img src="@currentAvatar" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=HV&background=6C63FF&color=fff';" />
                            <div class="chat-tutor-status"></div>
                        </div>
                        <div class="chat-tutor-info">
                            <h3>@selectedStudentName</h3>
                            <span>Đang kết nối</span>
                        </div>
                    </div>
                </div>

                <!-- Chat Feed Scrollable -->
                <div id="chatFeed" class="chat-messages-log">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5 text-muted small">
                            Hãy gửi tin nhắn đầu tiên để bắt đầu hội thoại với học viên.
                        </div>
                    }
                    @foreach (var msg in Model)
                    {
                        var isTeacherMsg = msg.SenderId == currentTeacherId;
                        var senderAvatar = isTeacherMsg 
                            ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(User.Identity?.Name ?? "GV")}&background=6C63FF&color=fff" 
                            : currentAvatar;

                        <div class="chat-bubble-wrapper @(isTeacherMsg ? "student" : "ai")">
                            <img src="@senderAvatar" alt="Avatar" class="chat-bubble-avatar border border-1 border-primary" onerror="this.src='https://ui-avatars.com/api/?name=User&background=6C63FF&color=fff';" />
                            <div class="chat-bubble-content">
                                <p class="chat-bubble-text">@msg.MessageText</p>
                                <span class="chat-bubble-time">
                                    @msg.CreatedAt.AddHours(7).ToString("HH:mm")
                                </span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Message Input -->
                <div class="chat-input-bar">
                    <form asp-action="Send" method="post" class="chat-input-form">
                        <input type="hidden" name="receiverId" value="@selectedStudentId" />
                        <input type="text" name="messageText" placeholder="Nhập tin nhắn..." autocomplete="off" required />
                        <button type="submit" class="chat-send-btn">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <!-- Chat Screen Placeholder -->
                <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-center p-5 bg-light">
                    <div class="rounded-circle bg-primary-subtle text-primary border p-3 mb-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-comment-dots fs-3"></i>
                    </div>
                    <h5 class="text-dark font-weight-bold">Chưa chọn cuộc hội thoại</h5>
                    <p class="text-muted small max-w-xs mb-0">Chọn học viên ở danh sách bên trái để bắt đầu nhắn tin hỗ trợ trực tiếp.</p>
                </div>
            }
        </div>

    </div>
</div>

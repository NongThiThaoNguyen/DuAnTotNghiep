@using DuAnTotNghiep.Models
@model DuAnTotNghiep.Models.User
@{
    ViewData["Title"] = "Tiến trình học viên - " + Model.FullName;
    var snapshots = ViewBag.ProgressSnapshots as List<StudentProgressSnapshot> ?? new List<StudentProgressSnapshot>();
    var pathNodes = ViewBag.PathNodes as List<LearningPathNode> ?? new List<LearningPathNode>();
    var activities = ViewBag.StudyActivities as List<StudyActivityLog> ?? new List<StudyActivityLog>();
    var avatar = string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName ?? "HV")}&background=6C63FF&color=fff" : Model.AvatarUrl;
}

<div class="max-w-7xl mx-auto py-8 px-4 font-sans space-y-8">
    
    <!-- Navigation back -->
    <div class="flex items-center justify-between border-b border-slate-100 pb-3">
        <a href="/Teacher/Students" class="text-xs font-bold text-slate-500 hover:text-purple-650 transition-colors flex items-center gap-1.5 no-modal">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách học viên
        </a>
    </div>

    <!-- Student Profile Header Card -->
    <div class="bg-white rounded-3xl border border-slate-200 shadow-md p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-start sm:items-center justify-between relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-purple-500 to-indigo-500"></div>
        <div class="flex items-center gap-5">
            <img src="@avatar" alt="Avatar" class="w-20 h-20 rounded-full object-cover ring-4 ring-purple-100 bg-slate-50 shadow-sm" onerror="this.src='https://ui-avatars.com/api/?name=HV&background=6C63FF&color=fff';" />
            <div class="space-y-1.5">
                <h1 class="text-2xl font-black text-slate-900 leading-tight">@Model.FullName</h1>
                <p class="text-slate-500 text-xs font-medium">Học viên hệ thống | Ngày gia nhập: @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                <div class="flex flex-wrap gap-2 pt-1">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded text-[10px] font-bold bg-purple-50 text-purple-700 border border-purple-100">
                        Email: @Model.Email
                    </span>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-100">
                        SĐT: @(Model.Phone ?? "N/A")
                    </span>
                </div>
            </div>
        </div>

        <div>
            <a href="/Teacher/Messages?studentId=@Model.Id" class="px-5 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-indigo-600 text-white font-bold transition-all text-xs flex items-center gap-1.5 shadow-md shadow-purple-500/15 hover:from-purple-600 hover:to-indigo-700 hover:-translate-y-0.5 duration-200 cursor-pointer no-modal">
                <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                Nhắn tin trao đổi
            </a>
        </div>
    </div>

    <!-- Main columns -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left: Learning Path & Activity Log -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- 1. Learning Path Current Status -->
            <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6 sm:p-8 space-y-5">
                <h3 class="text-base font-extrabold text-slate-900 border-b border-slate-100 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-route text-purple-500"></i>
                    Lộ trình học tập hiện tại
                </h3>
                
                <div class="space-y-4">
                    @if (!pathNodes.Any())
                    {
                        <p class="text-slate-400 text-xs py-8 text-center italic">Chưa cấu hình lộ trình học tập cho học viên này.</p>
                    }
                    @foreach (var node in pathNodes)
                    {
                        var statusColor = node.Status switch
                        {
                            "COMPLETED" => "bg-emerald-50 text-emerald-700 border-emerald-100",
                            "IN_PROGRESS" => "bg-blue-50 text-blue-700 border-blue-100",
                            _ => "bg-slate-50 text-slate-550 border-slate-150"
                        };

                        <div class="p-4 bg-slate-50/50 border border-slate-150 rounded-2xl flex items-center justify-between gap-4 hover:bg-slate-50 transition-colors">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-slate-800">@node.NodeTitle</span>
                                <span class="text-xs text-slate-500 mt-1">Chủ đề: @(node.Topic?.Title ?? "N/A") | Thời lượng: @node.EstimatedMinutes phút</span>
                            </div>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-[10px] font-bold border @statusColor">
                                @node.Status
                            </span>
                        </div>
                    }
                </div>
            </div>

            <!-- 2. Recent Study Activity Log -->
            <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6 sm:p-8 space-y-5">
                <h3 class="text-base font-extrabold text-slate-900 border-b border-slate-100 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-clock-rotate-left text-purple-500"></i>
                    Nhật ký học tập gần đây
                </h3>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="border-b border-slate-200 text-slate-450 text-xs font-bold uppercase tracking-wider">
                                <th class="py-3 px-4">Chủ đề</th>
                                <th class="py-3 px-4">Hoạt động</th>
                                <th class="py-3 px-4 text-center">Thời lượng</th>
                                <th class="py-3 px-4 text-center">Điểm số</th>
                                <th class="py-3 px-4 text-right">Ngày thực hiện</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @if (!activities.Any())
                            {
                                <tr>
                                    <td colspan="5" class="py-8 text-center text-slate-400 italic">Không có bản ghi hoạt động nào.</td>
                                </tr>
                            }
                            @foreach (var log in activities)
                            {
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="py-4 px-4 font-bold text-slate-800">@(log.Topic?.Title ?? "Tổng quát")</td>
                                    <td class="py-4 px-4">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-slate-100 text-slate-650 border border-slate-200">
                                            @log.ActivityType
                                        </span>
                                    </td>
                                    <td class="py-4 px-4 text-center text-slate-500">@log.DurationMinutes phút</td>
                                    <td class="py-4 px-4 text-center font-extrabold text-slate-800">@(log.Score?.ToString("0.0") ?? "-")đ</td>
                                    <td class="py-4 px-4 text-right text-slate-450 text-xs">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right: Periodic Snapshots -->
        <div class="space-y-8">
            
            <!-- Snapshot Progress Cards -->
            <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6 sm:p-8 space-y-5">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-3 flex items-center gap-1.5">
                    <i class="fa-solid fa-chart-line text-purple-500"></i>
                    Tiến trình định kỳ
                </h3>
                
                <div class="space-y-4">
                    @if (!snapshots.Any())
                    {
                        <p class="text-slate-400 text-xs py-8 text-center italic">Không có báo cáo snapshot tiến trình.</p>
                    }
                    @foreach (var snap in snapshots)
                    {
                        <div class="p-4 bg-slate-50/60 rounded-2xl border border-slate-150 flex flex-col gap-2.5 hover:bg-slate-50 transition-colors">
                            <div class="flex justify-between text-xs text-slate-500 font-bold border-b border-slate-100 pb-2">
                                <span class="flex items-center gap-1">
                                    <i class="fa-solid fa-calendar-day text-slate-400"></i>
                                    @snap.SnapshotDate.ToString("dd/MM/yyyy")
                                </span>
                                <span class="text-purple-650">Đạt @snap.ProgressPercent%</span>
                            </div>
                            <div class="grid grid-cols-2 gap-4 text-xs mt-1">
                                <div>
                                    <span class="text-slate-400 text-[10px] block font-bold uppercase tracking-wide">Số Node xong</span>
                                    <span class="font-bold text-slate-800 text-sm">@snap.CompletedNodes bài</span>
                                </div>
                                <div>
                                    <span class="text-slate-400 text-[10px] block font-bold uppercase tracking-wide">Điểm trung bình</span>
                                    <span class="font-extrabold text-emerald-600 text-sm">@(snap.AverageScore?.ToString("0.0") ?? "-")đ</span>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(snap.WeakPoints))
                            {
                                <div class="text-[10px] text-rose-700 bg-rose-50 p-2.5 rounded-xl border border-rose-100 mt-2 leading-relaxed">
                                    <span class="font-bold uppercase tracking-wider text-[9px] block mb-0.5">Điểm cần cải thiện:</span>
                                    @snap.WeakPoints
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

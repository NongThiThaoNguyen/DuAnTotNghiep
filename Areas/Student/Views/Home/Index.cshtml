                    </a>
                </div>
            </div>

            <!-- ==================== 4. AI RECOMMENDATION & 6. AI ANALYSIS ==================== -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <!-- AI Đề xuất (4) -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
                    <h3 class="font-extrabold text-slate-900 text-base flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        AI Đề xuất học tập
                    </h3>
                    
                    <div class="space-y-3">
                        <div class="bg-blue-50/50 border border-blue-100/50 p-3 rounded-xl">
                            <span class="block text-[9px] text-blue-500 font-bold uppercase mb-0.5">Hôm nay nên học gì</span>
                            <p class="text-xs text-blue-700 leading-normal font-semibold">Tập trung cải thiện kỹ năng còn yếu để tối ưu hóa lộ trình ôn thi.</p>
                        </div>
                        <div class="space-y-2.5 text-xs">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                                <span class="text-slate-500">Lesson đề xuất:</span>
                                <span class="font-bold text-slate-800 truncate flex-1 text-right">@(nextNode?.NodeTitle ?? "Ngữ pháp căn bản")</span>
                            </div>

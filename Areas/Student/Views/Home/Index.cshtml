@{
    ViewData["Title"] = "Dashboard Học Viên";
}

<div class="bg-white rounded-xl shadow-xs border border-slate-200 p-6">
    <h1 class="text-2xl font-bold text-slate-800 mb-4">Chào mừng đến với khu vực Học Viên</h1>
    <p class="text-slate-600 mb-6">Bạn đang xem giao diện dành riêng cho tài khoản Student.</p>
    
    <div class="flex gap-4">
        <a asp-action="EditLearningProfile" asp-controller="Profile" asp-area="Student" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">
            Cập nhật Hồ sơ học tập
        </a>
    </div>
</div>

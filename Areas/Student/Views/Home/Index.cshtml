                            <p class="text-slate-450 text-[9px] mt-0.5 max-w-[160px] leading-relaxed">AI đang tổng hợp và đánh giá năng lực của bạn.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- ==================== 7. BIỂU ĐỒ HỌC TẬP ==================== -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 sm:p-8 space-y-6">
                <h3 class="font-extrabold text-slate-900 text-lg flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2m0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2"></path></svg>
                    Biểu đồ học tập
                </h3>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div class="h-64 flex flex-col justify-between">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-wide block text-center mb-2">Tiến trình học tập</span>
                        <div class="relative flex-1">
                            <canvas id="progressChart"></canvas>
                        </div>
                    </div>
                    <div class="h-64 flex flex-col justify-between">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-wide block text-center mb-2">Thời gian tích lũy (Phút)</span>
                        <div class="relative flex-1">
                            <canvas id="timeChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ================= CỘT PHẢI (1/3 chiều rộng) ================= -->
        <div class="space-y-8">
            
            <!-- ==================== 5. PLACEMENT TEST ==================== -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
                <h3 class="font-extrabold text-slate-900 text-base flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                    Kiểm tra đầu vào (M6)
                </h3>

                @if (attempt != null)
                {
                    <div class="space-y-3.5 text-xs">
                        <div class="flex justify-between items-center py-1.5 border-b border-slate-50">
                            <span class="text-slate-500">Điểm số</span>
                            <span class="font-bold text-blue-600">@attempt.TotalScore điểm</span>
                        </div>
                        <div class="flex justify-between items-center py-1.5 border-b border-slate-50">
                            <span class="text-slate-500">Trình độ ước lượng</span>
                            <span class="font-bold text-slate-800">@(attempt.EstimatedLevel?.Name ?? "Chưa rõ")</span>
                        </div>
                        <div class="flex justify-between items-center py-1.5 border-b border-slate-50">
                            <span class="text-slate-500">Trạng thái</span>
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">
                                @attempt.Status
                            </span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 space-y-4">
                        <p class="text-xs text-slate-500 leading-relaxed">Bạn chưa hoàn thành bài kiểm tra đánh giá năng lực tiếng Anh đầu vào.</p>
                        <a href="/Student/PlacementTest/Intro" class="w-full text-center py-2.5 px-4 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs transition-colors shadow-sm block cursor-pointer">
                            Làm bài Placement Test
                        </a>
                    </div>
                }
            </div>

            <!-- ==================== 9. THÀNH TÍCH ==================== -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
                <h3 class="font-extrabold text-slate-900 text-base flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5a2 2 0 10-2 2h2zm-2 2h4v12a2 2 0 01-2 2H10a2 2 0 01-2-2V9zm-4 4h4M4 11h4m12 2h-4m4-2h-4"></path></svg>
                    Thành tích & Danh hiệu
                </h3>

                <div class="space-y-4">
                    <div class="flex items-center justify-between text-xs">
                        <span class="text-slate-550 font-bold text-slate-500 uppercase">Hạng học lực</span>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold @rankColor border">
                            @rankTier
                        </span>
                    </div>

                    <!-- Danh sách Huy hiệu đẹp -->
                    <div class="grid grid-cols-4 gap-2 pt-2 border-t border-slate-50">
                        <div class="flex flex-col items-center text-center opacity-100" title="Đã tích lũy >100 XP">
                            <span class="text-2xl">🌱</span>
                            <span class="text-[9px] font-bold text-slate-600 mt-1">Khởi đầu</span>
                        </div>
                        <div class="flex flex-col items-center text-center @(completedLessons >= 5 ? "opacity-100" : "opacity-35")" title="Hoàn thành 5 bài học">
                            <span class="text-2xl">📚</span>
                            <span class="text-[9px] font-bold text-slate-600 mt-1">Chăm chỉ</span>
                        </div>
                        <div class="flex flex-col items-center text-center @(completedQuizzes >= 3 ? "opacity-100" : "opacity-35")" title="Hoàn thành 3 bài Quiz">
                            <span class="text-2xl">⚡</span>
                            <span class="text-[9px] font-bold text-slate-600 mt-1">Bứt phá</span>
                        </div>
                        <div class="flex flex-col items-center text-center @(dashboard?.StreakDays >= 5 ? "opacity-100" : "opacity-35")" title="Học liên tục 5 ngày">
                            <span class="text-2xl">🔥</span>
                            <span class="text-[9px] font-bold text-slate-600 mt-1">Kiên trì</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ==================== 10. THÔNG BÁO ==================== -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
                <h3 class="font-extrabold text-slate-900 text-base flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    Thông báo mới
                </h3>

                <div class="space-y-3">
                    @if (notifications != null && notifications.Any())
                    {
                        foreach (var n in notifications)
                        {
                            <div class="p-3 rounded-xl bg-slate-50 border border-slate-100 hover:bg-slate-100/50 transition-all text-xs">
                                <div class="flex justify-between items-center mb-1">
                                    <span class="font-bold text-slate-800 leading-tight">@n.Title</span>
                                    <span class="text-[8px] text-slate-400">@n.CreatedAt.ToString("dd/MM")</span>
                                </div>
                                <p class="text-slate-500 leading-relaxed text-[11px]">@n.Content</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-xs text-slate-400 italic">
                            Chưa có thông báo nào được ghi nhận.
                        </div>
                    }
                </div>
            </div>

            <!-- ==================== 8. HOẠT ĐỘNG GẦN ĐÂY ==================== -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-5">
                <h3 class="font-extrabold text-slate-900 text-base flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Hoạt động gần đây
                </h3>

                @if (timeline != null && timeline.Any())
                {
                    <div class="relative border-l border-slate-100 ml-2 pl-4 space-y-4.5">
                        @foreach (var act in timeline)
                        {
                            string iconBg = "bg-slate-150 text-slate-500";
                            if (act.Type == "LESSON" || act.Type == "LEARN") iconBg = "bg-blue-50 text-blue-600 border-blue-100";
                            else if (act.Type == "QUIZ") iconBg = "bg-amber-50 text-amber-600 border-amber-100";
                            else if (act.Type == "PLACEMENT_TEST") iconBg = "bg-purple-50 text-purple-600 border-purple-100";
                            else if (act.Type == "AI_RECOMMENDATION") iconBg = "bg-emerald-50 text-emerald-600 border-emerald-100";

                            <div class="relative text-xs">
                                <div class="absolute -left-[25px] top-0.5 w-4 h-4 rounded-full border border-white shadow-sm @iconBg flex items-center justify-center text-[7px] font-bold">
                                    •
                                </div>
                                <div>
                                    <span class="text-[9px] text-slate-400 block font-semibold">@act.Time.ToString("dd/MM/yyyy HH:mm")</span>
                                    <h5 class="font-bold text-slate-800 leading-tight mt-0.5">@act.Title</h5>
                                    <p class="text-slate-500 text-[10px] mt-0.5">@act.Detail</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-xs text-slate-400 italic">
                        Chưa ghi nhận hoạt động nào.
                    </div>
                }
            </div>

            <!-- ==================== 11. MỤC TIÊU HỌC TẬP ==================== -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
                <h3 class="font-extrabold text-slate-900 text-base flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Mục tiêu học tập (M3)
                </h3>

                <div class="space-y-3 text-xs leading-normal">
                    <div>
                        <span class="block text-[9px] text-slate-400 font-bold uppercase mb-0.5">Mục tiêu</span>
                        <span class="text-slate-800 font-bold">@(profile?.MainGoal?.GoalName ?? "Chưa thiết lập mục tiêu")</span>
                    </div>
                    <div>
                        <span class="block text-[9px] text-slate-400 font-bold uppercase mb-0.5">Thời gian học cam kết</span>
                        <span class="text-slate-800 font-bold">@(profile?.DailyStudyMinutes ?? 30) phút/ngày · @(profile?.WeeklyStudyDays ?? 5) ngày/tuần</span>
                    </div>
                    <div>
                        <span class="block text-[9px] text-slate-400 font-bold uppercase mb-0.5">Buổi học rảnh</span>
                        <span class="text-slate-800 font-bold">Buổi @(profile?.PreferredStudyTime ?? "Tự do")</span>
                    </div>
                    <div>
                        <span class="block text-[9px] text-slate-400 font-bold uppercase mb-0.5">Phong cách học tập</span>
                        <span class="text-slate-800 font-bold">Luyện tập tương tác (AI Active Learning)</span>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

@section Scripts {

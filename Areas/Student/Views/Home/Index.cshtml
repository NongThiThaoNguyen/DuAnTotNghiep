            <div class="text-2xl font-black text-slate-800 mt-1">
                @(profile?.CurrentLevel?.Code ?? "N/A")
            </div>
            <span class="text-[10px] text-slate-500 mt-1 truncate">@(profile?.CurrentLevel?.Name ?? "Chưa xác định")</span>
        </div>
        <!-- Learning Progress -->

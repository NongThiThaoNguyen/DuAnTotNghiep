@using System.Security.Claims
@{
    ViewData["Title"] = "Tổng quan";
    var user = ViewBag.User as DuAnTotNghiep.Models.User;
    var profile = ViewBag.UserLearningProfile as DuAnTotNghiep.DTOs.Onboarding.LearningProfileDto;
    var path = ViewBag.LearningPath as DuAnTotNghiep.Models.StudentLearningPath;
    var attempt = ViewBag.LatestAttempt as DuAnTotNghiep.Models.TestAttempt;
    var analysis = ViewBag.LatestAnalysis as DuAnTotNghiep.Models.CompetencyAnalysis;
    var nextNode = ViewBag.NextNode as DuAnTotNghiep.Models.LearningPathNode;
    var preferredTopics = ViewBag.PreferredTopicsList as List<string>;

    int totalTopics = ViewBag.TotalTopics ?? 0;
    int completedTopics = ViewBag.CompletedTopics ?? 0;
    int inProgressTopics = ViewBag.InProgressTopics ?? 0;
    int unstartedTopics = ViewBag.UnstartedTopics ?? 0;

    var dashboard = ViewBag.ProgressDashboard as DuAnTotNghiep.ViewModels.Progress.ProgressDashboardViewModel;
    decimal avgQuizScore = ViewBag.AverageQuizScore ?? 0m;
    var timeline = ViewBag.Timeline as List<dynamic>;
    var notifications = ViewBag.NotificationsList as List<DuAnTotNghiep.Models.Notification>;

    // XP & Level calculations
    int studyMinutes = dashboard?.TotalStudyMinutes ?? 0;
    int completedLessons = dashboard?.CompletedLessonsCount ?? 0;
    int completedQuizzes = dashboard?.CompletedQuizzesCount ?? 0;
    int totalXp = studyMinutes * 10 + completedLessons * 50 + completedQuizzes * 100;
    int level = (totalXp / 1000) + 1;
    int xpInLevel = totalXp % 1000;

    // Rank Tier
    string rankTier = "Bronze";
    string rankColor = "text-amber-700 bg-amber-50 border-amber-100";
    if (totalXp >= 3000)
    {
        rankTier = "Gold";
        rankColor = "text-yellow-600 bg-yellow-50 border-yellow-100";
    }
    else if (totalXp >= 1000)
    {
        rankTier = "Silver";
        rankColor = "text-slate-500 bg-slate-50 border-slate-100";
    }

    double percent = totalTopics > 0 ? Math.Round((double)completedTopics / totalTopics * 100) : 0;

    // Greeting by time of day
    int hour = DateTime.Now.Hour;
    string timeGreeting = "Chào ngày mới";
    if (hour >= 5 && hour < 12) timeGreeting = "Chào buổi sáng";
    else if (hour >= 12 && hour < 18) timeGreeting = "Chào buổi chiều";
    else if (hour >= 18 && hour < 22) timeGreeting = "Chào buổi tối";
    else timeGreeting = "Chào đêm muộn";
}

<div class="max-w-7xl mx-auto py-6 px-4 font-sans space-y-8">
    
    <!-- ==================== 1. HEADER ==================== -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 sm:p-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">

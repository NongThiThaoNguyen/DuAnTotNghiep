                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">
                            Target @(profile.TargetLevel.Code)
                        </span>
                    }
                </div>
            </div>
        </div>
        
        <!-- Header Actions (Bên phải) -->
        <div class="flex items-center gap-2.5 w-full md:w-auto border-t md:border-t-0 pt-4 md:pt-0">
            <a href="/Student/Progress/History" class="p-2.5 rounded-xl border border-slate-200 text-slate-500 hover:text-blue-600 hover:bg-slate-50 transition-all flex items-center justify-center shrink-0 cursor-pointer" title="Lịch sử hoạt động">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </a>
            <a href="/Student/Profile/EditLearningProfile" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-750 hover:bg-slate-50 font-bold transition-all text-xs flex items-center gap-1.5 cursor-pointer">
                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                Hồ sơ
            </a>
            <a href="/Profile" class="px-4 py-2.5 rounded-xl bg-blue-600 text-white hover:bg-blue-700 font-bold transition-all text-xs flex items-center gap-1.5 shadow-sm shadow-blue-600/10 cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                Cài đặt
            </a>
        </div>
    </div>

    <!-- ==================== 2. THỐNG KÊ NHANH ==================== -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Placement Score -->
        <div class="bg-white p-4.5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between">

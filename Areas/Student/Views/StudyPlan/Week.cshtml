@model DuAnTotNghiep.Models.ViewModels.StudyPlan.WeeklyStudyPlanViewModel

@{
    ViewData["Title"] = "Kế hoạch tuần";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";

    var prevWeekStart = Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeekStart = Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd");
    var today = DateOnly.FromDateTime(DateTime.Today);
}

<link rel="stylesheet" href="~/css/studyplan.css" asp-append-version="true" />

<div class="container mx-auto">
    <!-- Header Page & Tab navigation -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Kế Hoạch Học Tập</h1>
            <p class="text-sm text-slate-500">Lộ trình: <span class="font-semibold text-slate-700">@Model.PathTitle</span></p>
        </div>
        
        <!-- Tab Navigation -->
        <div class="flex bg-slate-100 p-1.5 rounded-xl border border-slate-200 self-start md:self-center">
            <a href="@Url.Action("Today", "StudyPlan", new { area = "Student" })" class="px-4 py-2 text-xs font-semibold rounded-lg text-slate-600 hover:text-slate-800 hover:bg-slate-200/50">
                <i class="fa-solid fa-calendar-day mr-1"></i> Hôm nay
            </a>
            <a href="@Url.Action("Week", "StudyPlan", new { area = "Student" })" class="px-4 py-2 text-xs font-semibold rounded-lg bg-white text-slate-800 shadow-xs border border-slate-200">
                <i class="fa-solid fa-calendar-week mr-1 text-blue-600"></i> Tuần này
            </a>
            <a href="@Url.Action("Month", "StudyPlan", new { area = "Student" })" class="px-4 py-2 text-xs font-semibold rounded-lg text-slate-600 hover:text-slate-800 hover:bg-slate-200/50">
                <i class="fa-solid fa-calendar-days mr-1"></i> Tháng này
            </a>
        </div>
    </div>

    <!-- Week Navigation & Progress Bar -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm mb-6 space-y-6">
        <!-- Navigation Buttons -->
        <div class="flex items-center justify-between gap-4 flex-wrap">
            <div class="flex items-center gap-2">
                <a href="@Url.Action("Week", "StudyPlan", new { area = "Student", weekStart = prevWeekStart })" class="px-3.5 py-2 border border-slate-200 text-slate-600 font-semibold text-xs rounded-xl hover:bg-slate-50 transition-all flex items-center gap-1 cursor-pointer">
                    <i class="fa-solid fa-chevron-left text-[10px]"></i> Tuần trước
                </a>
                <a href="@Url.Action("Week", "StudyPlan", new { area = "Student", weekStart = nextWeekStart })" class="px-3.5 py-2 border border-slate-200 text-slate-600 font-semibold text-xs rounded-xl hover:bg-slate-50 transition-all flex items-center gap-1 cursor-pointer">
                    Tuần sau <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </a>
            </div>
            
            <h2 class="text-base font-bold text-slate-800 text-center order-first sm:order-none w-full sm:w-auto">
                Tuần: @Model.WeekStart.ToString("dd/MM/yyyy") — @Model.WeekEnd.ToString("dd/MM/yyyy")
            </h2>

            <a href="@Url.Action("Week", "StudyPlan", new { area = "Student" })" class="px-3.5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold text-xs rounded-xl transition-all flex items-center gap-1 cursor-pointer">
                Về tuần hiện tại
            </a>
        </div>

        <hr class="border-slate-100" />

        <!-- Weekly Progress Summary -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Left block: progress stats -->
            <div class="md:col-span-2">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-sm font-semibold text-slate-600">Tiến độ tuần này:</span>
                    <span class="text-sm font-bold text-blue-600">@Model.CompletionPercent% (@Model.CompletedTasks/@Model.TotalTasks nhiệm vụ)</span>
                </div>
                <div class="w-full bg-slate-100 rounded-full h-3">
                    <div class="bg-blue-600 h-3 rounded-full transition-all duration-500" style="width: @Model.CompletionPercent%"></div>
                </div>
            </div>

            <!-- Right block: duration statistics -->
            <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 flex items-center justify-around text-center gap-4">
                <div>
                    <span class="block text-xl font-extrabold text-slate-700">@Model.TotalMinutes</span>
                    <span class="text-[10px] uppercase font-bold text-slate-400">Tổng số phút</span>
                </div>
                <div class="border-l border-slate-200 h-8"></div>
                <div>
                    <span class="block text-xl font-extrabold text-rose-500">@Model.OverdueTasks</span>
                    <span class="text-[10px] uppercase font-bold text-slate-400">Quá hạn</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Weekly Timeline -->
    <div class="space-y-6">
        @foreach (var day in Model.DayGroups)
        {
            var isDayToday = (day.Date == today);
            
            <div class="bg-white rounded-2xl border @(isDayToday ? "border-blue-400 shadow-md" : "border-slate-200 shadow-sm") p-5 transition-all">
                <!-- Day Header -->
                <div class="flex items-center justify-between border-b border-slate-100 pb-3 mb-4">
                    <div class="flex items-center gap-2">
                        <h3 class="text-base font-bold @(isDayToday ? "text-blue-600" : "text-slate-800")">
                            @day.DayLabel
                        </h3>
                        @if (isDayToday)
                        {
                            <span class="px-2 py-0.5 text-[9px] font-bold bg-blue-100 text-blue-700 rounded-full">TODAY</span>
                        }
                    </div>
                    <span class="text-xs font-semibold text-slate-500">
                        <i class="fa-regular fa-clock mr-1"></i> @day.TotalMinutes phút học
                    </span>
                </div>

                <!-- Daily Tasks -->
                @if (!day.Tasks.Any())
                {
                    <p class="text-xs text-slate-400 italic py-2">
                        <i class="fa-regular fa-calendar-minus mr-1"></i> Không có nhiệm vụ lập lịch trong ngày này.
                    </p>
                }
                else
                {
                    <div class="space-y-1">
                        @foreach (var task in day.Tasks)
                        {
                            <partial name="_DailyTaskCard" model="task" />
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Include Skip Modal inside Today.cshtml but to allow trigger from here, we will render it at bottom -->
<div id="skipModal" class="fixed inset-0 z-[100] flex items-center justify-center hidden bg-slate-950/40 backdrop-blur-xs">
    <div class="bg-white rounded-2xl border border-slate-200 w-full max-w-md p-6 shadow-xl mx-4 transform transition-all">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-slate-800">Bỏ qua nhiệm vụ học tập</h3>
            <button type="button" onclick="closeSkipModal()" class="text-slate-400 hover:text-slate-600 cursor-pointer">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        
        <form id="skipForm" method="post" action="@Url.Action("SkipTask", "StudyPlan", new { area = "Student" })">
            @Html.AntiForgeryToken()
            <input type="hidden" name="nodeId" id="skipNodeId" value="" />
            
            <p class="text-sm text-slate-600 mb-4">
                Bạn đang chuẩn bị bỏ qua nhiệm vụ: <strong id="skipTaskTitle" class="text-slate-800"></strong>.
                Hệ thống sẽ dời tiến độ bài này. Vui lòng cho biết lý do để tối ưu hóa lộ trình của AI sau này:
            </p>

            <div class="mb-5">
                <label for="reason" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Lý do bỏ qua</label>
                <textarea name="reason" id="reason" rows="3" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 placeholder-slate-400" placeholder="Ví dụ: Bận đột xuất, Kiến thức này đã vững, Muốn học kỹ năng khác trước..."></textarea>
            </div>

            <div class="flex justify-end gap-3">
                <button type="button" onclick="closeSkipModal()" class="px-4 py-2 border border-slate-200 text-slate-600 font-medium text-xs rounded-xl hover:bg-slate-50 transition-all cursor-pointer">
                    Hủy bỏ
                </button>
                <button type="submit" class="px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white font-medium text-xs rounded-xl shadow-sm hover:shadow transition-all cursor-pointer">
                    Xác nhận bỏ qua
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openSkipModal(nodeId, title) {
        document.getElementById('skipNodeId').value = nodeId;
        document.getElementById('skipTaskTitle').innerText = title;
        
        const modal = document.getElementById('skipModal');
        modal.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
    }

    function closeSkipModal() {
        const modal = document.getElementById('skipModal');
        modal.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
        document.getElementById('skipForm').reset();
    }
</script>

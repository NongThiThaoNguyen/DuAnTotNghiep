@model List<DuAnTotNghiep.ViewModels.Progress.LearningHistoryItemViewModel>
@{
    ViewData["Title"] = "Lịch sử học tập";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
}

<div class="space-y-6 animate-fade-in">
    <!-- Breadcrumb & Title -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="space-y-1">
            <h1 class="text-3xl font-bold tracking-tight text-slate-800">Lịch sử học tập</h1>
            <p class="text-xs text-slate-500">Xem lại chi tiết tất cả các hoạt động học tập của bạn trên hệ thống</p>
        </div>
        
        <a asp-action="Index" asp-controller="Progress" asp-area="Student" asp-route-studentId="@ViewBag.TargetStudentId" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-sm font-semibold rounded-xl text-slate-700 bg-white hover:bg-slate-50 shadow-2xs transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Quay lại Dashboard
        </a>
    </div>

    <!-- History list -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-2xs overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex flex-col xl:flex-row xl:items-center justify-between gap-4">
            <div>
                <h3 class="font-bold text-slate-800">Dòng thời gian hoạt động</h3>
                <p class="text-xs text-slate-500 mt-1">Hiển thị tối đa @pageSize hoạt động mỗi trang</p>
            </div>
            
            <form method="get" asp-action="History" asp-controller="Progress" asp-area="Student" class="flex flex-wrap items-center gap-3">
                <input type="hidden" name="studentId" value="@ViewBag.TargetStudentId" />
                <div class="flex items-center gap-2">
                    <input type="date" name="startDate" value="@ViewBag.StartDate" class="bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-xs font-semibold text-slate-700 outline-hidden focus:border-indigo-500 focus:bg-white transition-all" />
                    <span class="text-xs text-slate-400">đến</span>
                    <input type="date" name="endDate" value="@ViewBag.EndDate" class="bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-xs font-semibold text-slate-700 outline-hidden focus:border-indigo-500 focus:bg-white transition-all" />
                </div>
                
                <select name="activityType" class="bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-xs font-semibold text-slate-700 outline-hidden focus:border-indigo-500 focus:bg-white transition-all">
                    <option value="" selected="@(string.IsNullOrEmpty(ViewBag.ActivityType))">Tất cả hoạt động</option>
                    <option value="LEARN" selected="@(ViewBag.ActivityType == "LEARN")">Học tập (LEARN)</option>
                    <option value="QUIZ" selected="@(ViewBag.ActivityType == "QUIZ")">Bài tập (QUIZ)</option>
                    <option value="PRACTICE" selected="@(ViewBag.ActivityType == "PRACTICE")">Luyện tập (PRACTICE)</option>
                    <option value="CHAT" selected="@(ViewBag.ActivityType == "CHAT")">Hỏi đáp AI (CHAT)</option>
                    <option value="REVIEW" selected="@(ViewBag.ActivityType == "REVIEW")">Ôn tập (REVIEW)</option>
                </select>

                <button type="submit" class="inline-flex items-center justify-center px-4 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-xs font-bold text-white rounded-xl shadow-2xs transition-colors">Lọc</button>
            </form>
        </div>

        @if (Model.Any())
        {
            <div class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    var iconColor = item.ActivityType == "LEARN" ? "bg-blue-100 text-blue-600" :
                                    item.ActivityType == "QUIZ" ? "bg-emerald-100 text-emerald-600" :
                                    item.ActivityType == "PRACTICE" ? "bg-purple-100 text-purple-600" :
                                    item.ActivityType == "CHAT" ? "bg-amber-100 text-amber-600" :
                                    item.ActivityType == "REVIEW" ? "bg-rose-100 text-rose-600" :
                                    "bg-slate-100 text-slate-600";

                    <div class="p-6 flex flex-col sm:flex-row sm:items-center gap-4 justify-between hover:bg-slate-50/50 transition-colors">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 rounded-full shrink-0 flex items-center justify-center font-bold text-sm @iconColor shadow-2xs">
                                @item.ActivityType.Substring(0, 1)
                            </div>
                            <div class="space-y-1">
                                <h4 class="font-bold text-slate-800 text-base">@item.Title</h4>
                                <div class="flex flex-wrap items-center gap-3 text-xs text-slate-500">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-sm bg-slate-100 text-[10px] font-bold text-slate-500 uppercase tracking-wider">@item.ActivityType</span>
                                    @if (item.DurationMinutes.HasValue)
                                    {
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                            @item.DurationMinutes.Value phút
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.MetadataJson))
                                    {
                                        <span class="text-slate-400 italic text-[11px] truncate max-w-xs" title="@item.MetadataJson">(@item.MetadataJson)</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="flex sm:flex-col items-center sm:items-end justify-between sm:justify-center gap-2 mt-2 sm:mt-0 pt-3 sm:pt-0 border-t border-slate-100 sm:border-0">
                            <span class="text-xs text-slate-400">@item.ActivityDate.ToString("dd/MM/yyyy HH:mm")</span>
                            
                            @if (item.Score.HasValue)
                            {
                                var scoreClass = item.Score.Value >= 8.0m ? "text-emerald-600 bg-emerald-50 border-emerald-100" :
                                                 item.Score.Value >= 5.0m ? "text-amber-600 bg-amber-50 border-amber-100" :
                                                 "text-rose-600 bg-rose-50 border-rose-100";

                                <span class="px-2 py-0.5 rounded-md text-xs font-bold border @scoreClass">
                                    Điểm: @item.Score.Value/10
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Simple Pagination Controls -->
            <div class="p-6 bg-slate-50/50 border-t border-slate-100 flex items-center justify-between">
                <div>
                    <span class="text-xs text-slate-500">Trang hiện tại: <strong>@currentPage</strong></span>
                </div>
                
                <div class="flex gap-2">
                    @if (currentPage > 1)
                    {
                        <a asp-action="History" asp-route-page="@(currentPage - 1)" asp-route-activityType="@ViewBag.ActivityType" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" asp-route-studentId="@ViewBag.TargetStudentId" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-xs font-semibold rounded-xl text-slate-700 bg-white hover:bg-slate-50 shadow-2xs transition-colors">
                            Trang trước
                        </a>
                    }
                    else
                    {
                        <span class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 text-xs font-semibold rounded-xl text-slate-300 bg-slate-50 cursor-not-allowed">
                            Trang trước
                        </span>
                    }

                    @if (Model.Count == pageSize)
                    {
                        <a asp-action="History" asp-route-page="@(currentPage + 1)" asp-route-activityType="@ViewBag.ActivityType" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" asp-route-studentId="@ViewBag.TargetStudentId" class="inline-flex items-center justify-center px-4 py-2 border border-slate-300 text-xs font-semibold rounded-xl text-slate-700 bg-white hover:bg-slate-50 shadow-2xs transition-colors">
                            Trang sau
                        </a>
                    }
                    else
                    {
                        <span class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 text-xs font-semibold rounded-xl text-slate-300 bg-slate-50 cursor-not-allowed">
                            Trang sau
                        </span>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-16 text-slate-400 text-sm">
                Không tìm thấy hoạt động nào phù hợp với bộ lọc đã chọn.
            </div>
        }
    </div>
</div>

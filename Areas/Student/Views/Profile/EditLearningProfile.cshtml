@model DuAnTotNghiep.ViewModels.Onboarding.UpdateLearningProfileViewModel
@{
    ViewData["Title"] = "Cập nhật hồ sơ học tập";
    var goals = ViewBag.Goals as IEnumerable<DuAnTotNghiep.DTOs.Onboarding.GoalDto>;
    var levels = ViewBag.Levels as IEnumerable<DuAnTotNghiep.DTOs.Onboarding.LevelDto>;
    var skills = ViewBag.Skills as IEnumerable<DuAnTotNghiep.DTOs.Onboarding.SkillDto>;
    var currentGoalId = Model.MainGoalId?.ToString() ?? "";
}

<div class="max-w-4xl mx-auto py-8">
    <div class="mb-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-2">Hồ sơ học tập</h2>
        <p class="text-slate-500">Cập nhật mục tiêu, trình độ và kỹ năng ưu tiên để AI điều chỉnh lộ trình học phù hợp nhất.</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 text-red-600 p-4 rounded-xl mb-6 border border-red-100">
            @TempData["ErrorMessage"]
        </div>
    }

    <div id="goalChangeWarning" class="hidden bg-amber-50 rounded-2xl p-6 border border-amber-200 mb-8 shadow-sm">
        <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div>
                <h4 class="font-bold text-amber-800 text-lg mb-1">Lưu ý thay đổi mục tiêu</h4>
                <p class="text-amber-700">Việc thay đổi mục tiêu học tập có thể khiến lộ trình học hiện tại không còn phù hợp. Bạn có thể cần đánh giá lại năng lực hoặc tạo Learning Path mới.</p>
            </div>
        </div>
    </div>

    <form method="post" asp-action="EditLearningProfile" class="space-y-8">
        @Html.AntiForgeryToken()
        
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 text-red-600 p-4 rounded-xl border border-red-100">
                <div asp-validation-summary="ModelOnly" class="font-medium list-none"></div>
            </div>
        }

        <!-- Mục tiêu học tập -->
        <div class="bg-white shadow-sm rounded-2xl p-6 md:p-8 border border-slate-200">
            <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-sm">1</span>
                Mục tiêu học tập
            </h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @if (goals != null)
                {
                    foreach (var goal in goals)
                    {
                        <label class="cursor-pointer block relative">
                            <input type="radio" asp-for="MainGoalId" value="@goal.Id" class="hidden peer goal-radio" data-initial="@currentGoalId" />
                            <div class="h-full rounded-xl p-4 border-2 border-slate-100 bg-white hover:border-blue-200 hover:bg-slate-50 transition-all peer-checked:border-blue-600 peer-checked:bg-blue-50">
                                <h6 class="font-bold text-slate-800 mb-1 peer-checked:text-blue-700">@goal.GoalName</h6>
                                <p class="text-slate-500 text-sm">@goal.Description</p>
                            </div>
                        </label>
                    }
                }
            </div>
            <span asp-validation-for="MainGoalId" class="text-red-500 text-sm mt-2 block"></span>
        </div>

        <!-- Trình độ hiện tại & Mục tiêu -->
        <div class="bg-white shadow-sm rounded-2xl p-6 md:p-8 border border-slate-200">
            <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-sm">2</span>
                Trình độ & Điểm số
            </h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Trình độ hiện tại</label>
                    <select asp-for="CurrentLevelId" class="w-full rounded-xl border-slate-200 p-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-colors">
                        <option value="">-- Chọn trình độ hiện tại --</option>
                        @if (levels != null)
                        {
                            foreach (var level in levels)
                            {
                                <option value="@level.Id">@level.Code - @level.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CurrentLevelId" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div id="targetScoreContainer">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Điểm mục tiêu (Nếu có)</label>
                    <input type="number" step="0.5" asp-for="TargetScore" class="w-full rounded-xl border-slate-200 p-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-colors" placeholder="Ví dụ: 6.5" />
                    <span asp-validation-for="TargetScore" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>
        </div>

        <!-- Kỹ năng ưu tiên -->
        <div class="bg-white shadow-sm rounded-2xl p-6 md:p-8 border border-slate-200">
            <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-sm">3</span>
                Kỹ năng ưu tiên cải thiện
            </h3>
            
            <div class="flex flex-wrap gap-3">
                @if (skills != null)
                {
                    foreach (var skill in skills)
                    {
                        bool isChecked = Model.SelectedSkillCodes.Contains(skill.SkillCode);
                        <label class="cursor-pointer relative inline-block">
                            <input type="checkbox" name="SelectedSkillCodes" value="@skill.SkillCode" class="hidden peer" @(isChecked ? "checked" : "") />
                            <div class="px-5 py-2.5 rounded-full border-2 border-slate-200 bg-white text-slate-600 font-medium hover:bg-slate-50 transition-all peer-checked:border-blue-600 peer-checked:bg-blue-600 peer-checked:text-white">
                                @skill.SkillName
                            </div>
                        </label>
                    }
                }
            </div>
            <span asp-validation-for="SelectedSkillCodes" class="text-red-500 text-sm mt-2 block"></span>
        </div>

        <!-- Thời gian học -->
        <div class="bg-white shadow-sm rounded-2xl p-6 md:p-8 border border-slate-200">
            <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-sm">4</span>
                Quỹ thời gian học
            </h3>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Phút/Ngày</label>
                    <input type="number" asp-for="DailyStudyMinutes" class="w-full rounded-xl border-slate-200 p-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-colors" placeholder="30" />
                    <span asp-validation-for="DailyStudyMinutes" class="text-red-500 text-sm mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Ngày/Tuần</label>
                    <input type="number" asp-for="WeeklyStudyDays" class="w-full rounded-xl border-slate-200 p-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-colors" placeholder="5" />
                    <span asp-validation-for="WeeklyStudyDays" class="text-red-500 text-sm mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Khung giờ rảnh</label>
                    <select asp-for="PreferredStudyTime" class="w-full rounded-xl border-slate-200 p-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-colors">
                        <option value="">-- Chọn buổi --</option>
                        <option value="Sáng">Buổi sáng</option>
                        <option value="Trưa">Buổi trưa</option>
                        <option value="Chiều">Buổi chiều</option>
                        <option value="Tối">Buổi tối</option>
                    </select>
                    <span asp-validation-for="PreferredStudyTime" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>
            
            <div class="mt-6">
                <label class="block text-sm font-bold text-slate-700 mb-2">Ghi chú thêm (Tùy chọn)</label>
                <textarea asp-for="LearningNote" rows="3" class="w-full rounded-xl border-slate-200 p-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-colors" placeholder="Bạn có lưu ý gì thêm về cách học không?"></textarea>
            </div>
        </div>

        <div class="flex justify-end gap-4 pt-4 border-t border-slate-200">
            <a asp-action="Index" asp-controller="Home" class="px-6 py-3 rounded-xl border border-slate-300 text-slate-600 font-medium hover:bg-slate-50 transition-colors">
                Hủy thay đổi
            </a>
            <button type="submit" class="px-8 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 shadow-lg shadow-blue-600/30 transition-all">
                Lưu hồ sơ
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const initialGoalId = '@currentGoalId';
            const goalRadios = document.querySelectorAll('.goal-radio');
            const warningBox = document.getElementById('goalChangeWarning');

            goalRadios.forEach(radio => {
                radio.addEventListener('change', function () {
                    if (this.checked && this.value !== initialGoalId) {
                        warningBox.classList.remove('hidden');
                    } else {
                        warningBox.classList.add('hidden');
                    }
                });
            });
        });
    </script>
}

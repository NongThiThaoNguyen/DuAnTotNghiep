@model DuAnTotNghiep.Models.ViewModels.Onboarding.OnboardingStep4ViewModel
@{
    ViewData["Title"] = "Thời gian học tập";
    var goalCode = ViewBag.GoalCode as string ?? "";
}

<style>
    .time-radio:checked + .time-card-body {
        border-color: #3b82f6 !important;
        background-color: #eff6ff !important;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.2);
    }
    .time-card-body {
        transition: all 0.2s ease-in-out;
        border: 2px solid #e2e8f0;
    }
    .time-card-body:hover {
        border-color: #bfdbfe;
    }
    .time-radio:checked + .time-card-body .time-badge {
        background-color: #3b82f6;
        color: #ffffff;
    }
</style>

<div class="max-w-3xl mx-auto py-12">
    
    <partial name="_OnboardingStepper" model="4" />

    <div class="bg-white shadow-xl shadow-slate-200/50 rounded-2xl p-8 md:p-12 border border-slate-100">
        
        <form method="post" asp-action="StudyTime">
            @Html.AntiForgeryToken()
            <input type="hidden" id="goalCode" value="@goalCode" />

            <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4 text-sm font-medium"></div>

            <h3 class="text-3xl font-bold mb-4 text-center text-slate-800">Thời gian học tập</h3>
            <p class="text-slate-500 text-center mb-10">Hãy cho AI biết bạn có thể dành bao nhiêu thời gian cho việc học, để chúng tôi xây dựng lịch học thực tế nhất.</p>

            <!-- Thời lượng học -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                <div>
                    <label asp-for="DailyStudyMinutes" class="block font-bold text-slate-700 mb-2">Số phút học mỗi ngày</label>
                    <div class="relative">
                        <input asp-for="DailyStudyMinutes" id="dailyMinutes" class="block w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 transition-colors text-lg" type="number" min="10" max="240" step="5" placeholder="VD: 30" />
                        <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none text-slate-500 font-medium">
                            phút
                        </div>
                    </div>
                    <span asp-validation-for="DailyStudyMinutes" class="text-red-500 text-sm mt-2 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="WeeklyStudyDays" class="block font-bold text-slate-700 mb-2">Số ngày học mỗi tuần</label>
                    <div class="relative">
                        <input asp-for="WeeklyStudyDays" id="weeklyDays" class="block w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 transition-colors text-lg" type="number" min="1" max="7" step="1" placeholder="VD: 5" />
                        <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none text-slate-500 font-medium">
                            ngày
                        </div>
                    </div>
                    <span asp-validation-for="WeeklyStudyDays" class="text-red-500 text-sm mt-2 block font-medium"></span>
                </div>
            </div>

            <!-- Suggestion / Warning Box -->
            <div id="estimateBox" class="hidden mb-10 p-6 rounded-2xl border transition-all duration-300">
                <div class="flex items-start gap-4">
                    <div id="estimateIcon" class="mt-1">
                        <!-- Icon will be injected by JS -->
                    </div>
                    <div>
                        <h4 class="font-bold text-lg mb-1" id="estimateTitle">Dự kiến thời gian học</h4>
                        <p class="text-slate-700 mb-2">Với cấu hình này, bạn sẽ học khoảng <strong id="estimateMinutes" class="text-blue-600 text-xl">0</strong> phút mỗi tuần.</p>
                        <p id="estimateWarning" class="text-sm font-medium hidden"></p>
                    </div>
                </div>
            </div>

            <hr class="border-slate-200 mb-10" />

            <!-- Khung giờ ưu tiên -->
            <h3 class="text-xl font-bold mb-4 text-slate-800">Khung giờ học ưu tiên</h3>
            <p class="text-slate-500 mb-6">Bạn thích học vào khoảng thời gian nào nhất trong ngày?</p>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                @if (ViewBag.PreferredStudyTimes != null)
                {
                    foreach (var time in ViewBag.PreferredStudyTimes)
                    {
                        <label class="cursor-pointer block relative">
                            <input type="radio" asp-for="PreferredStudyTime" value="@time" class="hidden time-radio" />
                            <div class="time-card-body h-full rounded-2xl p-4 bg-white flex flex-col items-center justify-center text-center">
                                <div class="time-badge w-12 h-12 rounded-full bg-slate-100 text-slate-500 flex items-center justify-center text-xl mb-3 transition-colors">
                                    @if (time == "Sáng") { <text>🌅</text> }
                                    else if (time == "Trưa") { <text>☀️</text> }
                                    else if (time == "Chiều") { <text>☕</text> }
                                    else if (time == "Tối") { <text>🌙</text> }
                                </div>
                                <h6 class="font-bold text-slate-800">@time</h6>
                            </div>
                        </label>
                    }
                }
            </div>
            <span asp-validation-for="PreferredStudyTime" class="text-red-500 text-sm block font-medium mb-10 text-center"></span>

            <div class="flex items-center justify-between mt-12 pt-6 border-t border-slate-100">
                <a asp-action="Skills" class="px-6 py-3 rounded-xl border border-slate-300 text-slate-600 font-medium hover:bg-slate-50 transition-colors">Quay lại</a>
                <button type="submit" class="px-8 py-3 rounded-xl bg-blue-600 text-white font-medium hover:bg-blue-700 shadow-lg shadow-blue-600/30 transition-all flex items-center gap-2">
                    Tiếp tục
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const dailyInput = document.getElementById("dailyMinutes");
            const weeklyInput = document.getElementById("weeklyDays");
            const estimateBox = document.getElementById("estimateBox");
            const estimateMinutes = document.getElementById("estimateMinutes");
            const estimateWarning = document.getElementById("estimateWarning");
            const estimateIcon = document.getElementById("estimateIcon");
            const goalCode = document.getElementById("goalCode").value;

            function calculateEstimate() {
                const daily = parseInt(dailyInput.value) || 0;
                const weekly = parseInt(weeklyInput.value) || 0;

                if (daily > 0 && weekly > 0) {
                    const total = daily * weekly;
                    estimateMinutes.textContent = total;
                    
                    // Show box
                    estimateBox.classList.remove("hidden");
                    
                    // Check logic for warning
                    let isWarning = false;
                    
                    // Logic cảnh báo nếu học quá ít so với mục tiêu cao (VD IELTS/TOEIC)
                    if ((goalCode === "IELTS" || goalCode === "TOEIC") && total < 150) {
                        isWarning = true;
                    }

                    if (isWarning) {
                        estimateBox.classList.add("bg-amber-50", "border-amber-200");
                        estimateBox.classList.remove("bg-blue-50", "border-blue-200");
                        estimateWarning.textContent = "Mục tiêu hiện tại có thể cần nhiều thời gian học hơn. Bạn nên cân nhắc tăng số phút học hoặc số ngày học để AI có thể lập lộ trình hiệu quả.";
                        estimateWarning.classList.remove("hidden");
                        estimateWarning.classList.add("text-amber-700");
                        estimateIcon.innerHTML = `<svg class="w-8 h-8 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>`;
                    } else {
                        estimateBox.classList.remove("bg-amber-50", "border-amber-200");
                        estimateBox.classList.add("bg-blue-50", "border-blue-200");
                        estimateWarning.classList.add("hidden");
                        estimateIcon.innerHTML = `<svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
                    }
                } else {
                    estimateBox.classList.add("hidden");
                }
            }

            dailyInput.addEventListener("input", calculateEstimate);
            weeklyInput.addEventListener("input", calculateEstimate);
            
            // Run on load if values exist
            calculateEstimate();

            document.querySelector('form').addEventListener('submit', function (e) {
                if ($(this).valid()) {
                    var btn = this.querySelector('button[type="submit"]');
                    btn.disabled = true;
                    btn.innerHTML = 'Đang lưu... <svg class="animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
                    btn.classList.add('opacity-75', 'cursor-not-allowed');
                }
            });
        });
    </script>
}

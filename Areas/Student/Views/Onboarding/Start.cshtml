@{
    ViewData["Title"] = "Chào mừng bạn đến với AI Study English";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 fw-bold text-primary mb-4">Chào mừng đến với hệ thống!</h1>
            <p class="lead text-muted mb-5">Để AI có thể thiết kế lộ trình học cá nhân hóa tốt nhất cho bạn, chúng ta hãy cùng nhau hoàn thiện hồ sơ học tập nhé. Sẽ chỉ mất khoảng 2 phút thôi!</p>
            
            <img src="/images/illustrations/onboarding-start.svg" alt="Welcome Illustration" class="img-fluid mb-5" style="max-height: 300px; object-fit: contain;" onerror="this.src='https://placehold.co/600x300/e9ecef/495057?text=Welcome+to+AI+Study+English'" />

            <div>
                <a asp-area="Student" asp-controller="Onboarding" asp-action="Goal" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">Bắt đầu ngay <i class="bi bi-arrow-right ms-2"></i></a>
            </div>
        </div>
    </div>
</div>

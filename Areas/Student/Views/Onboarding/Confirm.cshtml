@model DuAnTotNghiep.DTOs.Onboarding.LearningProfileDto
@{
    ViewData["Title"] = "Xác nhận hồ sơ";
    var isScoreBased = Model.MainGoal?.GoalCode == "IELTS" || Model.MainGoal?.GoalCode == "TOEIC";
}

<div class="max-w-4xl mx-auto py-12">
    <!-- Progress Indicator -->
    <partial name="_OnboardingStepper" model="5" />

    <div class="bg-white shadow-xl shadow-slate-200/50 rounded-2xl p-8 md:p-12 border border-slate-100">
        
        <div class="text-center mb-12">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h2 class="text-3xl font-bold text-slate-800 mb-4">Hồ sơ học tập của bạn đã sẵn sàng!</h2>
            <p class="text-slate-500">Hãy kiểm tra lại thông tin trước khi AI xây dựng lộ trình học tập cá nhân hóa dành riêng cho bạn.</p>
        </div>

        <!-- Profile Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
            
            <!-- Goal & Level -->
            <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
                <h4 class="font-bold text-slate-800 text-lg mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Mục tiêu & Trình độ
                </h4>
                
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-slate-500 mb-1">Mục tiêu chính</p>
                        <p class="font-semibold text-slate-800">@Model.MainGoal?.GoalName</p>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm text-slate-500 mb-1">Hiện tại</p>
                            <span class="inline-block px-3 py-1 bg-slate-200 text-slate-700 rounded-full text-sm font-medium">
                                @(Model.CurrentLevel?.Code ?? "Chưa đánh giá")
                            </span>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 mb-1">Mục tiêu</p>
                            <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-bold">
                                @if (isScoreBased)
                                {
                                    @($"{Model.MainGoal?.GoalCode} {Model.TargetScore}")
                                }
                                else
                                {
                                    @(Model.TargetLevel?.Code ?? "Không có")
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Study Time & Skills -->
            <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
                <h4 class="font-bold text-slate-800 text-lg mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Thời gian & Kỹ năng
                </h4>
                
                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm text-slate-500 mb-1">Tần suất học</p>
                            <p class="font-semibold text-slate-800">
                                @Model.DailyStudyMinutes phút/ngày<br/>
                                <span class="text-sm text-slate-500 font-normal">@Model.WeeklyStudyDays ngày/tuần</span>
                            </p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 mb-1">Khung giờ</p>
                            <p class="font-semibold text-slate-800">@Model.PreferredStudyTime</p>
                        </div>
                    </div>

                    <div>
                        <p class="text-sm text-slate-500 mb-2">Kỹ năng ưu tiên</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var skill in Model.PrioritySkills)
                            {
                                <span class="px-3 py-1 bg-white border border-slate-200 text-slate-700 rounded-full text-sm">
                                    @skill.SkillName
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(Model.LearningNote))
        {
            <div class="bg-amber-50 rounded-2xl p-6 border border-amber-100 mb-12">
                <h4 class="font-bold text-amber-800 text-lg mb-2 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Ghi chú học tập
                </h4>
                <p class="text-slate-700">@Model.LearningNote</p>
            </div>
        }

        <!-- Submit Form -->
        <form method="post" asp-action="Complete">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 text-red-600 p-4 rounded-xl mb-6 border border-red-100 flex items-center gap-3 justify-center">
                    <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                    <div asp-validation-summary="ModelOnly" class="font-medium font-bold"></div>
                </div>
            }
            <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-8 pt-8 border-t border-slate-100">
                <a asp-action="StudyTime" class="w-full sm:w-auto text-center px-6 py-3 rounded-xl border border-slate-300 text-slate-600 font-medium hover:bg-slate-50 transition-colors">
                    Chỉnh sửa thông tin
                </a>
                
                <button type="submit" class="w-full sm:w-auto px-8 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 shadow-lg shadow-blue-600/30 transition-all flex items-center justify-center gap-2">
                    Xác nhận & Bắt đầu học
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('form').addEventListener('submit', function (e) {
            if ($(this).valid()) {
                var btn = this.querySelector('button[type="submit"]');
                btn.disabled = true;
                btn.innerHTML = 'Đang xử lý... <svg class="animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
                btn.classList.add('opacity-75', 'cursor-not-allowed');
            }
        });
    </script>
}

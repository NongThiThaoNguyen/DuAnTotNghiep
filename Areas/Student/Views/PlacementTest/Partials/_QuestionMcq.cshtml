@model DuAnTotNghiep.ViewModels.PlacementTest.TestQuestionViewModel

<div class="mb-4">
    <p class="font-medium text-slate-800 text-lg mb-3">@Html.Raw(Model.QuestionText)</p>
    
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="Question Image" class="max-w-full h-auto mb-4 rounded shadow-sm" />
    }

    <div class="space-y-2 mt-2">
        @foreach (var option in Model.Options)
        {
            var isChecked = (Model.ExistingAnswer == option.Id.ToString()) ? "checked" : "";

            <label class="relative flex cursor-pointer rounded-lg border bg-white p-4 shadow-sm focus:outline-none 
                          border-slate-300 hover:border-indigo-400 has-[:checked]:border-indigo-600 has-[:checked]:ring-1 has-[:checked]:ring-indigo-600">
                <input type="radio" name="answers[@Model.QuestionId]" value="@option.Id" class="sr-only" @isChecked>
                <span class="flex flex-1">
                    <span class="flex flex-col">
                        <span class="block text-sm font-medium text-slate-900">@option.Text</span>
                    </span>
                </span>
                <svg class="h-5 w-5 text-indigo-600 invisible has-[:checked]:visible" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
            </label>
        }
    </div>
</div>

@model DuAnTotNghiep.Models.ViewModels.PlacementTest.TestQuestionViewModel

<div class="mb-4">
    <p class="font-medium text-slate-800 text-lg mb-3">@Html.Raw(Model.QuestionText)</p>
    
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="Question Image" class="max-w-full h-auto mb-4 rounded shadow-sm" />
    }

    <div class="mt-3">
        <input type="text" 
               name="answers[@Model.QuestionId]" 
               value="@Model.ExistingAnswer"
               class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-3 border" 
               placeholder="Nhập câu trả lời của bạn vào đây..." />
    </div>
</div>

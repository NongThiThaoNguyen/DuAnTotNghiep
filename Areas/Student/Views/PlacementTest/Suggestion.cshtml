@model DuAnTotNghiep.ViewModels.PlacementTest.PlacementTestSuggestionViewModel
@{
    ViewData["Title"] = "Bài kiểm tra đầu vào đề xuất";
}

<div class="max-w-4xl mx-auto py-12">
    <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">Bài Kiểm Tra Năng Lực</h2>
        <p class="text-slate-500 text-lg">Hệ thống đã chọn lọc bài kiểm tra phù hợp nhất dựa trên mục tiêu học tập của bạn.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-blue-50 text-blue-700 p-4 rounded-xl mb-6 border border-blue-200 font-medium">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Hồ sơ học tập -->
        <div class="bg-white shadow-sm rounded-2xl p-6 border border-slate-200">
            <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center text-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </span>
                Hồ sơ của bạn
            </h3>
            
            <div class="space-y-4">
                <div class="flex justify-between items-center py-3 border-b border-slate-50">
                    <span class="text-slate-500">Mục tiêu học tập:</span>
                    <span class="font-bold text-slate-800">@Model.GoalName</span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-slate-50">
                    <span class="text-slate-500">Trình độ hiện tại:</span>
                    <span class="font-bold text-slate-800">@Model.CurrentLevelName</span>
                </div>
                <div class="py-3">
                    <span class="text-slate-500 block mb-2">Kỹ năng ưu tiên:</span>
                    <div class="flex flex-wrap gap-2">
                        @if (Model.PrioritySkills != null && Model.PrioritySkills.Any())
                        {
                            foreach (var skill in Model.PrioritySkills)
                            {
                                <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-sm font-medium border border-blue-100">@skill</span>
                            }
                        }
                        else
                        {
                            <span class="text-slate-400 italic">Chưa xác định</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Bài Test Đề Xuất -->
        <div class="bg-blue-600 shadow-lg shadow-blue-600/30 rounded-2xl p-6 text-white relative overflow-hidden">
            <!-- Decorative circle -->
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-white opacity-10 rounded-full blur-2xl"></div>
            
            <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                <span class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                </span>
                Bài test đề xuất
            </h3>
            
            <div class="mb-8 relative z-10">
                <h4 class="text-2xl font-bold mb-2">@Model.SuggestedTestTitle</h4>
                <p class="text-blue-100 mb-6 line-clamp-3">@(string.IsNullOrEmpty(Model.SuggestedTestDescription) ? "Bài kiểm tra đầu vào được thiết kế riêng để đánh giá năng lực của bạn." : Model.SuggestedTestDescription)</p>
                
                <div class="flex items-center gap-6">
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="font-medium text-blue-50">@(Model.TimeLimitMinutes?.ToString() ?? "Không giới hạn") phút</span>
                    </div>
                </div>
            </div>

            <form method="post" asp-action="Start" class="relative z-10">
                @Html.AntiForgeryToken()
                <input type="hidden" name="suggestedTestId" value="@Model.SuggestedTestId" />
                <button type="submit" class="w-full py-4 rounded-xl bg-white text-blue-600 font-bold hover:bg-slate-50 transition-colors shadow-sm flex justify-center items-center gap-2 text-lg">
                    Bắt đầu làm bài
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </form>
        </div>
    </div>
</div>

@model DuAnTotNghiep.Models.ViewModels.PlacementTest.TestTakingViewModel

@{
    ViewData["Title"] = Model.TestTitle;
    Layout = "_Layout";
}

<div class="max-w-5xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-6">
        <div class="p-6 sm:flex sm:items-center sm:justify-between">
            <div class="sm:flex-auto">
                <h1 class="text-2xl font-bold text-slate-900">@Model.TestTitle</h1>
                <div class="mt-2 flex items-center text-sm text-slate-500">
                    <span class="mr-4">Trạng thái: <span class="font-medium text-indigo-600">@Model.Status</span></span>
                    <span id="autoSaveIndicator" class="text-slate-400"></span>
                </div>
            </div>
            <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
                <div class="bg-slate-50 rounded-lg p-4 border border-slate-100 text-center">
                    <div class="text-sm font-medium text-slate-500 mb-1">Thời gian còn lại</div>
                    <div id="countdown" class="text-3xl font-mono font-bold text-slate-800">
                        --:--
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form id="testForm" asp-action="Submit" method="post">
        <input type="hidden" name="attemptId" value="@Model.AttemptId" />

        <!-- Main Content -->
        @if (Model.Sections == null || !Model.Sections.Any())
        {
            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded-md mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-yellow-800">Thông báo từ hệ thống</h3>
                        <div class="mt-2 text-sm text-yellow-700">
                            <p>Không có dữ liệu phần thi. Bài kiểm tra này có thể chưa được cấu hình câu hỏi.</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            int questionCounter = 1;
            foreach (var testSection in Model.Sections)
            {
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-8">
                    <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
                        <h2 class="text-xl font-bold text-slate-800">Section @testSection.OrderIndex - @testSection.SectionTitle</h2>
                        <div class="flex items-center space-x-2 mt-1">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                                @testSection.SkillName
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(testSection.Instruction))
                        {
                            <p class="mt-3 text-sm text-slate-600 italic">@testSection.Instruction</p>
                        }
                    </div>
                    
                    <div class="p-6">
                        @if (testSection.Questions == null || !testSection.Questions.Any())
                        {
                            <p class="text-slate-500 italic">Section data unavailable (no questions).</p>
                        }
                        else
                        {
                            foreach (var question in testSection.Questions)
                            {
                                <div class="mb-8 border-b border-slate-100 pb-6 last:border-0 last:pb-0">
                                    <div class="flex items-start">
                                        <div class="flex-shrink-0 mt-0.5">
                                            <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-slate-100 text-slate-700 font-bold text-sm">
                                                @questionCounter
                                            </span>
                                        </div>
                                        <div class="ml-4 w-full">
                                            @if (question.QuestionType == "MCQ")
                                            {
                                                <partial name="Partials/_QuestionMcq" model="question" />
                                            }
                                            else if (question.QuestionType == "TRUE_FALSE")
                                            {
                                                <partial name="Partials/_QuestionTrueFalse" model="question" />
                                            }
                                            else if (question.QuestionType == "SHORT_ANSWER")
                                            {
                                                <partial name="Partials/_QuestionShortAnswer" model="question" />
                                            }
                                            else if (question.QuestionType == "LISTENING" || !string.IsNullOrEmpty(question.AudioUrl))
                                            {
                                                <partial name="Partials/_QuestionListening" model="question" />
                                            }
                                            else
                                            {
                                                // Default fallback to MCQ if not recognized
                                                <partial name="Partials/_QuestionMcq" model="question" />
                                            }
                                        </div>
                                    </div>
                                </div>
                                questionCounter++;
                            }
                        }
                    </div>
                </div>
            }
        }

        <!-- Submit Area -->
        <div class="flex justify-end mt-8">
            <button id="btnSubmit" type="submit" class="inline-flex items-center px-8 py-3 border border-transparent text-lg font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150">
                Submit Test
                <svg class="ml-2 -mr-1 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var timeLimitMinutes = @(Model.EndTime.HasValue ? 1 : 0);
            if (timeLimitMinutes === 0) {
                document.getElementById('countdown').innerText = "Không giới hạn";
                return;
            }

            var serverTimeMs = new Date('@Model.ServerTime.ToString("o")').getTime();
            var endTimeMs = new Date('@Model.EndTime?.ToString("o")').getTime();
            var clientLoadTimeMs = new Date().getTime();
            
            // Calculate how much time is left in milliseconds
            var distance = endTimeMs - serverTimeMs;
            var isSubmitting = false;

            function updateCountdown() {
                if (isSubmitting) return;

                var currentClientMs = new Date().getTime();
                var elapsedSinceLoad = currentClientMs - clientLoadTimeMs;
                var currentDistance = distance - elapsedSinceLoad;

                if (currentDistance <= 0) {
                    isSubmitting = true;
                    document.getElementById('countdown').innerText = "00:00";
                    document.getElementById('countdown').classList.add('text-red-600');
                    
                    // Timeout actions
                    if (typeof timerInterval !== 'undefined') {
                        clearInterval(timerInterval);
                    }
                    
                    // Replace alert with a non-blocking UI update if possible, or just one alert
                    alert("Đã hết thời gian làm bài! Hệ thống sẽ tự động nộp bài.");
                    
                    // Auto submit
                    document.getElementById('btnSubmit').disabled = true;
                    document.getElementById('btnSubmit').innerHTML = "Đang nộp bài...";
                    document.getElementById('testForm').submit();
                    return;
                }

                var minutes = Math.floor(currentDistance / (1000 * 60));
                var seconds = Math.floor((currentDistance % (1000 * 60)) / 1000);

                var minStr = minutes < 10 ? "0" + minutes : minutes;
                var secStr = seconds < 10 ? "0" + seconds : seconds;

                document.getElementById('countdown').innerText = minStr + ":" + secStr;

                if (minutes < 5) {
                    document.getElementById('countdown').classList.add('text-orange-500');
                }
            }

            updateCountdown();
            var timerInterval;
            if (!isSubmitting) {
                timerInterval = setInterval(updateCountdown, 1000);
            }

            // Auto Save Logic
            const form = document.getElementById('testForm');
            const attemptId = document.querySelector('input[name="attemptId"]').value;
            const indicator = document.getElementById('autoSaveIndicator');

            form.addEventListener('change', function(e) {
                if(e.target.tagName === 'INPUT') {
                    const nameAttr = e.target.getAttribute('name');
                    if(nameAttr && nameAttr.startsWith('answers[')) {
                        // Extract question id from answers[123]
                        const match = nameAttr.match(/answers\[(\d+)\]/);
                        if(match && match[1]) {
                            const questionId = match[1];
                            const answerValue = e.target.value;

                            indicator.innerText = "Trạng thái lưu: Đang lưu...";
                            indicator.className = "text-slate-500 italic";

                            fetch('/Student/PlacementTest/SaveAnswer', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({
                                    attemptId: parseInt(attemptId),
                                    questionId: parseInt(questionId),
                                    answerValue: answerValue
                                })
                            })
                            .then(response => response.json())
                            .then(data => {
                                if(data.success) {
                                    const date = new Date(data.savedAt);
                                    const timeStr = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                                    indicator.innerText = "Đã lưu lúc " + timeStr;
                                    indicator.className = "text-green-600";
                                } else {
                                    indicator.innerText = "Lỗi lưu: " + data.message;
                                    indicator.className = "text-red-500";
                                }
                            })
                            .catch(error => {
                                indicator.innerText = "Lỗi mạng, không thể lưu tạm!";
                                indicator.className = "text-red-500";
                                console.error('Error auto-saving:', error);
                            });
                        }
                    }
                }
            });

            // Prevent manual submit without confirmation
            form.addEventListener('submit', function(e) {
                if (!isSubmitting) {
                    if (!confirm('Bạn có chắc muốn nộp bài? Sau khi nộp sẽ không thể chỉnh sửa.')) {
                        e.preventDefault();
                    } else {
                        isSubmitting = true;
                        document.getElementById('btnSubmit').disabled = true;
                        document.getElementById('btnSubmit').innerHTML = "Đang nộp bài...";
                    }
                }
            });
        });
    </script>
}

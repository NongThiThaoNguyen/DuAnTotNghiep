@model DuAnTotNghiep.DTOs.PlacementTest.PlacementTestDto

@{
    ViewData["Title"] = "Bài kiểm tra đầu vào";
    Layout = "_Layout";
}

<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
        <div class="bg-indigo-600 px-6 py-8 sm:p-10 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-indigo-500 mb-4 shadow-sm">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
            </div>
            <h1 class="text-3xl font-extrabold text-white sm:text-4xl">
                Placement Test Required
            </h1>
            <p class="mt-4 text-lg text-indigo-100">
                Bạn cần hoàn thành bài kiểm tra đầu vào để hệ thống AI có thể thiết kế lộ trình học cá nhân hóa tốt nhất cho bạn.
            </p>
        </div>

        <div class="px-6 py-8 sm:p-10 bg-slate-50">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="mb-6 bg-green-50 border border-green-200 rounded-xl p-4 flex items-start gap-3 shadow-sm">
                    <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="text-sm text-green-800 font-medium">
                        @TempData["SuccessMessage"]
                    </div>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4 flex items-start gap-3 shadow-sm">
                    <svg class="w-5 h-5 text-red-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="text-sm text-red-800 font-medium">
                        @TempData["ErrorMessage"]
                    </div>
                </div>
            }

            @if (Model == null)
            {
                <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded-md">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-yellow-800">Thông báo từ hệ thống</h3>
                            <div class="mt-2 text-sm text-yellow-700">
                                <p>Hiện chưa có bài kiểm tra đầu vào khả dụng. Vui lòng liên hệ quản trị viên hoặc quay lại sau.</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="prose prose-indigo max-w-none text-slate-600 mb-8">
                    <h3>Vì sao cần làm bài kiểm tra này?</h3>
                    <ul>
                        <li>Xác định chính xác năng lực hiện tại của bạn qua các kỹ năng (Từ vựng, Ngữ pháp, Nghe, Đọc).</li>
                        <li>Hệ thống AI sẽ phân tích các điểm mạnh và điểm yếu.</li>
                        <li>Dựa vào kết quả này và mục tiêu bạn đã chọn ở phần Onboarding, một <strong>Learning Path (Lộ trình học)</strong> riêng biệt sẽ được tạo ra cho bạn.</li>
                    </ul>

                    <div class="bg-white p-5 rounded-xl border border-slate-200 mt-6 shadow-sm">
                        <h4 class="font-bold text-slate-900 mt-0 mb-3 border-b border-slate-100 pb-2">Thông tin bài kiểm tra</h4>
                        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-4">
                            <div>
                                <dt class="text-sm font-medium text-slate-500">Tên bài thi</dt>
                                <dd class="mt-1 font-semibold text-slate-900">@Model.Title</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-slate-500">Thời gian làm bài</dt>
                                <dd class="mt-1 font-semibold text-slate-900">@(Model.TimeLimitMinutes?.ToString() ?? "Không giới hạn") phút</dd>
                            </div>
                            <div class="sm:col-span-2">
                                <dt class="text-sm font-medium text-slate-500">Mô tả</dt>
                                <dd class="mt-1 text-sm text-slate-700">@(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)</dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <div class="mt-8 flex justify-center">
                    <form asp-action="Start" method="post">
                        <input type="hidden" name="testId" value="@Model.Id" />
                        <button type="submit" class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-full shadow-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors transform hover:scale-105 duration-200">
                            Start Placement Test
                            <svg class="ml-2 -mr-1 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </button>
                    </form>
                </div>
                <p class="text-center text-xs text-slate-400 mt-4">Sau khi bắt đầu, thời gian sẽ được tính. Hãy chuẩn bị sẵn sàng!</p>
            }
        </div>
    </div>
</div>

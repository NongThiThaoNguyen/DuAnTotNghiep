@model DuAnTotNghiep.Models.ViewModels.PlacementTest.TestResultViewModel
@{
    ViewData["Title"] = "Kết quả bài kiểm tra";
    Layout = "_Layout";
}

<div class="max-w-5xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 bg-green-50 border border-green-200 rounded-xl p-4 flex items-start gap-3 shadow-sm">
            <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="text-sm text-green-800 font-medium">
                @TempData["SuccessMessage"]
            </div>
        </div>
    }

    <!-- Header & Overall Score -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-8 py-10 px-6 relative">
        <div class="absolute top-0 inset-x-0 h-2 bg-gradient-to-r from-blue-500 to-indigo-600"></div>
        
        <div class="flex justify-between items-start mb-6">
            <div>
                <h1 class="text-3xl font-extrabold text-slate-900 mb-2">Kết Quả Sơ Bộ Bài Kiểm Tra</h1>
                <p class="text-slate-500">Nộp bài lúc: @(Model.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>
            </div>
            @if (Model.AiCompleted)
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <span class="w-2 h-2 rounded-full bg-green-500"></span>
                    AI Analysis Ready
                </span>
            }
            else
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                    <span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
                    AI đang phân tích...
                </span>
            }
        </div>

        <div class="flex flex-col md:flex-row justify-center items-center gap-8 md:gap-16 mt-8">
            <div class="flex flex-col items-center">
                <div class="text-sm font-medium text-slate-500 uppercase tracking-wider mb-2">Tổng Điểm</div>
                <div class="text-5xl font-black text-indigo-600">@Model.TotalScore <span class="text-2xl text-slate-400 font-medium">/ @Model.MaxScore</span></div>
                <div class="mt-2 text-lg font-semibold text-slate-700">@Model.Percentage.ToString("0.##")%</div>
            </div>

            <div class="hidden md:block w-px h-24 bg-slate-200"></div>

            <div class="flex flex-col items-center">
                <div class="text-sm font-medium text-slate-500 uppercase tracking-wider mb-2">Trình Độ Ước Lượng</div>
                <div class="w-24 h-24 rounded-full bg-gradient-to-br from-indigo-100 to-blue-50 flex items-center justify-center border-4 border-white shadow-md ring-1 ring-slate-100">
                    <span class="text-4xl font-black text-indigo-600">@Model.EstimatedLevel</span>
                </div>
            </div>
        </div>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 border-t border-slate-100 pt-8">
            <div class="text-center">
                <div class="text-3xl font-bold text-slate-700">@Model.TotalQuestions</div>
                <div class="text-sm font-medium text-slate-500 uppercase mt-1">Tổng Số Câu</div>
            </div>
            <div class="text-center">
                <div class="text-3xl font-bold text-green-600">@Model.CorrectAnswers</div>
                <div class="text-sm font-medium text-slate-500 uppercase mt-1">Câu Đúng</div>
            </div>
            <div class="text-center">
                <div class="text-3xl font-bold text-red-500">@Model.IncorrectAnswers</div>
                <div class="text-sm font-medium text-slate-500 uppercase mt-1">Câu Sai</div>
            </div>
        </div>
    </div>

    <!-- Weaknesses Summary -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-orange-50 rounded-xl p-6 border border-orange-100 flex items-start gap-4">
            <div class="bg-orange-100 text-orange-600 p-3 rounded-lg shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div>
                <h3 class="text-sm font-bold text-orange-800 uppercase tracking-wider">Kỹ Năng Yếu Nhất</h3>
                <p class="text-lg font-semibold text-orange-900 mt-1">@(Model.WeakestSkill ?? "Không có dữ liệu")</p>
                <p class="text-sm text-orange-700 mt-1">Hệ thống AI sẽ tập trung cải thiện kỹ năng này trong lộ trình học của bạn.</p>
            </div>
        </div>
        
        <div class="bg-amber-50 rounded-xl p-6 border border-amber-100 flex items-start gap-4">
            <div class="bg-amber-100 text-amber-600 p-3 rounded-lg shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
            </div>
            <div>
                <h3 class="text-sm font-bold text-amber-800 uppercase tracking-wider">Chủ Đề Yếu Nhất</h3>
                <p class="text-lg font-semibold text-amber-900 mt-1">@(Model.WeakestTopic ?? "Không có dữ liệu")</p>
                <p class="text-sm text-amber-700 mt-1">Cần tăng cường từ vựng và bài tập xoay quanh chủ đề này.</p>
            </div>
        </div>
    </div>

    <!-- Skill Performance -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-8">
        <div class="px-6 py-5 border-b border-slate-200 bg-slate-50">
            <h3 class="text-lg font-bold text-slate-800">Phân Tích Theo Kỹ Năng (Skill Performance)</h3>
        </div>
        <div class="p-6">
            @if (Model.SkillScores.Any())
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200">
                        <thead>
                            <tr>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Kỹ năng</th>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Điểm số</th>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Tỷ lệ</th>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider w-1/3">Mức độ</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var skill in Model.SkillScores)
                            {
                                <tr>
                                    <td class="px-3 py-4 whitespace-nowrap font-medium text-slate-800">@skill.SkillName</td>
                                    <td class="px-3 py-4 whitespace-nowrap text-slate-600">@skill.EarnedScore / @skill.MaxScore</td>
                                    <td class="px-3 py-4 whitespace-nowrap font-semibold @(skill.Percentage >= 80 ? "text-green-600" : (skill.Percentage >= 50 ? "text-yellow-600" : "text-red-600"))">
                                        @skill.Percentage.ToString("0.##")%
                                    </td>
                                    <td class="px-3 py-4 whitespace-nowrap">
                                        <div class="w-full bg-slate-200 rounded-full h-2">
                                            <div class="h-2 rounded-full @(skill.Percentage >= 80 ? "bg-green-500" : (skill.Percentage >= 50 ? "bg-yellow-500" : "bg-red-500"))" style="width: @skill.Percentage.ToString("0.##").Replace(",", ".")%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-slate-500 italic text-center py-4">Chưa có dữ liệu phân tích kỹ năng.</p>
            }
        </div>
    </div>

    <!-- Topic Performance -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-8">
        <div class="px-6 py-5 border-b border-slate-200 bg-slate-50">
            <h3 class="text-lg font-bold text-slate-800">Phân Tích Theo Chủ Đề (Topic Performance)</h3>
        </div>
        <div class="p-6">
            @if (Model.TopicScores.Any())
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200">
                        <thead>
                            <tr>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Chủ đề</th>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Điểm số</th>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Tỷ lệ</th>
                                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider w-1/3">Mức độ</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var topic in Model.TopicScores)
                            {
                                <tr>
                                    <td class="px-3 py-4 whitespace-nowrap font-medium text-slate-800">@topic.TopicName</td>
                                    <td class="px-3 py-4 whitespace-nowrap text-slate-600">@topic.EarnedScore / @topic.MaxScore</td>
                                    <td class="px-3 py-4 whitespace-nowrap font-semibold @(topic.Percentage >= 80 ? "text-green-600" : (topic.Percentage >= 50 ? "text-yellow-600" : "text-red-600"))">
                                        @topic.Percentage.ToString("0.##")%
                                    </td>
                                    <td class="px-3 py-4 whitespace-nowrap">
                                        <div class="w-full bg-slate-200 rounded-full h-2">
                                            <div class="h-2 rounded-full @(topic.Percentage >= 80 ? "bg-green-500" : (topic.Percentage >= 50 ? "bg-yellow-500" : "bg-red-500"))" style="width: @topic.Percentage.ToString("0.##").Replace(",", ".")%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-slate-500 italic text-center py-4">Chưa có dữ liệu phân tích chủ đề.</p>
            }
        </div>
    </div>

    <!-- Actions -->
    <div class="flex justify-center mt-10">
        @if (Model.AiCompleted)
        {
            <a asp-controller="LearningPath" asp-action="Index" class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-xl shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all hover:shadow-md">
                Xem lộ trình học (AI Learning Path)
                <svg class="ml-2 -mr-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="inline-flex items-center px-8 py-3 border border-slate-300 text-base font-medium rounded-xl shadow-sm text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all hover:shadow-md">
                <svg class="mr-2 -ml-1 h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Quay về Dashboard
            </a>
        }
    </div>

</div>
